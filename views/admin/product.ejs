        <!-- ===================== CROP MODAL (VARIANT EDIT) ===================== -->
        <div id="cropModalVariantEdit">
            <div class="crop-box">
                <div style="display:flex; justify-content:space-between; margin-bottom:14px; align-items:center;">
                    <h3>Crop Variant Image <span id="cropProgressVariantEdit" style="color:#888; font-size:13px;"></span>
                    </h3>
                </div>
                <img id="cropImageVariantEdit">
                <div style="display:flex; gap:10px; margin-top:14px; justify-content:flex-end;">
                    <button class="btn-grey" id="skipCropBtnVariantEdit">Skip</button>
                    <button class="btn-dark" id="cropDoneBtnVariantEdit">✅ Crop & Next</button>
                </div>
            </div>
        </div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
        <script>
            const currentPageProducts = <%- JSON.stringify(products) %>;

            function openEditModalByIndex(index) {
                const p = currentPageProducts[index];
                if (p) {
                    openEditModal({
                        _id: p._id,
                        name: p.name,
                        price: p.price,
                        stock: p.stock,
                        description: p.description,
                        category: p.category?._id,
                        status: p.status,
                        images: p.images,
                        size: p.size || "",
                        color: p.color || "",
                        variants: p.variants || [],
                        isActive: p.isActive
                    });
                }
            }



            // ════════════════════════════════════════════════════════
            //  HELPERS
            // ════════════════════════════════════════════════════════


            function openModal(id) { document.getElementById(id).style.display = 'flex'; }
            function closeModal(id) { document.getElementById(id).style.display = 'none'; }

            function showToast(msg, color) {
                Toastify({
                    text: msg, duration: 3000, gravity: 'top', position: 'right',
                    backgroundColor: color === 'green' ? '#2ecc71' : '#e74c3c'
                }).showToast();
            }


            // ════════════════════════════════════════════════════════
            //  VARIANT CONFIG
            // ════════════════════════════════════════════════════════
            const SIZES = ['XS', 'S', 'M', 'L', 'XL', 'XXL'];
            const COLORS = [
                { name: 'Red', hex: '#e74c3c' },
                { name: 'Blue', hex: '#3498db' },
                { name: 'Green', hex: '#2ecc71' },
                { name: 'Black', hex: '#1a1a1a' },
                { name: 'White', hex: '#f5f5f5' },
                { name: 'Yellow', hex: '#f1c40f' },
                { name: 'Pink', hex: '#e91e8c' },
                { name: 'Gray', hex: '#95a5a6' },
                { name: 'Navy', hex: '#2c3e7a' },
                { name: 'Brown', hex: '#8d5524' },
            ];

            // Sync empty-state hint for a variant tbody
            function syncEmptyState(tbodyId) {
                const tbody = document.getElementById(tbodyId);
                const emptyId = tbodyId === 'addVariantsBody' ? 'addVariantEmpty' : 'editVariantEmpty';
                const empty = document.getElementById(emptyId);
                if (!empty) return;
                empty.style.display = tbody.querySelectorAll('tr').length === 0 ? 'block' : 'none';
            }

            // Add a single variant row (optionally pre-filled with data)
            function addVariantRow(tbodyId, data = {}) {
                const tbody = document.getElementById(tbodyId);

                const sizeOptions = SIZES.map(s =>
                    `<option value="${s}" ${data.size === s ? 'selected' : ''}>${s}</option>`
                ).join('');

                const colorOptions = COLORS.map(c =>
                    `<option value="${c.name}" ${data.color === c.name ? 'selected' : ''} data-hex="${c.hex}">${c.name}</option>`
                ).join('');

                const tr = document.createElement('tr');
                tr.innerHTML = `
        <td>
            <select onchange="highlightRow(this)">
                <option value="">-- Size --</option>
                ${sizeOptions}
            </select>
        </td>
        <td>
            <select onchange="updateColorDot(this)">
                <option value="">-- Color --</option>
                ${colorOptions}
            </select>
        </td>
        <td>
            <input type="number" min="0" value="${data.stock !== undefined ? data.stock : 0}"
                placeholder="0" style="text-align:center;">
        </td>
        <td>
            <input type="number" min="0" value="${data.price || ''}"
                placeholder="Optional">
        </td>
        <td style="text-align:center;">
            <button type="button" class="btn-remove-variant"
                onclick="removeVariantRow(this, '${tbodyId}')">✕</button>
        </td>
    `;

                tbody.appendChild(tr);
                syncEmptyState(tbodyId);

                // If color was pre-filled, show the dot immediately
                const colorSelect = tr.querySelector('td:nth-child(2) select');
                if (data.color) updateColorDot(colorSelect);
            }

            // Remove a variant row
            function removeVariantRow(btn, tbodyId) {
                btn.closest('tr').remove();
                syncEmptyState(tbodyId);
            }




            // ════════════════════════════════════════════════════════
            //  CROPPER FACTORY
            // ════════════════════════════════════════════════════════
            function makeCropperFlow({ inputEl, progressEl, cropImgEl, cropModalEl, cropDoneBtn, skipBtn, previewEl, countEl, onDone, minFiles = 1 }) {
                let cropper = null, queue = [], blobs = [], idx = 0;

                inputEl.addEventListener('change', function () {
                    if (this.files.length < minFiles) {
                        showToast(`Please select at least ${minFiles} image(s)`, 'red');
                        this.value = '';
                        return;
                    }
                    queue = Array.from(this.files);
                    blobs = []; idx = 0;
                    previewEl.innerHTML = '';
                    openCrop(0);
                });

                function openCrop(i) {
                    progressEl.textContent = `(${i + 1} of ${queue.length})`;
                    const reader = new FileReader();
                    reader.onload = e => {
                        cropImgEl.src = e.target.result;
                        cropModalEl.classList.add('show');
                        if (cropper) cropper.destroy();
                        cropper = new Cropper(cropImgEl, { aspectRatio: 1, viewMode: 1 });
                    };
                    reader.readAsDataURL(queue[i]);
                }

                cropDoneBtn.addEventListener('click', () => {
                    cropper.getCroppedCanvas({ width: 800, height: 800 }).toBlob(blob => {
                        const blobWithId = { id: Date.now() + Math.random(), blob, name: queue[idx].name };
                        blobs.push(blobWithId);
                        addThumb(blobWithId);
                        next();
                    }, 'image/jpeg', 0.9);
                });

                skipBtn.addEventListener('click', () => {
                    const blobWithId = { id: Date.now() + Math.random(), blob: queue[idx], name: queue[idx].name };
                    blobs.push(blobWithId);
                    addThumb(blobWithId);
                    next();
                });

                function next() {
                    idx++;
                    if (idx < queue.length) {
                        openCrop(idx);
                    } else {
                        cropModalEl.classList.remove('show');
                        if (cropper) { cropper.destroy(); cropper = null; }
                        countEl.textContent = `${blobs.length} images ready ✅`;
                        inputEl.value = ''; // Reset input to allow re-selection
                        if (onDone) onDone(blobs);
                    }
                }

                function addThumb(item) {
                    const wrap = document.createElement('div');
                    wrap.className = 'img-container';
                    wrap.dataset.id = item.id;
                    
                    const img = document.createElement('img');
                    img.src = URL.createObjectURL(item.blob);
                    img.style.width = '120px';
                    img.style.height = '120px';
                    img.style.objectFit = 'cover';
                    img.style.borderRadius = '8px';
                    img.style.border = '2px solid var(--primary-orange)';
                    img.style.boxShadow = '0 4px 8px rgba(0,0,0,0.1)';
                    img.style.transition = 'transform 0.2s';
                    img.onmouseover = () => img.style.transform = 'scale(1.05)';
                    img.onmouseout = () => img.style.transform = 'scale(1)';

                    const del = document.createElement('div');
                    del.className = 'img-delete-btn';
                    del.innerHTML = '✕';
                    del.onclick = () => {
                        blobs = blobs.filter(b => b.id !== item.id);
                        wrap.remove();
                        countEl.textContent = blobs.length > 0 ? `${blobs.length} images ready ✅` : 'No images selected';
                    };

                    wrap.appendChild(img);
                    wrap.appendChild(del);
                    previewEl.appendChild(wrap);
                }

                return { 
                    getBlobs: () => blobs,
                    clear: () => { blobs = []; previewEl.innerHTML = ''; countEl.textContent = 'No images selected'; }
                };
            }

            // Wire up ADD cropper (1 image required)
            const addCropper = makeCropperFlow({
                inputEl: document.getElementById('addImageInput'),
                progressEl: document.getElementById('cropProgress'),
                cropImgEl: document.getElementById('cropImage'),
                cropModalEl: document.getElementById('cropModal'),
                cropDoneBtn: document.getElementById('cropDoneBtn'),
                skipBtn: document.getElementById('skipCropBtn'),
                previewEl: document.getElementById('addPreview'),
                countEl: document.getElementById('addImgCount'),
                minFiles: 1
            });

            // Wire up EDIT cropper (1 image if changing)
            const editCropper = makeCropperFlow({
                inputEl: document.getElementById('editImageInput'),
                progressEl: document.getElementById('cropProgressEdit'),
                cropImgEl: document.getElementById('cropImageEdit'),
                cropModalEl: document.getElementById('cropModalEdit'),
                cropDoneBtn: document.getElementById('cropDoneBtnEdit'),
                skipBtn: document.getElementById('skipCropBtnEdit'),
                previewEl: document.getElementById('editPreview'),
                countEl: document.getElementById('editImgCount'),
                minFiles: 1
            });

            // Wire up VARIANT cropper (1 image required)
            const variantCropper = makeCropperFlow({
                inputEl: document.getElementById('variantImageInput'),
                progressEl: document.getElementById('cropProgressVariant'),
                cropImgEl: document.getElementById('cropImageVariant'),
                cropModalEl: document.getElementById('cropModalVariant'),
                cropDoneBtn: document.getElementById('cropDoneBtnVariant'),
                skipBtn: document.getElementById('skipCropBtnVariant'),
                previewEl: document.getElementById('variantPreview'),
                countEl: document.getElementById('variantImgCount'),
                minFiles: 1
            });

            // Wire up EDIT VARIANT cropper
            const editVariantCropper = makeCropperFlow({
                inputEl: document.getElementById('editVariantImageInput'),
                progressEl: document.getElementById('cropProgressVariantEdit'),
                cropImgEl: document.getElementById('cropImageVariantEdit'),
                cropModalEl: document.getElementById('cropModalVariantEdit'),
                cropDoneBtn: document.getElementById('cropDoneBtnVariantEdit'),
                skipBtn: document.getElementById('skipCropBtnVariantEdit'),
                previewEl: document.getElementById('editVariantPreview'),
                countEl: document.getElementById('editVariantImgCount'),
                minFiles: 1
            });


            // ════════════════════════════════════════════════════════
            //  ADD PRODUCT — SUBMIT
            // ════════════════════════════════════════════════════════
            async function submitAddProduct() {
                const name = document.getElementById('addName').value.trim();
                const category = document.getElementById('addCategory').value;
                const price = document.getElementById('addPrice').value;
                const description = document.getElementById('addDescription').value.trim();
                const size = document.getElementById('addSize').value;
                const color = document.getElementById('addColor').value;
                const stock = document.getElementById('addStock').value;
                const isActive = document.getElementById('addIsActive').checked;
                const blobs = addCropper.getBlobs();

                // Validate basic fields (allow 0 for price/stock)
                if (name === "" || category === "" || price === "" || stock === "") {
                    return showToast('Fill all required fields', 'red');
                }
                if (price < 0) return showToast('Price cannot be negative', 'red');
                if (stock < 0) return showToast('Stock cannot be negative', 'red');
                if (blobs.length < 1) return showToast('Upload & crop at least 1 image', 'red');

                const fd = new FormData();
                fd.append('name', name);
                fd.append('category', category);
                fd.append('price', price);
                fd.append('description', description);
                fd.append('stock', stock);
                fd.append('isActive', isActive);
                fd.append('size', size);
                fd.append('color', color);
                blobs.forEach(({ blob, name: n }, i) => fd.append('images', blob, `img_${i}_${n}`));

                try {
                    const res = await fetch('/admin/addProduct', { method: 'POST', body: fd });
                    if (res.ok || res.redirected) {
                        showToast('Product added!', 'green');
                        setTimeout(() => location.href = '/admin/product', 1200);
                    } else {
                        const data = await res.json();
                        showToast(data.message || 'Failed to add product', 'red');
                    }
                } catch { showToast('Server error', 'red'); }
            }


            // ════════════════════════════════════════════════════════
            //  EDIT PRODUCT — OPEN MODAL
            // ════════════════════════════════════════════════════════
            function openEditModal(p) {
                document.getElementById('editProductId').value = p._id;
                document.getElementById('editName').value = p.name;
                document.getElementById('editPrice').value = p.price;
                document.getElementById('editStock').value = p.stock || 0;
                document.getElementById('editDescription').value = p.description || '';
                document.getElementById('editIsActive').checked = p.isActive === true;
                document.getElementById('editCategory').value = p.category || '';
                document.getElementById('editSize').value = p.size || '';
                document.getElementById('editColor').value = p.color || '';
                document.getElementById('editImgCount').textContent = '';
                document.getElementById('editPreview').innerHTML = '';

                // Show current images
                const cur = document.getElementById('editCurrentImages');
                cur.innerHTML = '';
                (p.images || []).forEach(src => {
                    const img = document.createElement('img');
                    img.src = src;
                    cur.appendChild(img);
                });

                // Show Variants
                const vList = document.getElementById('editVariantsList');
                vList.innerHTML = '';
                if (p.variants && p.variants.length > 0) {
                    p.variants.forEach((v, vIdx) => {
                        const div = document.createElement('div');
                        div.style = 'display:flex; justify-content:space-between; align-items:center; background:#f5f5f5; padding:8px 12px; border-radius:6px; margin-bottom:5px; font-size:13px;';
                        
                        // Using data attributes to safely store index and avoid quote issues in onclick
                        div.innerHTML = `
                            <span><strong>${v.size}</strong> - ${v.color} (Stock: ${v.stock})</span>
                            <div style="display:flex; gap:8px;">
                                <button type="button" class="btn-orange" style="padding:4px 10px; font-size:11px;" 
                                    onclick='openEditVariantByIndex("${p._id}", ${vIdx})'>Edit</button>
                                <button type="button" style="background:#e74c3c; color:white; border:none; padding:4px 10px; border-radius:4px; cursor:pointer; font-size:11px;" 
                                    onclick='confirmDeleteVariant("${p._id}", "${v._id}")'>Delete</button>
                            </div>
                        `;
                        vList.appendChild(div);
                    });
                } else {
                    vList.innerHTML = '<p style="color:#888; font-size:12px;">No variants added yet.</p>';
                }

                // Store current variants for the modal to reference by index
                window.currentEditVariants = p.variants || [];
                openModal('editProductModal');
            }


            // ════════════════════════════════════════════════════════
            //  EDIT PRODUCT — SUBMIT
            // ════════════════════════════════════════════════════════
            async function submitEditProduct() {
                const id = document.getElementById('editProductId').value;
                const name = document.getElementById('editName').value.trim();
                const category = document.getElementById('editCategory').value;
                const price = document.getElementById('editPrice').value;
                const description = document.getElementById('editDescription').value.trim();
                const stock = document.getElementById('editStock').value;
                const size = document.getElementById('editSize').value;
                const color = document.getElementById('editColor').value;
                const isActive = document.getElementById('editIsActive').checked;
                const blobs = editCropper.getBlobs();

                if (name === "" || category === "" || price === "" || stock === "") {
                    return showToast('Fill all required fields', 'red');
                }
                if (price < 0) return showToast('Price cannot be negative', 'red');
                if (stock < 0) return showToast('Stock cannot be negative', 'red');

                const fd = new FormData();
                fd.append('name', name);
                fd.append('category', category);
                fd.append('price', price);
                fd.append('description', description);
                fd.append('stock', stock);
                fd.append('isActive', isActive);
                fd.append('size', size);
                fd.append('color', color);
                blobs.forEach(({ blob, name: n }, i) => fd.append('images', blob, `img_${i}_${n}`));

                try {
                    const res = await fetch(`/admin/product/edit/${id}`, { method: 'POST', body: fd });
                    if (res.ok || res.redirected) {
                        showToast('Product updated!', 'green');
                        setTimeout(() => location.reload(), 1200);
                    } else {
                        const data = await res.json();
                        showToast(data.message || 'Failed to update product', 'red');
                    }
                } catch { showToast('Server error', 'red'); }
            }


            // ════════════════════════════════════════════════════════
            //  DELETE
            // ════════════════════════════════════════════════════════
            let deleteId = null;

            function confirmDelete(id) {
                deleteId = id;
                openModal('deleteModal');
            }

            document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
                if (!deleteId) return;
                try {
                    const res = await fetch(`/admin/product/delete/${deleteId}`, { method: 'PATCH' });
                    const data = await res.json();
                    if (data.success) {
                        showToast('Product deleted!', 'green');
                        document.querySelector(`button[onclick="confirmDelete('${deleteId}')"]`).closest('tr').remove();
                    } else {
                        showToast('Failed to delete', 'red');
                    }
                } catch { showToast('Server error', 'red'); }
                closeModal('deleteModal');
                deleteId = null;
            });


            // ════════════════════════════════════════════════════════
            //  TOGGLE STATUS
            // ════════════════════════════════════════════════════════
            async function toggleStatus(id, checkbox) {
                try {
                    const res = await fetch(`/admin/product/toggle/${id}`, { method: 'PATCH' });
                    const data = await res.json();
                    if (!data.success) {
                        checkbox.checked = !checkbox.checked;
                        showToast('Failed to update status', 'red');
                    } else {
                        showToast(`Status: ${data.status}`, 'green');
                    }
                } catch {
                    checkbox.checked = !checkbox.checked;
                    showToast('Server error', 'red');
                }
            }




            // ════════════════════════════════════════════════════════
            //  ADD VARIANT — LOGIC
            // ════════════════════════════════════════════════════════

            function openAddVariantModal(id) {
                document.getElementById('variantProductId').value = id;
                document.querySelectorAll('input[name="variantSizes"]').forEach(cb => cb.checked = false);
                clearVariantImages();
                openModal('addVariantModal');
            }

            function clearVariantImages() {
                variantCropper.clear();
            }

            async function submitAddVariant() {
                const id = document.getElementById('variantProductId').value;
                const sizeCheckboxes = document.querySelectorAll('input[name="variantSizes"]:checked');
                const sizes = Array.from(sizeCheckboxes).map(cb => cb.value);
                const color = document.getElementById('variantColor').value;
                const stock = document.getElementById('variantStock').value;
                const price = document.getElementById('variantPrice').value;
                const blobs = variantCropper.getBlobs();

                if (sizes.length === 0 || !color || !stock) return showToast('Select at least one size, color, and stock', 'red');

                const fd = new FormData();
                sizes.forEach(s => fd.append('size', s));
                fd.append('color', color);
                fd.append('stock', stock);
                fd.append('price', price || 0);
                blobs.forEach(({ blob, name: n }, i) => fd.append('images', blob, `var_${i}_${n}`));

                try {
                    const res = await fetch(`/admin/product/addVariant/${id}`, { method: 'POST', body: fd });
                    if (res.ok) {
                        showToast('Variant added successfully!', 'green');
                        closeModal('addVariantModal');
                        location.reload(); // Reload to see changes in Edit modal if it was open from table
                    } else {
                        showToast('Failed to add variant', 'red');
                    }
                } catch { showToast('Server error', 'red'); }
            }

            function openEditVariantModal(productId, variant) {
                document.getElementById('editVariantProductId').value = productId;
                document.getElementById('editVariantId').value = variant._id;
                document.getElementById('editVariantSize').value = variant.size;
                document.getElementById('editVariantColor').value = variant.color;
                document.getElementById('editVariantStock').value = variant.stock;
                document.getElementById('editVariantPrice').value = variant.price;
                
                // Show current images
                const cur = document.getElementById('editVariantCurrentImages');
                cur.innerHTML = '';
                (variant.images || []).forEach(src => {
                    const img = document.createElement('img');
                    img.src = src;
                    img.style.width = '60px';
                    img.style.height = '60px';
                    img.style.objectFit = 'cover';
                    img.style.borderRadius = '4px';
                    img.style.marginRight = '5px';
                    cur.appendChild(img);
                });

                editVariantCropper.clear();
                openModal('editVariantModal');
            }

            function clearEditVariantImages() {
                editVariantCropper.clear();
            }

            async function submitEditVariant() {
                const productId = document.getElementById('editVariantProductId').value;
                const variantId = document.getElementById('editVariantId').value;
                const size = document.getElementById('editVariantSize').value;
                const color = document.getElementById('editVariantColor').value;
                const stock = document.getElementById('editVariantStock').value;
                const price = document.getElementById('editVariantPrice').value;
                const blobs = editVariantCropper.getBlobs();

                if (!size || !color || !stock) return showToast('Size, color, and stock are required', 'red');

                const fd = new FormData();
                fd.append('size', size);
                fd.append('color', color);
                fd.append('stock', stock);
                fd.append('price', price || 0);
                blobs.forEach(({ blob, name: n }, i) => fd.append('images', blob, `var_edit_${i}_${n}`));

                try {
                    const res = await fetch(`/admin/product/editVariant/${productId}/${variantId}`, { method: 'POST', body: fd });
                    if (res.ok) {
                        showToast('Variant updated successfully!', 'green');
                        closeModal('editVariantModal');
                        location.reload();
                    } else {
                        showToast('Failed to update variant', 'red');
                    }
                } catch { showToast('Server error', 'red'); }
            }


            // Safe way to open edit variant using cached array index
            function openEditVariantByIndex(productId, index) {
                const variant = window.currentEditVariants[index];
                if (variant) {
                    openEditVariantModal(productId, variant);
                }
            }

            async function confirmDeleteVariant(productId, variantId) {
                if (!confirm('Are you sure you want to delete this variant?')) return;
                try {
                    const res = await fetch(`/admin/product/deleteVariant/${productId}/${variantId}`, { method: 'DELETE' });
                    const data = await res.json();
                    if (data.success) {
                        showToast('Variant deleted!', 'green');
                        location.reload();
                    } else {
                        showToast(data.message || 'Failed to delete variant', 'red');
                    }
                } catch { showToast('Server error', 'red'); }
            }


        </script>
</body>

</html>