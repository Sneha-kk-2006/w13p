<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Product Management</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

    <style>
        :root {
            --primary-orange: #d35b31;
            --sidebar-bg: #f5f1ed;
            --active-green: #2ecc71;
            --inactive-red: #e74c3c;
            --border-light: #e0e0e0;
            --text-dark: #334155;
        }
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Inter',sans-serif; }
        body { background:#f8f9fa; display:flex; min-height:100vh; color:var(--text-dark); }
        .main-content { flex:1; padding:40px; min-width:0; }
        .data-card { background:white; border-radius:12px; border:1px solid var(--border-light); padding:25px; overflow-x:auto; }
        table { width:100%; border-collapse:collapse; min-width:700px; }
        th { text-align:left; padding:15px; border-bottom:2px solid #f0f0f0; color:#666; font-size:14px; }
        td { padding:15px; border-bottom:1px solid #f0f0f0; font-size:14px; vertical-align:middle; }

        /* Toggle */
        .switch { position:relative; display:inline-block; width:44px; height:22px; }
        .switch input { opacity:0; width:0; height:0; }
        .slider { position:absolute; cursor:pointer; top:0; left:0; right:0; bottom:0; background:#ccc; transition:.4s; border-radius:34px; }
        .slider:before { position:absolute; content:""; height:16px; width:16px; left:3px; bottom:3px; background:white; transition:.4s; border-radius:50%; }
        input:checked + .slider { background:var(--active-green); }
        input:checked + .slider:before { transform:translateX(22px); }

        /* Modals */
        .modal-overlay { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.45); backdrop-filter:blur(3px); display:none; align-items:center; justify-content:center; z-index:2000; padding:20px; }
        .modal { background:white; width:100%; max-width:650px; border-radius:14px; padding:30px; max-height:90vh; overflow-y:auto; }
        .form-group { margin-bottom:18px; }
        .form-group label { display:block; font-size:13px; font-weight:600; margin-bottom:7px; color:#555; }
        .form-input { width:100%; padding:11px 14px; border:1px solid var(--border-light); border-radius:8px; outline:none; font-size:14px; background:#f9f9f9; }
        .form-input:focus { border-color:var(--primary-orange); background:white; }
        textarea.form-input { height:90px; resize:vertical; }
        .btn-orange { background:var(--primary-orange); color:white; border:none; padding:11px 24px; border-radius:8px; cursor:pointer; font-weight:600; }
        .btn-dark { background:#334155; color:white; border:none; padding:11px 24px; border-radius:8px; cursor:pointer; font-weight:600; }
        .btn-grey { background:#e5e7eb; color:#333; border:none; padding:11px 24px; border-radius:8px; cursor:pointer; font-weight:600; }

        /* Image previews */
        .preview-wrap { display:flex; gap:10px; flex-wrap:wrap; margin-top:10px; }
        .preview-wrap img { width:80px; height:80px; object-fit:cover; border-radius:8px; border:2px solid var(--border-light); }

        /* Crop modal */
        #cropModal, #cropModalEdit {
            display:none; position:fixed; top:0; left:0; width:100%; height:100%;
            background:rgba(0,0,0,0.75); z-index:3000;
            align-items:center; justify-content:center;
        }
        #cropModal.show, #cropModalEdit.show { display:flex; }
        .crop-box { background:white; padding:25px; border-radius:12px; max-width:520px; width:90%; }
        .crop-box img { max-width:100%; max-height:320px; display:block; }

        /* Pagination */
        .page-link { padding:8px 13px; border-radius:8px; text-decoration:none; color:var(--text-dark); border:1px solid var(--border-light); font-size:14px; }
        .page-link.active { background:var(--primary-orange); color:white; border-color:var(--primary-orange); }
    </style>
</head>
<body>

<%- include('../partials/admin/header') %>

<main class="main-content">

    <!-- Header -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:25px; flex-wrap:wrap; gap:15px;">
        <h1 style="font-size:24px; font-weight:600;">Product Management</h1>
        <button class="btn-dark" style="display:flex; align-items:center; gap:8px;"
            onclick="openModal('addProductModal')">
            <span class="material-symbols-outlined">add</span> Add Product
        </button>
    </div>

    <!-- Search (backend) -->
    <div style="background:white; padding:15px; border-radius:12px; border:1px solid var(--border-light); margin-bottom:20px;">
        <form method="GET" action="/admin/products" style="display:flex; gap:10px; flex-wrap:wrap;">
            <input type="text" name="search" value="<%= search %>"
                placeholder="Search products..."
                style="flex:1; min-width:180px; padding:10px 15px; border:1px solid var(--border-light); border-radius:8px; outline:none;" />
            <button type="submit" style="background:var(--primary-orange); color:white; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; font-weight:600;">
                Search
            </button>
            <% if (search) { %>
                <a href="/admin/products" style="display:flex; align-items:center; color:#888; text-decoration:underline; font-size:13px;">
                    ✕ Clear
                </a>
            <% } %>
        </form>
    </div>

    <!-- Table -->
    <div class="data-card">
        <table>
            <thead>
                <tr>
                    <th>Si.No</th>
                    <th>Image</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (products.length === 0) { %>
                <tr>
                    <td colspan="7" style="text-align:center; color:#888; padding:30px;">
                        No products found <% if(search){ %> for "<%= search %>"<% } %>
                    </td>
                </tr>
                <% } else { %>
                <% products.forEach((p, i) => { %>
                <tr>
                    <td><%= (currentPage - 1) * limit + i + 1 %></td>
                    <td>
                        <img src="<%= p.images?.[0] || '/placeholder.png' %>"
                            style="width:55px; height:55px; object-fit:cover; border-radius:6px;">
                    </td>
                    <td style="font-weight:500;"><%= p.name %></td>
                    <td><%= p.category?.name || '—' %></td>
                    <td>₹<%= p.price %></td>
                    <td>
  <% if(p.stock === 0) { %>
    <span class="text-red-500 font-bold">Out of stock</span>
  <% } else if(p.stock <= 5) { %>
    <span class="text-yellow-500 font-bold"><%= p.stock %> left</span>
  <% } else { %>
    <span class="text-green-500"><%= p.stock %></span>
  <% } %>
</td>
                    <td>
                        <label class="switch">
                            <input type="checkbox" <%= p.isActive  ? 'checked' : '' %>
                                onchange="toggleStatus('<%= p._id %>', this)">
                            <span class="slider"></span>
                        </label>
                    </td>
                    <td>
                        <div style="display:flex; gap:10px; align-items:center;">
                            <button style="background:none; border:none; cursor:pointer; color:var(--primary-orange);"
                                onclick='openEditModal(<%= JSON.stringify({_id: p._id, name: p.name, price: p.price, description: p.description, category: p.category?._id, status: p.status, images: p.images}) %>)'>
                                <span class="material-symbols-outlined">edit_note</span>
                            </button>
                            <button style="background:none; border:none; cursor:pointer; color:var(--inactive-red);"
                                onclick="confirmDelete('<%= p._id %>')">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
                <% }) %>
                <% } %>
            </tbody>
        </table>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
        <div style="display:flex; gap:8px; margin-top:22px; justify-content:center; align-items:center; flex-wrap:wrap;">
            <% if (currentPage > 1) { %>
                <a class="page-link" href="/admin/product?page=<%= currentPage-1 %>&search=<%= search %>">← Prev</a>
            <% } %>
            <% for(let i=1; i<=totalPages; i++) { %>
                <a class="page-link <%= i===currentPage ? 'active' : '' %>"
                   href="/admin/product?page=<%= i %>&search=<%= search %>"><%= i %></a>
            <% } %>
            <% if (currentPage < totalPages) { %>
                <a class="page-link" href="/admin/product?page=<%= currentPage+1 %>&search=<%= search %>">Next →</a>
            <% } %>
            <span style="color:#888; font-size:13px;">Total: <%= total %></span>
        </div>
        <% } %>
    </div>
</main>


<!-- ===================== ADD PRODUCT MODAL ===================== -->
<div class="modal-overlay" id="addProductModal">
    <div class="modal">
        <div style="display:flex; justify-content:space-between; margin-bottom:22px; align-items:center;">
            <h2 style="font-weight:600;">Add Product</h2>
            <span class="material-symbols-outlined" style="cursor:pointer; color:#999;" onclick="closeModal('addProductModal')">close</span>
        </div>

        <div class="form-group">
            <label>Product Name</label>
            <input type="text" id="addName" class="form-input" placeholder="Enter product name">
        </div>
        <div class="form-group">
            <label>Category</label>
            <select id="addCategory" class="form-input">
                <option value="">-- Select Category --</option>
                <% categories.forEach(cat => { %>
                    <option value="<%= cat._id %>"><%= cat.name %></option>
                <% }) %>
            </select>
        </div>
        <div class="form-group">
            <label>Price (₹)</label>
            <input type="number" id="addPrice" class="form-input" placeholder="Enter price" min="0">
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea id="addDescription" class="form-input" placeholder="Product description"></textarea>
        </div>
        <div class="form-group" style="display:flex; justify-content:space-between; align-items:center;">
            <label style="margin:0;">Active Status</label>
            <label class="switch">
                <input type="checkbox" id="addIsActive" checked>
                <span class="slider"></span>
            </label>
        </div>
        <!-- admin/addProduct.ejs or editProduct.ejs -->
<div>
  <label>Stock Quantity</label>
  <input type="number" name="stock" id="addStock" min="0" value="<%= products  ? products .stock : 0 %>" required />
</div>
        <div class="form-group">
            <label>Product Images <span style="color:red; font-size:12px;">(minimum 3 required)</span></label>
            <input type="file" id="addImageInput" multiple accept="image/* "name="images" multiple
                style="width:100%; padding:10px; border:1px dashed #ccc; border-radius:8px; cursor:pointer;">
            <small id="addImgCount" style="color:#888; display:block; margin-top:5px;">No images selected</small>
            <div class="preview-wrap" id="addPreview"></div>
        </div>

        <div style="display:flex; gap:12px; justify-content:flex-end; margin-top:10px;">
            <button class="btn-grey" onclick="closeModal('addProductModal')">Cancel</button>
            <button class="btn-dark" onclick="submitAddProduct()">Save Product</button>
        </div>
    </div>
</div>


<!-- ===================== EDIT PRODUCT MODAL ===================== -->
<div class="modal-overlay" id="editProductModal">
    <div class="modal">
        <div style="display:flex; justify-content:space-between; margin-bottom:22px; align-items:center;">
            <h2 style="font-weight:600;">Edit Product</h2>
            <span class="material-symbols-outlined" style="cursor:pointer; color:#999;" onclick="closeModal('editProductModal')">close</span>
        </div>

        <input type="hidden" id="editProductId">
        <div class="form-group">
            <label>Product Name</label>
            <input type="text" id="editName" class="form-input">
        </div>
        <div class="form-group">
            <label>Category</label>
            <select id="editCategory" class="form-input">
                <option value="">-- Select Category --</option>
                <% categories.forEach(cat => { %>
                    <option value="<%= cat._id %>"><%= cat.name %></option>
                <% }) %>
            </select>
        </div>
        <div class="form-group">
            <label>Price (₹)</label>
            <input type="number" id="editPrice" class="form-input" min="0">
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea id="editDescription" class="form-input"></textarea>
        </div>
        <div class="form-group" style="display:flex; justify-content:space-between; align-items:center;">
            <label style="margin:0;">Active Status</label>
            <label class="switch">
                <input type="checkbox" id="editIsActive">
                <span class="slider"></span>
            </label>
        </div>
        <!-- admin/addProduct.ejs or editProduct.ejs -->
<div>
  <label>Stock Quantity</label>
  <input type="number" name="stock" min="0" id="stock" class="form-input" value="<%= products ? products.stock : 0 %>" required />
</div>

        <!-- Existing images -->
        <div class="form-group">
            <label>Current Images</label>
            <div class="preview-wrap" id="editCurrentImages"></div>
        </div>

        <div class="form-group">
            <label>Replace Images <span style="color:#888; font-size:12px;">(upload min 3 to replace, or leave empty to keep current)</span></label>
            <input type="file" id="editImageInput" multiple accept="image/*"
                style="width:100%; padding:10px; border:1px dashed #ccc; border-radius:8px; cursor:pointer;">
            <small id="editImgCount" style="color:#888; display:block; margin-top:5px;"></small>
            <div class="preview-wrap" id="editPreview"></div>
        </div>

        <div style="display:flex; gap:12px; justify-content:flex-end; margin-top:10px;">
            <button class="btn-grey" onclick="closeModal('editProductModal')">Cancel</button>
            <button class="btn-orange" onclick="submitEditProduct()">Update Product</button>
        </div>
    </div>
</div>


<!-- ===================== DELETE MODAL ===================== -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal" style="max-width:380px;">
        <h3 style="margin-bottom:12px;">Delete Product</h3>
        <p style="color:#666;">Are you sure you want to delete this product? This action cannot be undone.</p>
        <div style="display:flex; gap:12px; justify-content:flex-end; margin-top:22px;">
            <button class="btn-grey" onclick="closeModal('deleteModal')">Cancel</button>
            <button id="confirmDeleteBtn"
                style="background:#e74c3c; color:white; border:none; padding:11px 22px; border-radius:8px; cursor:pointer; font-weight:600;">
                Delete
            </button>
        </div>
    </div>
</div>


<!-- ===================== CROP MODAL (ADD) ===================== -->
<div id="cropModal">
    <div class="crop-box">
        <div style="display:flex; justify-content:space-between; margin-bottom:14px; align-items:center;">
            <h3>Crop Image <span id="cropProgress" style="color:#888; font-size:13px;"></span></h3>
        </div>
        <img id="cropImage">
        <div style="display:flex; gap:10px; margin-top:14px; justify-content:flex-end;">
            <button class="btn-grey" id="skipCropBtn">Skip</button>
            <button class="btn-dark" id="cropDoneBtn">✅ Crop & Next</button>
        </div>
    </div>
</div>

<!-- ===================== CROP MODAL (EDIT) ===================== -->
<div id="cropModalEdit">
    <div class="crop-box">
        <div style="display:flex; justify-content:space-between; margin-bottom:14px; align-items:center;">
            <h3>Crop Image <span id="cropProgressEdit" style="color:#888; font-size:13px;"></span></h3>
        </div>
        <img id="cropImageEdit">
        <div style="display:flex; gap:10px; margin-top:14px; justify-content:flex-end;">
            <button class="btn-grey" id="skipCropBtnEdit">Skip</button>
            <button class="btn-dark" id="cropDoneBtnEdit">✅ Crop & Next</button>
        </div>
    </div>
</div>


<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script>

// ── Helpers ──────────────────────────────────────────────
function openModal(id)  { document.getElementById(id).style.display = 'flex'; }
function closeModal(id) { document.getElementById(id).style.display = 'none'; }

function showToast(msg, color) {
    Toastify({
        text: msg, duration: 3000, gravity: 'top', position: 'right',
        backgroundColor: color === 'green' ? '#2ecc71' : '#e74c3c'
    }).showToast();
}

// ── Cropper factory (reusable for add & edit) ────────────
function makeCropperFlow({ inputEl, progressEl, cropImgEl, cropModalEl, cropDoneBtn, skipBtn, previewEl, countEl, onDone }) {
    let cropper = null, queue = [], blobs = [], idx = 0;

    inputEl.addEventListener('change', function () {
        if (this.files.length < 3) {
            showToast('Please select at least 3 images', 'red');
            this.value = '';
            return;
        }
        queue = Array.from(this.files);
        blobs = []; idx = 0;
        previewEl.innerHTML = '';
        openCrop(0);
    });

    function openCrop(i) {
        progressEl.textContent = `(${i + 1} of ${queue.length})`;
        const reader = new FileReader();
        reader.onload = e => {
            cropImgEl.src = e.target.result;
            cropModalEl.classList.add('show');
            if (cropper) cropper.destroy();
            cropper = new Cropper(cropImgEl, { aspectRatio: 1, viewMode: 1 });
        };
        reader.readAsDataURL(queue[i]);
    }

    cropDoneBtn.addEventListener('click', () => {
        cropper.getCroppedCanvas({ width: 800, height: 800 }).toBlob(blob => {
            blobs.push({ blob, name: queue[idx].name });
            addThumb(blob);
            next();
        }, 'image/jpeg', 0.9);
    });

    skipBtn.addEventListener('click', () => {
        blobs.push({ blob: queue[idx], name: queue[idx].name });
        addThumb(queue[idx]);
        next();
    });

    function next() {
        idx++;
        if (idx < queue.length) {
            openCrop(idx);
        } else {
            cropModalEl.classList.remove('show');
            if (cropper) { cropper.destroy(); cropper = null; }
            countEl.textContent = `${blobs.length} images ready ✅`;
            if (onDone) onDone(blobs);
        }
    }

    function addThumb(blobOrFile) {
        const img = document.createElement('img');
        img.src = URL.createObjectURL(blobOrFile);
        previewEl.appendChild(img);
    }

    return { getBlobs: () => blobs };
}

// ── Wire up ADD cropper ──────────────────────────────────
const addCropper = makeCropperFlow({
    inputEl:     document.getElementById('addImageInput'),
    progressEl:  document.getElementById('cropProgress'),
    cropImgEl:   document.getElementById('cropImage'),
    cropModalEl: document.getElementById('cropModal'),
    cropDoneBtn: document.getElementById('cropDoneBtn'),
    skipBtn:     document.getElementById('skipCropBtn'),
    previewEl:   document.getElementById('addPreview'),
    countEl:     document.getElementById('addImgCount'),
});

// ── Wire up EDIT cropper ─────────────────────────────────
const editCropper = makeCropperFlow({
    inputEl:     document.getElementById('editImageInput'),
    progressEl:  document.getElementById('cropProgressEdit'),
    cropImgEl:   document.getElementById('cropImageEdit'),
    cropModalEl: document.getElementById('cropModalEdit'),
    cropDoneBtn: document.getElementById('cropDoneBtnEdit'),
    skipBtn:     document.getElementById('skipCropBtnEdit'),
    previewEl:   document.getElementById('editPreview'),
    countEl:     document.getElementById('editImgCount'),
});


// ── ADD PRODUCT submit ───────────────────────────────────
async function submitAddProduct() {
    const name        = document.getElementById('addName').value.trim();
    const category    = document.getElementById('addCategory').value;
    const price       = document.getElementById('addPrice').value;
    const stock       = document.getElementById('addStock').value;
    const description = document.getElementById('addDescription').value.trim();
    const isActive    = document.getElementById('addIsActive').checked;

    const blobs       = addCropper.getBlobs();

    if (!name || !category || !price||!stock) return showToast('Fill all required fields', 'red');
    if(price<0) return showToast('price not negative ','red')
    if (blobs.length < 3)            return showToast('Upload & crop at least 3 images', 'red');

    const fd = new FormData();
    fd.append('name', name);
    fd.append('category', category);
    fd.append('price', price);
    fd.append('stock', stock);
    fd.append('description', description);
    fd.append('isActive', isActive);
    blobs.forEach(({ blob, name: n }, i) => fd.append('images', blob, `img_${i}_${n}`));

    try {
        const res = await fetch('/admin/addProduct', { method: 'POST', body: fd });
        if (res.ok || res.redirected) {
            showToast('Product added!', 'green');
            setTimeout(() => location.href = '/admin/product', 1200);
        } else {
            showToast('Failed to add product', 'red');
        }
    } catch { showToast('Server error', 'red'); }
}


// ── EDIT PRODUCT — open modal ────────────────────────────
function openEditModal(p) {
    document.getElementById('editProductId').value    = p._id;
    document.getElementById('editName').value         = p.name;
    document.getElementById('editPrice').value        = p.price;
    document.getElementById('editDescription').value  = p.description || '';
    document.getElementById('editIsActive').checked   = p.status === 'Active';
    document.getElementById('editCategory').value     = p.category || '';
    document.getElementById('editImgCount').textContent = '';
    document.getElementById('editPreview').innerHTML  = '';

    // Show current images
    const cur = document.getElementById('editCurrentImages');
    cur.innerHTML = '';
    (p.images || []).forEach(src => {
        const img = document.createElement('img');
        img.src = src;
        cur.appendChild(img);
    });

    openModal('editProductModal');
}

// ── EDIT PRODUCT submit ──────────────────────────────────
async function submitEditProduct() {
    const id          = document.getElementById('editProductId').value;
    const name        = document.getElementById('editName').value.trim();
    const category    = document.getElementById('editCategory').value;
    const price       = document.getElementById('editPrice').value;
    const description = document.getElementById('editDescription').value.trim();
    const isActive    = document.getElementById('editIsActive').checked;
    const blobs       = editCropper.getBlobs();

    if (!name || !category || !price) return showToast('Fill all required fields', 'red');
    if (blobs.length > 0 && blobs.length < 3) return showToast('Upload at least 3 images or leave empty to keep current', 'red');

    const fd = new FormData();
    fd.append('name', name);
    fd.append('category', category);
    fd.append('price', price);
    fd.append('description', description);
    fd.append('isActive', isActive);
    blobs.forEach(({ blob, name: n }, i) => fd.append('images', blob, `img_${i}_${n}`));

    try {
        const res = await fetch(`/admin/product/edit/${id}`, { method: 'POST', body: fd });
        if (res.ok || res.redirected) {
            showToast('Product updated!', 'green');
            setTimeout(() => location.reload(), 1200);
        } else {
            showToast('Failed to update product', 'red');
        }
    } catch { showToast('Server error', 'red'); }
}


// ── DELETE ───────────────────────────────────────────────
let deleteId = null;

function confirmDelete(id) {
    deleteId = id;
    openModal('deleteModal');
}

document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
    if (!deleteId) return;
    try {
        const res  = await fetch(`/admin/product/delete/${deleteId}`, { method: 'PATCH' });
        const data = await res.json();
        if (data.success) {
            showToast('Product deleted!', 'green');
            document.querySelector(`button[onclick="confirmDelete('${deleteId}')"]`).closest('tr').remove();
        } else {
            showToast('Failed to delete', 'red');
        }
    } catch { showToast('Server error1', 'red'); }
    closeModal('deleteModal');
    deleteId = null;
});


// ── TOGGLE STATUS ────────────────────────────────────────
async function toggleStatus(id, checkbox) {
    try {
        const res  = await fetch(`/admin/product/toggle/${id}`, { method: 'PATCH' });
        const data = await res.json();
        if (!data.success) {
            checkbox.checked = !checkbox.checked;
            showToast('Failed to update status', 'red');
        } else {
            showToast(`Status: ${data.status}`, 'green');
        }
    } catch {
        checkbox.checked = !checkbox.checked;
        showToast('Server error', 'red');
    }
}

</script>
