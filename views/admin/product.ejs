<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Product Management</title>
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">

    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', sans-serif; }
        body { background-color: #fbfbfb; display: flex; min-height: 100vh; }
        
        .admin-main { flex: 1; padding: 60px 40px; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px; }
        .page-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; text-transform: uppercase; letter-spacing: -1px; }

        .btn-minimal { background: transparent; border: 1px solid #000; padding: 12px 25px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .btn-minimal:hover { background: #000; color: #fff; }

        .data-card { background: #fff; border: 0.5px solid #eee; padding: 0; overflow: hidden; }
        
        .data-table { width: 100%; border-collapse: collapse; }
        .data-table th { text-align: left; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2px; color: #999; padding: 20px; border-bottom: 0.5px solid #eee; }
        .data-table td { padding: 20px; font-size: 0.75rem; border-bottom: 0.5px solid #eee; text-transform: uppercase; letter-spacing: 0.5px; }

        .p-img { width: 50px; aspect-ratio: 1/1; object-fit: cover; background: #f8f8f8; cursor: pointer; }

        /* Status Toggle */
        .switch { position: relative; display: inline-block; width: 34px; height: 18px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; inset: 0; background-color: #eee; transition: .4s; }
        .slider:before { position: absolute; content: ""; height: 14px; width: 14px; left: 2px; bottom: 2px; background-color: #fff; transition: .4s; border: 0.5px solid #ddd; }
        input:checked + .slider { background-color: #000; }
        input:checked + .slider:before { transform: translateX(16px); }

        /* Zara Style Notifications */
        .zara-toast { background: #000 !important; color: #fff !important; border-radius: 0 !important; font-family: 'Inter', sans-serif !important; font-size: 0.65rem !important; text-transform: uppercase !important; letter-spacing: 2px !important; padding: 15px 40px !important; width: 100% !important; max-width: 600px !important; margin-top: 20px !important; box-shadow: 0 10px 40px rgba(0,0,0,0.2) !important; z-index: 99999 !important; }
        .swal2-container { z-index: 99999 !important; }

        /* Modals */
        .modal-overlay { position: fixed; inset: 0; background: rgba(255,255,255,0.98); z-index: 2000; display: none; align-items: center; justify-content: center; }
        .modal-box { width: 90%; max-width: 700px; padding: 60px; max-height: 95vh; overflow-y: auto; background: #fff; position: relative; display: flex; flex-direction: column; }
        .modal-box h2 { font-family: 'Playfair Display', serif; font-size: 2rem; text-transform: uppercase; margin-bottom: 40px; }

        .modal-footer { position: sticky; bottom: -60px; background: rgba(255,255,255,0.9); padding: 20px 0; border-top: 1px solid #eee; display: flex; justify-content: flex-end; gap: 15px; margin-top: auto; width: 100%; z-index: 10; }

        .form-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; color: #999; margin-bottom: 10px; display: block; }
        .form-input { width: 100%; border: none; border-bottom: 1px solid #000; padding: 12px 0; font-size: 0.85rem; outline: none; background: transparent; margin-bottom: 25px; }

        .preview-wrap { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 15px; }
        .preview-wrap img { width: 100px; aspect-ratio: 3/4; object-fit: cover; border: 0.5px solid #eee; }

        .pagination { display: flex; justify-content: center; gap: 15px; margin-top: 40px; padding-bottom: 40px; }
        .page-link { font-size: 0.7rem; text-transform: uppercase; padding: 5px 10px; text-decoration: none; color: #999; font-weight: 600; }
        .page-link.active { color: #000; text-decoration: underline; }

        .crop-box { background: #fff; padding: 30px; width: 95%; max-width: 500px; border: 1px solid #000; z-index: 3000; display: flex; flex-direction: column; align-items: center; }
        .crop-box h3 { font-family: 'Playfair Display', serif; font-size: 1.2rem; text-transform: uppercase; margin-bottom: 20px; align-self: flex-start; }
        .crop-box .img-container { width: 100%; height: 350px; background: #f9f9f9; margin-bottom: 20px; overflow: hidden; }
        .crop-box img { max-width: 100%; display: block; }
        .crop-btn-group { display: flex; gap: 15px; width: 100%; justify-content: flex-end; padding-top: 15px; border-top: 0.5px solid #eee; }
        
        .action-link { display: block; margin-bottom: 5px; text-align: left; }
    </style>
</head>

<body>

    <%- include('../partials/admin/header') %>

    <main class="admin-main">
        <header class="page-header" style="border-bottom: 2px solid #000; padding-bottom: 20px; margin-bottom:30px;">
            <h1 class="page-title" style="margin:0;">Snova Inventory</h1>
            <button class="btn-minimal" onclick="openModal('addProductModal')">+ Create New Article</button>
        </header>

        <div style="margin-bottom: 40px;">
            <form method="GET" action="/admin/product" style="display:flex; gap:20px; align-items:center;">
                <input type="text" name="search" value="<%= search %>" placeholder="Article Name/Ref..." 
                    style="border:none; border-bottom:1px solid #000; padding:12px 0; font-size:0.8rem; text-transform:uppercase; letter-spacing:1px; outline:none; width:300px; background:transparent;">
                <button type="submit" class="btn-minimal" style="padding: 10px 20px;">Filter</button>
                <% if (search) { %>
                    <a href="/admin/product" style="font-size:0.6rem; text-transform:uppercase; letter-spacing:1px; text-decoration:underline; color:#999;">Reset</a>
                <% } %>
            </form>
        </div>

        <div class="data-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Sl No.</th>
                        <th>Preview</th>
                        <th>Nomenclature</th>
                        <th>Category</th>
                        <th style="text-align: center;">Valuation</th>
                        <th style="text-align: center;">Availability</th>
                        <th style="text-align: center;">Active</th>
                        <th style="text-align: right;">Operations</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products.length===0) { %>
                        <tr>
                            <td colspan="8" style="text-align:center; color:#999; padding:50px;">NO ARTICLES FOUND</td>
                        </tr>
                    <% } else { %>
                        <% products.forEach((p, i)=> { %>
                            <tr>
                                <td style="color: #999;"><%= (currentPage - 1) * limit + i + 1 %></td>
                                <td>
                                    <% 
                                    let displayImg = 'https://placehold.co/600x800?text=SNOVA';
                                    if (p.images && p.images.length > 0) {
                                        displayImg = p.images[0];
                                    } else if (p.variants && p.variants.length > 0) {
                                        const varWithImg = p.variants.find(v => v.images && v.images.length > 0);
                                        if (varWithImg) displayImg = varWithImg.images[0];
                                    }
                                %>
                                <div style="position:relative; cursor:pointer;" onclick="openAddVariantModal('<%= p._id %>')" title="Click to manage variants">
                                    <img src="<%= displayImg %>" class="p-img">
                                    <div style="position:absolute; bottom:0; left:0; right:0; background:rgba(0,0,0,0.6); color:#fff; font-size:0.5rem; text-align:center; padding:2px;">+ VARIANTS</div>
                                </div>
                                </td>
                                <td style="font-weight: 600;"><%= p.name %></td>
                                <td><%= p.category?.name || '—' %></td>
                                <td style="text-align: center;">₹<%= p.price %></td>
                                <td style="text-align: center;">
                                    <% if(p.stock===0) { %>
                                        <span style="color:#e74c3c; font-weight:700;">SOLD OUT</span>
                                    <% } else if(p.stock <=5) { %>
                                        <span style="color:#f39c12; font-weight:700;"><%= p.stock %> REMAINING</span>
                                    <% } else { %>
                                        <span style="color:#666;"><%= p.stock %> UNITS</span>
                                    <% } %>
                                </td>
                                <td style="text-align: center;">
                                    <label class="switch" style="transform: scale(0.85);">
                                        <input type="checkbox" <%=p.isActive ? 'checked' : '' %> onchange="toggleStatus('<%= p._id %>', this)">
                                        <span class="slider"></span>
                                    </label>
                                </td>
                                <td style="text-align: right;">
                                    <div style="display:flex; flex-direction:column; gap:5px; align-items:flex-end;">
                                        <button class="action-link" style="background:none; border:none; text-transform:uppercase; font-size:0.6rem; font-weight:800; text-decoration:underline; cursor:pointer;" onclick="openEditModalByIndex(<%= i %>)">Update</button>
                                        <button class="action-link" style="color:var(--primary-orange, #000); background:none; border:none; text-transform:uppercase; font-size:0.6rem; font-weight:800; text-decoration:underline; cursor:pointer;" onclick="location.href='/admin/product/variants/<%= p._id %>'">View Variants</button>
                                        <button class="action-link" style="color:#e74c3c; background:none; border:none; text-transform:uppercase; font-size:0.6rem; font-weight:800; text-decoration:underline; cursor:pointer;" onclick="confirmDelete('<%= p._id %>')">Archive</button>
                                    </div>
                                </td>
                            </tr>
<% /* Expandable row removed */ %>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (totalPages > 1) { %>
            <div class="pagination">
                <% if (currentPage > 1) { %>
                    <a class="page-link" href="/admin/product?page=<%= currentPage-1 %>&search=<%= search %>">Prev</a>
                <% } %>
                <% for(let i=1; i<=totalPages; i++) { %>
                    <a class="page-link <%= i===currentPage ? 'active' : '' %>" href="/admin/product?page=<%= i %>&search=<%= search %>"><%= i %></a>
                <% } %>
                <% if (currentPage < totalPages) { %>
                    <a class="page-link" href="/admin/product?page=<%= currentPage+1 %>&search=<%= search %>">Next</a>
                <% } %>
            </div>
        <% } %>
    </main>

    <div class="modal-overlay" id="addProductModal">
        <div class="modal-box">
            <h2>Product Specification</h2>
            
            <div class="form-group">
                <label class="form-label">Product Name</label>
                <input type="text" id="addName" class="form-input" placeholder="Enter article name">
            </div>

            <div class="form-group">
                <label class="form-label">Category</label>
                <select id="addCategory" class="form-input">
                    <option value="">-- SELECT CATEGORY --</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat._id %>"><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                <div class="form-group">
                    <label class="form-label">Price (₹)</label>
                    <input type="number" id="addPrice" class="form-input" placeholder="0">
                </div>
                <div class="form-group">
                    <label class="form-label">Stock Units</label>
                    <input type="number" id="addStock" class="form-input" placeholder="0">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea id="addDescription" class="form-input" style="height: 100px;"></textarea>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                <div class="form-group">
                    <label class="form-label">Primary Size</label>
                    <select id="addSize" class="form-input">
                        <option value="">N/A</option>
                        <% ['XS','S','M','L','XL','XXL','One Size'].forEach(s => { %>
                            <option value="<%= s %>"><%= s %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Primary Color</label>
                    <select id="addColor" class="form-input">
                        <option value="">N/A</option>
                        <% ['Red','Blue','Green','Black','White','Yellow','Pink','Gray'].forEach(c => { %>
                            <option value="<%= c %>"><%= c %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">
                <span class="form-label" style="margin:0;">Active Status</span>
                <label class="switch">
                    <input type="checkbox" id="addIsActive" checked>
                    <span class="slider"></span>
                </label>
            </div>

            <div class="form-group">
                <label class="form-label">Article Imagery <small>(3 images recommended)</small></label>
                <input type="file" id="addImageInput" accept="image/*" class="form-input" multiple>
                <small id="addImgCount" style="color:#888; display:block; margin-top:5px;"></small>
                <div class="preview-wrap" id="addPreview"></div>
            </div>


            <div class="modal-footer">
                <button class="btn-minimal" style="border:none; color:#999;" onclick="closeModal('addProductModal')">Discard</button>
                <button class="btn-minimal" onclick="submitAddProduct()">Verify Entry</button>
            </div>
        </div>
    </div>


        <div class="modal-overlay" id="editProductModal">
            <div class="modal-box">
                <h2>Modify Product</h2>

                <input type="hidden" id="editProductId">
                <div class="form-group">
                    <label>Product Name</label>
                    <input type="text" id="editName" class="form-input">
                </div>
                <div class="form-group">
                    <label>Category</label>
                    <select id="editCategory" class="form-input">
                        <option value="">-- Select Category --</option>
                        <% categories.forEach(cat=> { %>
                            <option value="<%= cat._id %>">
                                <%= cat.name %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div class="form-group" style="display:grid; grid-template-columns:1fr 1fr; gap:15px;">
                    <div>
                        <label>Base Price (₹)</label>
                        <input type="number" id="editPrice" class="form-input" min="0">
                    </div>
                    <div>
                        <label>Base Stock</label>
                        <input type="number" id="editStock" class="form-input" min="0">
                    </div>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea id="editDescription" class="form-input"></textarea>
                </div>
                <div class="form-group" style="display:grid; grid-template-columns:1fr 1fr; gap:15px;">
                    <div>
                        <label>Base Size</label>
                        <select id="editSize" class="form-input">
                            <option value="">-- No Size --</option>
                            <option value="XS">XS</option>
                            <option value="S">S</option>
                            <option value="M">M</option>
                            <option value="L">L</option>
                            <option value="XL">XL</option>
                            <option value="XXL">XXL</option>
                            <option value="One Size">One Size</option>
                        </select>
                    </div>
                    <div>
                        <label>Base Color</label>
                        <select id="editColor" class="form-input">
                            <option value="">-- No Color --</option>
                            <option value="Red">Red</option>
                            <option value="Blue">Blue</option>
                            <option value="Green">Green</option>
                            <option value="Black">Black</option>
                            <option value="White">White</option>
                            <option value="Yellow">Yellow</option>
                            <option value="Pink">Pink</option>
                            <option value="Gray">Gray</option>
                        </select>
                    </div>
                </div>

                <div class="form-group" style="display:flex; justify-content:space-between; align-items:center;">
                    <label style="margin:0;">Active Status</label>
                    <label class="switch">
                        <input type="checkbox" id="editIsActive">
                        <span class="slider"></span>
                    </label>
                </div>


                <!-- =========================================================== -->

                <!-- Existing images -->
                <div class="form-group">
                    <label>Current Images</label>
                    <div class="preview-wrap" id="editCurrentImages"></div>
                </div>

                <div class="form-group">
                    <label>Replace Images <span style="color:#888; font-size:12px;">(optional, leave empty to keep current)</span></label>
                    <input type="file" id="editImageInput" multiple accept="image/*"
                        style="width:100%; padding:10px; border:1px dashed #ccc; border-radius:8px; cursor:pointer;">
                    <small id="editImgCount" style="color:#888; display:block; margin-top:5px;"></small>
                    <div class="preview-wrap" id="editPreview"></div>
                </div>

                <!-- NEW: Manage Variants section inside Edit Product -->
                <div class="form-group" style="margin-top:20px; border-top:1px solid #eee; padding-top:15px;">
                    <label style="display:flex; justify-content:space-between; align-items:center;">
                        Variants
                        <button class="btn-minimal" style="padding:5px 10px; font-size:12px;" onclick="openAddVariantModal(document.getElementById('editProductId').value)">+ Add Variant</button>
                    </label>
                    <div id="editVariantsList" style="margin-top:10px;">
                        <!-- Variants will be listed here -->
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn-minimal" style="border:none; color:#999;" onclick="closeModal('editProductModal')">Cancel</button>
                    <button class="btn-minimal" onclick="submitEditProduct()">Update Inventory</button>
                </div>
            </div>
        </div>


        <!-- ===================== DELETE MODAL ===================== -->
        <div class="modal-overlay" id="deleteModal">
            <div class="modal-box" style="max-width:400px; text-align:center;">
                <h2>Archive Article?</h2>
                <p style="color:#999; font-size:0.75rem; text-transform:uppercase; letter-spacing:1px; margin-bottom:40px;">This action will remove the article from active inventory and customer views.</p>
                <div style="display:flex; flex-direction:column; gap:15px;">
                    <button id="confirmDeleteBtn" class="btn-minimal" style="background:#000; color:#fff;">Confirm Archive</button>
                    <button class="btn-minimal" style="border:none; color:#999;" onclick="closeModal('deleteModal')">Keep Article</button>
                </div>
            </div>
        </div>


        <!-- ===================== CROP MODAL (ADD) ===================== -->


        <div class="modal-overlay" id="cropModal">
            <div class="crop-box">
                <div style="display:flex; justify-content:space-between; margin-bottom:14px; align-items:center;">
                    <h3>Crop Image <span id="cropProgress" style="color:#888; font-size:13px;"></span></h3>
                </div>
                <div class="img-container">
                    <img id="cropImage">
                </div>
                <div class="crop-btn-group">
                    <button class="btn-minimal" style="border:none; color:#999;" id="skipCropBtn">Cancel</button>
                    <button class="btn-minimal" id="cropDoneBtn">Save Crop</button>
                </div>
            </div>
        </div>

        <!-- ===================== CROP MODAL (EDIT) ===================== -->

        <div class="modal-overlay" id="cropModalEdit">
            <div class="crop-box">
                <div style="display:flex; justify-content:space-between; margin-bottom:14px; align-items:center;">
                    <h3>Crop Image <span id="cropProgressEdit" style="color:#888; font-size:13px;"></span></h3>
                </div>
                <div class="img-container">
                    <img id="cropImageEdit">
                </div>
                <div class="crop-btn-group">
                    <button class="btn-minimal" style="border:none; color:#999;" id="skipCropBtnEdit">Cancel</button>
                    <button class="btn-minimal" id="cropDoneBtnEdit">Save Crop</button>
                </div>
            </div>
        </div>



        <div class="modal-overlay" id="addVariantModal">
            <div class="modal-box">
                <h2>Add Extended Variant</h2>

                <input type="hidden" id="variantProductId">

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:15px;">
                    <div class="form-group">
                        <label>Size</label>
                        <select id="variantSize" class="form-input">
                            <option value="">-- Select Size --</option>
                            <% ['XS','S','M','L','XL','XXL','One Size'].forEach(s => { %>
                                <option value="<%= s %>"><%= s %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Color</label>
                        <select id="variantColor" class="form-input">
                            <option value="">-- Select Color --</option>
                            <option value="Red">Red</option>
                            <option value="Blue">Blue</option>
                            <option value="Green">Green</option>
                            <option value="Black">Black</option>
                            <option value="White">White</option>
                        </select>
                    </div>
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:15px;">
                    <div class="form-group">
                        <label>Stock</label>
                        <input type="number" id="variantStock" class="form-input" min="0" placeholder="0">
                    </div>
                    <div class="form-group">
                        <label>Price (₹) <small>(optional)</small></label>
                        <input type="number" id="variantPrice" class="form-input" min="0" placeholder="Base Price">
                    </div>
                </div>

                <div class="form-group">
                    <label>Variant Images <span style="color:#888; font-size:12px;">(3 images recommended)</span></label>
                    <div style="display:flex; gap:10px; align-items:center; margin-bottom:10px;">
                        <input type="file" id="variantImageInput" multiple accept="image/*"
                            style="flex:1; padding:10px; border:1px dashed #ccc; border-radius:8px; cursor:pointer;">
                        <button class="btn-minimal" style="border:none; color:#999;" onclick="clearVariantImages()" style="padding:10px;">Clear</button>
                    </div>
                    <small id="variantImgCount" style="color:#888; display:block; margin-top:5px;">No images selected</small>
                    <div class="preview-wrap" id="variantPreview"></div>
                </div>

                <div class="modal-footer">
                    <button class="btn-minimal" style="border:none; color:#999;" onclick="closeModal('addVariantModal')">Cancel</button>
                    <button class="btn-minimal" onclick="submitAddVariant()">Commit Variant</button>
                </div>
            </div>
        </div>


        <!-- ===================== CROP MODAL (VARIANT) ===================== -->
        <div class="modal-overlay" id="cropModalVariant">
            <div class="crop-box">
                <div style="display:flex; justify-content:space-between; margin-bottom:14px; align-items:center;">
                    <h3>Crop Variant Image <span id="cropProgressVariant" style="color:#888; font-size:13px;"></span></h3>
                </div>
                <div class="img-container">
                    <img id="cropImageVariant">
                </div>
                <div class="crop-btn-group">
                    <button class="btn-minimal" style="border:none; color:#999;" id="skipCropBtnVariant">Cancel</button>
                    <button class="btn-minimal" id="cropDoneBtnVariant">Save Crop</button>
                </div>
            </div>
        </div>

        <!-- ===================== EDIT VARIANT MODAL ===================== -->
        <div class="modal-overlay" id="editVariantModal">
            <div class="modal-box">
                <h2>Adjust Variant</h2>

                <input type="hidden" id="editVariantProductId">
                <input type="hidden" id="editVariantId">

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:15px;">
                    <div class="form-group">
                        <label>Size</label>
                        <select id="editVariantSize" class="form-input">
                            <option value="">-- Select Size --</option>
                            <option value="XS">XS</option>
                            <option value="S">S</option>
                            <option value="M">M</option>
                            <option value="L">L</option>
                            <option value="XL">XL</option>
