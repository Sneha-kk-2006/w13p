        <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
        <script>
            const currentPageProducts = <%- JSON.stringify(products) %>;

            function showToast(msg, color = '#000') {
                Toastify({
                    text: (msg || "").toUpperCase(),
                    duration: 3000,
                    gravity: "top",
                    position: "center",
                    style: { 
                        background: color === 'red' ? '#ff0000' : '#000', 
                        borderRadius: "0px",
                        fontSize: "0.7rem",
                        letterSpacing: "1.5px",
                        fontWeight: "500",
                        fontFamily: "'Inter', sans-serif",
                        padding: "15px 40px"
                    }
                }).showToast();
            }

            function openEditModalByIndex(index) {
                const p = currentPageProducts[index];
                if (p) {
                    openEditModal({
                        _id: p._id,
                        name: p.name,
                        price: p.price,
