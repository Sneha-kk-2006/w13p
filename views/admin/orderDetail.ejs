<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Order Detail</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .admin-main {
            flex: 1;
            padding: 60px 40px;
            background-color: #fbfbfb;
            min-height: 100vh;
        }

        .back-link {
            text-decoration: none;
            color: #999;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 30px;
            transition: 0.3s;
        }

        .back-link:hover {
            color: #000;
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 40px;
            border-bottom: 0.5px solid #eee;
            padding-bottom: 30px;
        }

        .order-info-primary h1 {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            text-transform: uppercase;
            letter-spacing: -1px;
            margin: 0;
        }

        .order-meta {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #999;
            margin-top: 10px;
            font-weight: 600;
        }

        .status-pill {
            padding: 8px 15px;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 800;
            border: 1px solid #000;
        }

        .detail-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 40px;
        }

        .card {
            background: #fff;
            border: 0.5px solid #eee;
            padding: 30px;
            margin-bottom: 30px;
        }

        .card-title {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 800;
            margin-bottom: 25px;
            color: #000;
            border-bottom: 0.5px solid #eee;
            padding-bottom: 15px;
        }

        .item-row {
            display: flex;
            align-items: center;
            gap: 20px;
            padding: 15px 0;
            border-bottom: 0.5px solid #f9f9f9;
        }

        .item-image {
            width: 70px;
            height: 70px;
            background: #f8f8f8;
            object-fit: cover;
        }

        .item-details {
            flex: 1;
        }

        .item-name {
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .item-meta {
            font-size: 0.7rem;
            color: #999;
        }

        .item-price {
            font-weight: 700;
            font-size: 0.85rem;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .summary-total {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #000;
            font-weight: 800;
            font-size: 1.1rem;
        }

        .address-box {
            line-height: 1.8;
            font-size: 0.8rem;
            color: #555;
        }

        .address-name {
            font-weight: 800;
            color: #000;
            text-transform: uppercase;
            display: block;
            margin-bottom: 10px;
            font-size: 0.75rem;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <%- include('../partials/admin/header', { activePage: 'orders' }) %>

    <main class="admin-main">
        <a href="/admin/orders" class="back-link">
            <i class="fa-solid fa-arrow-left"></i> Back to Archive
        </a>

        <header class="order-header">
            <div class="order-info-primary">
                <h1>Order #<%= order.orderId %></h1>
                <div class="order-meta">
                    Placed on <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                </div>
                <% if (order.cancellationReason) { %>
                    <div style="margin-top: 15px; color: #c53030; font-size: 0.75rem; text-transform: uppercase; font-weight: 700;">
                        Cancellation Reason: <span style="font-weight: 400; color: #555;"><%= order.cancellationReason %></span>
                    </div>
                <% } %>
                <% if (order.returnReason) { %>
                    <div style="margin-top: 15px; color: #dd6b20; font-size: 0.75rem; text-transform: uppercase; font-weight: 700;">
                        Return Reason: <span style="font-weight: 400; color: #555;"><%= order.returnReason %></span>
                    </div>
                <% } %>
            </div>
            <div class="status-action" style="text-align: right;">
                <div class="order-meta" style="margin-bottom: 10px;">Status Control</div>
                <select class="status-select" onchange="updateStatus('<%= order.orderId %>', this.value)" style="padding: 10px; font-size: 0.7rem; text-transform: uppercase; border: 1px solid #000; font-weight: 700; cursor: pointer;">
                    <option value="Pending" <%= order.orderStatus === 'Pending' ? 'selected' : '' %> <%= ['Delivered', 'Cancelled', 'Returned', 'Return Requested', 'Return Rejected'].includes(order.orderStatus) ? 'disabled' : '' %>>Pending</option>
                    <option value="Shipped" <%= order.orderStatus === 'Shipped' ? 'selected' : '' %> <%= ['Delivered', 'Cancelled', 'Returned', 'Return Requested', 'Return Rejected'].includes(order.orderStatus) ? 'disabled' : '' %>>Shipped</option>
                    <option value="Out for Delivery" <%= order.orderStatus === 'Out for Delivery' ? 'selected' : '' %> <%= ['Delivered', 'Cancelled', 'Returned', 'Return Requested', 'Return Rejected'].includes(order.orderStatus) ? 'disabled' : '' %>>Out for Delivery</option>
                    <option value="Delivered" <%= order.orderStatus === 'Delivered' ? 'selected' : '' %> <%= ['Cancelled', 'Returned', 'Return Requested', 'Return Rejected'].includes(order.orderStatus) ? 'disabled' : '' %>>Delivered</option>
                    <option value="Cancelled" <%= order.orderStatus === 'Cancelled' ? 'selected' : '' %> <%= ['Delivered', 'Returned', 'Return Requested', 'Return Rejected'].includes(order.orderStatus) ? 'disabled' : '' %>>Cancelled</option>
                    
                    <% if (order.orderStatus === 'Return Requested') { %>
                        <option value="Return Requested" selected disabled>Return Requested</option>
                        <option value="Returned">Approve Return</option>
                        <option value="Return Rejected">Reject Return</option>
                    <% } else if (order.orderStatus === 'Returned') { %>
                        <option value="Returned" selected disabled>Returned</option>
                    <% } else if (order.orderStatus === 'Return Rejected') { %>
                        <option value="Return Rejected" selected disabled>Return Rejected</option>
                    <% } else { %>
                         <div class="status-pill"><%= order.orderStatus %></div>
                    <% } %>
                </select>
            </div>
        </header>

        <div class="detail-grid">
            <div class="main-content">
                <div class="card">
                    <h2 class="card-title">Order Manifest</h2>
                    <% order.orderItems.forEach(item => { %>
                        <div class="item-row" style="display: flex; align-items: center; justify-content: space-between;">
                            <div style="display: flex; align-items: center; gap: 20px; flex: 1;">
                                <img src="<%= (item.product && item.product.images && item.product.images.length > 0) ? item.product.images[0] : 'https://via.placeholder.com/70' %>" class="item-image">
                                <div class="item-details">
                                    <div class="item-name"><%= item.product ? item.product.name : 'Unknown Product' %></div>
                                    <div class="item-meta">Quantity: <%= item.quantity %></div>
                                    <div class="item-meta" style="margin-top: 5px;">
                                        <span class="status-pill" style="font-size: 0.55rem; padding: 4px 8px; background: #f5f5f5;">
                                            <%= item.status || 'Pending' %>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="item-pricing-actions" style="text-align: right; min-width: 200px;">
                                <div class="item-price" style="margin-bottom: 10px;">₹<%= (item.price * item.quantity).toLocaleString() %></div>
                                
                                <% if (item.status === 'Return Requested') { %>
                                    <div class="action-buttons" style="display: flex; gap: 10px; justify-content: flex-end;">
                                        <button onclick="updateItemStatus('<%= order.orderId %>', '<%= item._id %>', 'Returned')" style="background: #000; color: #fff; border: none; padding: 5px 10px; font-size: 0.6rem; font-weight: 700; cursor: pointer; text-transform: uppercase;">Approve</button>
                                        <button onclick="updateItemStatus('<%= order.orderId %>', '<%= item._id %>', 'Return Rejected')" style="background: #fff; color: #cc0000; border: 1px solid #cc0000; padding: 5px 10px; font-size: 0.6rem; font-weight: 700; cursor: pointer; text-transform: uppercase;">Reject</button>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <div class="card">
                    <h2 class="card-title">Shipping Logistics</h2>
                    <div class="address-box">
                        <span class="address-name"><%= order.shippingAddress.fullName %></span>
                        <%= order.shippingAddress.addressline1 %><br>
                        <% if(order.shippingAddress.addressline2) { %> <%= order.shippingAddress.addressline2 %><br> <% } %>
                        <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %><br>
                        <%= order.shippingAddress.country %><br>
                        <span style="font-weight: 700; color: #000; margin-top: 10px; display: block;">T: <%= order.shippingAddress.phone %></span>
                    </div>
                </div>
            </div>

            <aside class="sidebar-content">
                <div class="card">
                    <h2 class="card-title">Financial Summary</h2>
                    <div class="summary-row">
                        <span>Subtotal</span>
                        <%
                            let displayTotal = order.totalPrice;
                            if (displayTotal === 0 && order.orderStatus === 'Cancelled') {
                                let subtotal = order.orderItems.reduce((acc, item) => acc + ((item.price || 0) * (item.quantity || 1)), 0);
                                displayTotal = Math.max(0, subtotal + (order.gst || 0) - (order.discount || 0) - (order.offerDiscount || 0));
                            }
                        %>
                        <span>₹<%= displayTotal.toLocaleString() %></span>
                    </div>
                    <div class="summary-row">
                        <span>Shipping</span>
                        <span>Gratis</span>
                    </div>
                    <div class="summary-row">
                        <span>Payment Method</span>
                        <span style="font-weight: 700;"><%= order.paymentMethod %></span>
                    </div>
                    <div class="summary-row">
                        <span>Payment Status</span>
                        <span style="color: <%= order.paymentStatus === 'Paid' ? '#2ecc71' : '#e74c3c' %>; font-weight: 700;"><%= order.paymentStatus %></span>
                    </div>
                    <div class="summary-row summary-total">
                        <span>Total Revenue</span>
                        <%
                            let finalDisplayTotal = order.totalPrice;
                            if (finalDisplayTotal === 0 && order.orderStatus === 'Cancelled') {
                                let subtotal = order.orderItems.reduce((acc, item) => acc + ((item.price || 0) * (item.quantity || 1)), 0);
                                finalDisplayTotal = Math.max(0, subtotal + (order.gst || 0) - (order.discount || 0) - (order.offerDiscount || 0));
                            }
                        %>
                        <span>₹<%= finalDisplayTotal.toLocaleString() %></span>
                    </div>
                </div>

                <div class="card">
                    <h2 class="card-title">Customer Profile</h2>
                    <div class="user-info">
                        <div class="user-name" style="font-size: 0.85rem; font-weight: 800; color: #000;"><%= order.userId ? order.userId.name : 'Guest' %></div>
                        <div class="user-email" style="font-size: 0.7rem; color: #999; margin-top: 5px;"><%= order.userId ? order.userId.email : 'No email provided' %></div>
                        <div style="font-size: 0.7rem; color: #999; margin-top: 5px;">Phone: <%= order.userId ? order.userId.phone : 'N/A' %></div>
                    </div>
                </div>
            </aside>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function updateItemStatus(orderId, itemId, newStatus) {
            try {
                const response = await fetch('/admin/orders/updateItemStatus', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId, itemId, status: newStatus })
                });

                const data = await response.json();
                if (data.success) {
                    Swal.fire({
                        text: 'Item status updated',
                        toast: true,
                        position: 'top',
                        showConfirmButton: false,
                        timer: 2000,
                        background: '#000',
                        color: '#fff'
                    }).then(() => { location.reload(); });
                } else {
                    Swal.fire({ text: data.message || 'Error', icon: 'error' });
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.fire({ text: 'Unexpected error', icon: 'error' });
            }
        }

        async function updateStatus(orderId, newStatus) {
            try {
                const response = await fetch('/admin/orders/updateStatus', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ orderId, status: newStatus })
                });

                const data = await response.json();

                if (data.success) {
                    Swal.fire({
                        text: 'Order status updated',
                        toast: true,
                        position: 'top',
                        showConfirmButton: false,
                        timer: 3000,
                        background: '#000',
                        color: '#fff',
                        showClass: { popup: 'animate__animated animate__fadeInDown' }
                    }).then(() => { location.reload(); });
                } else {
                    Swal.fire({
                        text: data.message || 'Something went wrong',
                        toast: true,
                        position: 'top',
                        showConfirmButton: false,
                        timer: 3000,
                        background: '#c62828',
                        color: '#fff',
                        didClose: () => { location.reload(); }
                    });
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.fire({
                    text: 'An unexpected error occurred',
                    toast: true,
                    position: 'top',
                    showConfirmButton: false,
                    timer: 3000,
                    background: '#c62828',
                    color: '#fff'
                });
            }
        }
    </script>
</body>
</html>
