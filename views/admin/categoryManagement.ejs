<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Category Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <style>
        .admin-main { flex: 1; padding: 60px 40px; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px; }
        .page-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; text-transform: uppercase; letter-spacing: -1px; }
        
        .btn-minimal { background: transparent; border: 1px solid #000; padding: 12px 25px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .btn-minimal:hover { background: #000; color: #fff; }

        .search-area { display: flex; gap: 15px; margin-bottom: 30px; }
        .search-input { border: none; border-bottom: 1px solid #000; padding: 10px 0; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; outline: none; width: 300px; background: transparent; }

        .data-table { width: 100%; border-collapse: collapse; background: #fff; border: 0.5px solid #eee; }
        .data-table th { text-align: left; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2px; color: #999; padding: 20px; border-bottom: 0.5px solid #eee; }
        .data-table td { padding: 20px; font-size: 0.75rem; border-bottom: 0.5px solid #eee; text-transform: uppercase; letter-spacing: 0.5px; }

        /* Modal Overlay */
        .modal-overlay { position: fixed; inset: 0; background: rgba(255,255,255,0.95); z-index: 1000; display: none; align-items: center; justify-content: center; }
        .modal-box { width: 90%; max-width: 400px; padding: 40px; }
        .modal-box h3 { font-family: 'Playfair Display', serif; font-size: 1.8rem; text-transform: uppercase; margin-bottom: 30px; }
        .modal-form input { width: 100%; border: none; border-bottom: 1px solid #000; padding: 12px 0; font-size: 0.85rem; outline: none; background: transparent; margin-bottom: 25px; text-transform: uppercase; }

        .action-icon { cursor: pointer; font-size: 14px; margin-right: 15px; text-decoration: underline; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; background: none; border: none; }

        /* Toggle Switch Custom */
        .switch { position: relative; display: inline-block; width: 36px; height: 18px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; inset: 0; background-color: #eee; transition: .4s; }
        .slider:before { position: absolute; content: ""; height: 14px; width: 14px; left: 2px; bottom: 2px; background-color: #fff; transition: .4s; border: 1px solid #ddd; }
        input:checked + .slider { background-color: #000; }
        input:checked + .slider:before { transform: translateX(18px); border-color: #000; }

        .pagination { display: flex; justify-content: center; gap: 15px; margin-top: 40px; }
        .page-link { font-size: 0.7rem; text-transform: uppercase; padding: 5px 10px; text-decoration: none; color: #999; font-weight: 600; }
        .page-link.active { color: #000; text-decoration: underline; }
        .modal-box { 
    width: 90%; 
    max-width: 400px; 
    padding: 40px; 
    border: 1px solid #000;  /* ← add this */
}
        /* Zara Style Notifications */
        .zara-toast { background: #000 !important; color: #fff !important; border-radius: 0 !important; font-family: 'Inter', sans-serif !important; font-size: 0.65rem !important; text-transform: uppercase !important; letter-spacing: 2px !important; padding: 15px 40px !important; width: 100% !important; max-width: 600px !important; margin-top: 20px !important; box-shadow: 0 10px 40px rgba(0,0,0,0.2) !important; z-index: 9999 !important; }
    </style>
</head>
<body>

    <%- include('../partials/admin/header', { activePage: 'categories' }) %>

    <main class="admin-main">
        <header class="page-header">
            <h1 class="page-title">Categories</h1>
            <button class="btn-minimal" onclick="openModal('addCategoryModal')">Add Category</button>
        </header>

        <div class="search-area">
            <form action="/admin/category" method="GET" style="display: flex; gap: 10px;">
                <input type="text" name="search" value="<%= search || '' %>" placeholder="Find Category..." class="search-input">
                <button type="submit" class="btn-minimal">Filter</button>
            </form>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Ref.</th>
                    <th>Name</th>
                    <th>Status</th>
                   
                    <th style="text-align: right;">Authorization</th>
                </tr>
            </thead>
            <tbody>
                <% categories.forEach((cat, index) => { %>
                    <tr>
                        <td style="color: #999;">#0<%= index + 1 %></td>
                        <td style="font-weight: 600;"><%= cat.name %></td>
                        <td>
                            <label class="switch">
                                <input type="checkbox" <%= cat.status==='Active' ? 'checked' : '' %> onclick="toggleStatus(event, '<%= cat._id %>', '<%= cat.status %>')">
                                <span class="slider"></span>
                            </label>
                        </td>
            
                        <td style="text-align: right;">
                            <button class="action-icon" onclick="openEditModal('<%= cat._id %>', '<%= cat.name %>')">Edit</button>
                            <button class="action-icon" style="color: #e74c3c" onclick="confirmDelete('<%= cat._id %>')">Delete</button>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <div class="pagination">
            <% if(currentPage > 1) { %>
                <a href="/admin/category?page=<%= currentPage-1 %>&search=<%= search %>" class="page-link">Prev</a>
            <% } %>
            <% for(let i=1; i<=totalPage; i++) { %>
                <a href="/admin/category?page=<%= i %>&search=<%= search %>" class="page-link <%= currentPage === i ? 'active' : '' %>"><%= i %></a>
            <% } %>
            <% if(currentPage < totalPage) { %>
                <a href="/admin/category?page=<%= currentPage+1 %>&search=<%= search %>" class="page-link">Next</a>
            <% } %>
        </div>
    </main>

    <!-- Modals -->
    <div class="modal-overlay" id="addCategoryModal">
        <div class="modal-box">
            <h3>Add Category</h3>
            <form id="addForm">
                <input type="text" id="categoryName" placeholder="Name (e.g. Menswear)" required>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
                    <span style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700;">Active Status</span>
                    <label class="switch"><input type="checkbox" id="isActive" checked><span class="slider"></span></label>
                </div>
                <button type="submit" class="btn-minimal w-full">Create Category</button>
                <button type="button" class="btn-minimal w-full mt-4" style="border:none; color:#999;" onclick="closeModal('addCategoryModal')">Cancel</button>
            </form>
        </div>
    </div>

    <div class="modal-overlay" id="editCategoryModal">
        <div class="modal-box">
            <h3>Edit Category</h3>
            <form id="editForm">
                <input type="text" id="editName" placeholder="New Name" required>
                <button type="submit" class="btn-minimal w-full">Update Details</button>
                <button type="button" class="btn-minimal w-full mt-4" style="border:none; color:#999;" onclick="closeModal('editCategoryModal')">Cancel</button>
            </form>
        </div>
    </div>

    <script>
        function openModal(id) { document.getElementById(id).style.display = 'flex'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }

        function showToast(msg) {
            Toastify({
                text: msg.toUpperCase(),
                duration: 3000,
                gravity: "top",
                position: "center",
                style: { 
                    background: "#000", 
                    borderRadius: "0px",
                    fontSize: "0.7rem",
                    letterSpacing: "1.5px",
                    fontWeight: "500",
                    fontFamily: "'Inter', sans-serif",
                    padding: "15px 40px"
                }
            }).showToast();
        }

        function openEditModal(id, name) {
            document.getElementById('editName').value = name;
            document.getElementById('editForm').setAttribute('data-id', id);
            openModal('editCategoryModal');
        }

        document.getElementById('addForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const name = document.getElementById('categoryName').value.trim();
            const isActive = document.getElementById('isActive').checked;
            try {
                const res = await fetch('/admin/addCategory', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, isActive })
                });
                const data = await res.json();
                if(res.ok) {
                    showToast("CATEGORY CREATED");
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(data.message.toUpperCase());
                }
            } catch(err) { console.error(err); }
        });

        document.getElementById('editForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const id = e.target.getAttribute('data-id');
            const name = document.getElementById('editName').value.trim();
            try {
                const res = await fetch(`/admin/category/edit/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name })
                });
                const data = await res.json();
                if(res.ok) {
                    showToast("UPDATED");
                    setTimeout(() => location.reload(), 1000);
                }else{
                    showToast(data.message||"something went wrong")
                     setTimeout(() => location.reload(), 1000);
                }
            } catch(err) {
             
                console.error(err); }
        });

        function toggleStatus(event, id, currentStatus) {
            event.preventDefault(); // Stop the switch from toggling visually until confirmed
            
            const actionText = currentStatus === 'Active' ? 'UNLIST' : 'LIST';

            Swal.fire({
                title: `${actionText} CATEGORY?`,
                text: `ARE YOU SURE YOU WANT TO ${actionText} THIS CATEGORY?`,
                showCancelButton: true,
                confirmButtonColor: '#000',
                cancelButtonColor: '#999',
                confirmButtonText: actionText,
                cancelButtonText: 'CANCEL',
                customClass: {
                    title: 'font-serif uppercase',
                    popup: 'rounded-none'
                }
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try { 
                        const res = await fetch('/admin/category/toggle/'+id, { method: 'PATCH' }); 
                        const data = await res.json();
                        if(data.success) {
                            const status = data.message ? data.message.toUpperCase() : 'STATUS UPDATED';
                            showToast(status);
                            setTimeout(() => location.reload(), 800);
                        } else {
                            showToast('ERROR UPDATING STATUS');
                            setTimeout(() => location.reload(), 1000);
                        }
                    } catch(err) { 
                        console.error(err);
                        location.reload();
                    }
                }
            });
        }

        function confirmDelete(id) {
            Swal.fire({
                title: 'DELETE CATEGORY?',
                text: "ALL ASSOCIATED DATA WILL BE REMOVED",
                showCancelButton: true,
                confirmButtonColor: '#000',
                cancelButtonColor: '#999',
                confirmButtonText: 'DELETE',
                cancelButtonText: 'CANCEL',
                customClass: {
                    title: 'font-serif uppercase',
                    popup: 'rounded-none'
                }
            }).then(async (result) => {
                if (result.isConfirmed) {
                    const res = await fetch(`/admin/category/delete/${id}`, { method: "PATCH" });
                    const data = await res.json();
                    if (data.success) location.reload();
                }
            });
        }
    </script>
</body>
</html>