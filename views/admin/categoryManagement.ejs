<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Management - Categories</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        :root {
            --primary-orange: #d35b31;
            --sidebar-bg: #f5f1ed;
            --active-green: #2ecc71;
            --inactive-red: #e74c3c;
            --border-light: #e0e0e0;
            --text-dark: #334155;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body { background: #f8f9fa; display: flex; min-height: 100vh; }

        /* --- SIDEBAR & LAYOUT --- */
        .sidebar { width: 260px; background: var(--sidebar-bg); border-right: 1px solid var(--border-light); padding: 20px 0; }
        .brand-box { background: var(--primary-orange); color: white; margin: 0 20px 30px; padding: 10px 20px; border-radius: 8px; font-weight: bold; font-size: 20px; display: flex; align-items: center; gap: 10px; }
        .nav-item { padding: 12px 25px; display: flex; align-items: center; gap: 15px; color: #444; text-decoration: none; }
        .nav-item.active { background: #fff; border-left: 4px solid var(--primary-orange); font-weight: 600; }
        .main-content { flex: 1; padding: 40px; }
        
        /* --- TABLE & CARDS --- */
        .data-container { background: white; border-radius: 12px; border: 1px solid var(--border-light); padding: 25px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th { text-align: left; padding: 15px; border-bottom: 2px solid #f0f0f0; color: #666; font-size: 14px; }
        td { padding: 15px; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
        .add-btn { background: #56d0a0; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-weight: 600; }

        /* --- ACTION ICONS --- */
        .action-icons { display: flex; align-items: center; gap: 12px; }
        .icon-btn { cursor: pointer; font-size: 20px; transition: 0.2s; border: none; background: none; }
        .edit-icon { color: var(--primary-orange); }
        .delete-icon { color: var(--inactive-red); }
        .icon-btn:hover { transform: scale(1.1); }

        /* --- MODAL STYLES --- */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(4px);
            display: none; align-items: center; justify-content: center; z-index: 2000;
        }
        .modal { background: white; width: 100%; max-width: 400px; border-radius: 16px; padding: 30px; animation: slideUp 0.3s ease-out; }
        @keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; font-size: 14px; font-weight: 600; color: #64748b; margin-bottom: 8px; }
        .form-group input { width: 100%; padding: 12px 15px; border: 1px solid var(--border-light); border-radius: 8px; outline: none; }
        .modal-footer { display: flex; gap: 12px; justify-content: flex-end; margin-top: 25px; }

        /* --- TOGGLE SWITCH --- */
        .switch { position: relative; display: inline-block; width: 44px; height: 22px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; transition: .4s; border-radius: 34px; }
        .slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider { background-color: var(--active-green); }
        input:checked + .slider:before { transform: translateX(22px); }
    </style>
</head>
<body>
 <%- include('../partials/admin/header') %>

    <main class="main-content">
        <div class="header-row" style="display:flex; justify-content:space-between; margin-bottom:30px;">
            <h1>Categories</h1>
            <button class="add-btn" onclick="openModal('addCategoryModal')">
                <span class="material-symbols-outlined">add</span> Add Category
            </button>
        </div>

        <div class="data-container">
            <table>
                <thead>
                    <tr>
                        <th>Si.No</th>
                        <th>Category Name</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% categories.forEach((cat, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td style="font-weight: 600;"><%= cat.name %></td>
                        <td>
                            <label class="switch">
                                <input type="checkbox" <%= cat.status === 'Active' ? 'checked' : '' %> 
                                       onchange="toggleStatus('<%= cat._id %>')">
                                <span class="slider"></span>
                            </label>
                        </td>
                        <td>
                            <div class="action-icons">
                                <button class="icon-btn edit-icon" 
                                        onclick="openEditModal('<%= cat._id %>', '<%= cat.name %>', '<%= cat.status %>')">
                                    <span class="material-symbols-outlined">edit_note</span>
                                </button>
                                <button class="icon-btn delete-icon" onclick="confirmDelete('<%= cat._id %>')">
                                    <span class="material-symbols-outlined">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>

    <div class="modal-overlay" id="addCategoryModal">
        <div class="modal">
            <div class="modal-header" style="display:flex; justify-content:space-between; margin-bottom:20px;">
                <h2>Add Category</h2>
                <span class="material-symbols-outlined" style="cursor:pointer" onclick="closeModal('addCategoryModal')">close</span>
            </div>
            <form action="/admin/addCategory" method="POST" id="addForm">
                <div class="form-group">
                    <label>Category Name</label>
                    <input type="text" name="name"id="categoryName" >
                    <p id="addError" style="color:red; font-size:0.9em; margin-top:5px;"></p>
            </div>
            <div class="form-group" style="display:flex; justify-content:space-between; align-items:center;">
                </div>
                <div class="form-group" style="display:flex; justify-content:space-between; align-items:center;">
                    <label>Active</label>
                    <label class="switch"><input type="checkbox" name="isActive" id="isActive" checked><span class="slider"></span></label>
                </div>
                <div class="modal-footer">
                    <button type="submit"  class="btn-primary" style="background:var(--primary-orange); color:white; border:none; padding:10px 20px; border-radius:8px; cursor:pointer;">Save</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal-overlay" id="editCategoryModal">
        <div class="modal">
            <div class="modal-header" style="display:flex; justify-content:space-between; margin-bottom:20px;">
                <h2>Edit Category</h2>
                <span class="material-symbols-outlined" style="cursor:pointer" onclick="closeModal('editCategoryModal')">close</span>
            </div>
            <form id="editForm" method="POST" >
                <div class="form-group">
                    <label>Category Name</label>
                    <input type="text" name="name" id="editName" >
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn-primary" style="background:var(--primary-orange); color:white; border:none; padding:10px 20px; border-radius:8px; cursor:pointer;">Update</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal-overlay" id="deleteModal">
  <div class="modal">
    <h3 style="margin-bottom:15px;">Delete Category</h3>
    <p style="color:#555;">Are you sure you want to delete this category?</p>

    <div class="modal-footer">
      <button onclick="closeModal('deleteModal')" 
        style="padding:8px 15px; border:none; border-radius:6px; cursor:pointer;">
        Cancel
      </button>

      <button id="confirmDeleteBtn"
        style="background:#e74c3c; color:white; border:none; padding:8px 15px; border-radius:6px; cursor:pointer;">
        Delete
      </button>
    </div>
  </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
        function openModal(id) { document.getElementById(id).style.display = 'flex'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }

        function openEditModal(id, name) {
            document.getElementById('editName').value = name;
            document.getElementById('editForm').action = `/admin/category/edit/${id}`;
            openModal('editCategoryModal');
        }


let deleteId = null;

function confirmDelete(id) {
    deleteId = id;
    openModal('deleteModal'); 
}


    </script>
    <script>

document.addEventListener('DOMContentLoaded', () => {
    const addForm = document.getElementById('addForm');
    const nameInput = document.getElementById('categoryName');
    const isActiveInput = document.getElementById('isActive');

    addForm.addEventListener('submit', async function(e) {
        e.preventDefault();

        // Validation
        if (!nameInput.value.trim()) {
            Toastify({
                text: "Category name is required",
                duration: 3000,
                gravity: "top",
                position: "right",
                backgroundColor: "#e74c3c"
            }).showToast();
            return;
        }

        try {
            const response = await fetch('/admin/addCategory', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    name: nameInput.value.trim(), 
                    isActive: isActiveInput.checked 
                })
            });

            const data = await response.json();

            if (response.ok) {
                Toastify({
                    text: data.message || "Category added successfully",
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    backgroundColor: "#2ecc71"
                }).showToast();

                nameInput.value = '';
                isActiveInput.checked = true;
                closeModal('addCategoryModal');
                setTimeout(() => location.reload(), 1000); // show toast before reload
            } else {
                Toastify({
                    text: data.message || "Server error",
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    backgroundColor: "#e74c3c"
                }).showToast();
            }

        } catch (err) {
            console.error(err);
            Toastify({
                text: "Server error. Try again later.",
                duration: 3000,
                gravity: "top",
                position: "right",
                backgroundColor: "#e74c3c"
            }).showToast();
        }
    });
});




const editForm = document.getElementById('editForm');
const editNameInput = document.getElementById('editName');

editForm.addEventListener('submit', async function(e) {
    e.preventDefault();

    if (!editNameInput.value.trim()) {
        Toastify({
            text: "Category name is required",
            duration: 3000,
            gravity: "top",
            position: "right",
            backgroundColor: "#e74c3c"
        }).showToast();
        return;
    }

    try {
        const response = await fetch(editForm.action, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                name: editNameInput.value.trim()
            })
        });

        const data = await response.json();

        if (response.ok) {
            Toastify({
                text: data.message || "Category edited successfully",
                duration: 3000,
                gravity: "top",
                position: "right",
                backgroundColor: "#2ecc71"
            }).showToast();

            closeModal('editCategoryModal');
            setTimeout(() => {
                window.location.href = "/admin/category";
            }, 1500);

        } else {
           
            Toastify({
                text: data.message || "Error updating category",
                duration: 3000,
                gravity: "top",
                position: "right",
                backgroundColor: "#e74c3c"
            }).showToast();
        }

    } catch (err) {
        console.error(err);
        Toastify({
            text: "Server error. Try again later.",
            duration: 3000,
            gravity: "top",
            position: "right",
            backgroundColor: "#e74c3c"
        }).showToast();
    }
});




document.getElementById("confirmDeleteBtn").addEventListener("click", async () => {

    if (!deleteId) return;

    try {
        const res = await fetch(`/admin/category/delete/${deleteId}`, {
            method: "PATCH"
        });

        const data = await res.json();

        if (data.success) {

            Toastify({
                text: "Category deleted successfully!",
                duration: 3000,
                gravity: "top",
                position: "right",
                backgroundColor: "green"
            }).showToast();

            const row = document
              .querySelector(`button[onclick="confirmDelete('${deleteId}')"]`)
              .closest("tr");

            if (row) row.remove();

        } else {
            Toastify({
                text: " Failed to delete category",
                duration: 3000,
                backgroundColor: "red"
            }).showToast();
        }

    } catch (err) {
        Toastify({
            text: "⚠️ Server error",
            duration: 3000,
            backgroundColor: "red"
        }).showToast();
    }

    closeModal('deleteModal');
    deleteId = null;
});



 function openEditmodal(id,name){
    document.getElementById('editName').value=name;
    document.getElementById('editForm').action=`/admin/category/edit${id}`;
    openModal('editCategorymodal')

    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
function closeModal(id) { document.getElementById(id).style.display = 'none'; }
 }
</script>
   
</body>
</html>