<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Error Page</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, Helvetica, sans-serif;
}

body{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);
color:white;
overflow:hidden;
}

.error-container{
text-align:center;
z-index:2;
}

.error-code{
font-size:120px;
font-weight:bold;
letter-spacing:10px;
animation:bounce 2s infinite;
}

.error-title{
font-size:32px;
margin-bottom:15px;
}

.error-text{
max-width:400px;
margin:auto;
margin-bottom:30px;
opacity:0.8;
}

.home-btn{
text-decoration:none;
background:#ff4b2b;
padding:12px 30px;
border-radius:25px;
color:white;
font-weight:bold;
transition:0.3s;
}

.home-btn:hover{
background:#ff416c;
transform:scale(1.1);
}

/* Floating numbers */

.floating span{
position:absolute;
font-size:100px;
opacity:0.05;
animation:float 10s linear infinite;
}

.floating span:nth-child(1){
left:10%;
top:80%;
animation-delay:0s;
}

.floating span:nth-child(2){
left:50%;
top:90%;
animation-delay:3s;
}

.floating span:nth-child(3){
left:80%;
top:85%;
animation-delay:6s;
}

/* Animations */

@keyframes float{
0%{
transform:translateY(0) rotate(0deg);
}
100%{
transform:translateY(-1000px) rotate(360deg);
}
}

@keyframes bounce{
0%,100%{
transform:translateY(0);
}
50%{
transform:translateY(-15px);
}
}

</style>
</head>

<body>

<div class="error-container">

<h1 class="error-code">404</h1>

<h2 class="error-title">Oops! Page Not Found</h2>

<p class="error-text">
The page you are looking for might have been removed,
had its name changed, or is temporarily unavailable.
</p>

<a href="/" class="home-btn">Go Back Home</a>

</div>

<div class="floating">
<span>4</span>
<span>0</span>
<span>4</span>
</div>

</body>
</html>