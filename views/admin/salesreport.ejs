<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Sales Report</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --border-gray: #eee;
            --text-muted: #999;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body { background: var(--off-white); display: flex; min-height: 100vh; }

        .admin-main { flex: 1; padding: 40px; }

        .dash-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; border-bottom: 1px solid var(--border-gray); padding-bottom: 20px; }
        .dash-title { font-family: 'Playfair Display', serif; font-size: 2rem; letter-spacing: -1px; }

        .breadcrumbs { display: flex; gap: 10px; align-items: center; margin-bottom: 20px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; }
        .breadcrumbs a { color: var(--text-muted); text-decoration: none; transition: 0.3s; }
        .breadcrumbs a:hover { color: #000; }
        .breadcrumbs span { color: #ccc; }

        .filter-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 20px; align-items: flex-end; margin-bottom: 30px; background: #fbfbfb; padding: 25px; border: 1px solid var(--border-gray); }
        .filter-group { display: flex; flex-direction: column; gap: 8px; }
        .filter-group label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; color: var(--text-muted); }
        .filter-input { border: none; border-bottom: 1px solid #000; padding: 5px 0; font-size: 0.8rem; outline: none; background: transparent; }

        .btn-action { background: #000; color: #fff; border: none; padding: 10px 20px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .btn-outline { background: transparent; color: #000; border: 1px solid #000; }
        .btn-outline:hover { background: #000; color: #fff; }

        .metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .metric-card { padding: 30px; border: 1px solid var(--border-gray); background: #fff; }
        .metric-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2px; color: var(--text-muted); font-weight: 700; }
        .metric-val { font-size: 1.8rem; font-weight: 400; letter-spacing: -1px; margin-top: 10px; }

        .data-table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        .data-table th { text-align: left; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); padding: 15px 0; border-bottom: 1px solid var(--border-gray); }
        .data-table td { padding: 20px 0; font-size: 0.75rem; border-bottom: 1px solid var(--border-gray); text-transform: uppercase; }

        .export-group { display: flex; gap: 10px; }
    </style>
</head>
<body>

    <%- include('../partials/admin/header', { activePage: 'dashboard' }) %>

    <main class="admin-main">
        <nav class="breadcrumbs">
            <a href="/admin/dashboard">Dashboard</a>
            <span>/</span>
            <a href="/admin/salesreport">Sales Report</a>
        </nav>

        <header class="dash-header">
            <h1 class="dash-title">Sales Report</h1>
            <div class="export-group">
                <button class="btn-action btn-outline" onclick="exportReport('pdf')">Export PDF</button>
                <button class="btn-action btn-outline" onclick="exportReport('excel')">Export Excel</button>
            </div>
        </header>

        <form action="/admin/salesreport" method="GET" class="filter-bar" id="reportForm">
            <div class="filter-group">
                <label>Quick Filter</label>
                <select name="filter" class="filter-input" onchange="this.form.submit()">
                    <option value="daily" <%= filter === 'daily' ? 'selected' : '' %>>Today</option>
                    <option value="weekly" <%= filter === 'weekly' ? 'selected' : '' %>>Last 7 Days</option>
                    <option value="monthly" <%= filter === 'monthly' ? 'selected' : '' %>>Last 30 Days</option>
                    <option value="yearly" <%= filter === 'yearly' ? 'selected' : '' %>>Last Year</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Start Date</label>
                <input type="date" name="startDate" value="<%= startDate %>" class="filter-input">
            </div>
            <div class="filter-group">
                <label>End Date</label>
                <input type="date" name="endDate" value="<%= endDate %>" class="filter-input">
            </div>
            <button type="submit" class="btn-action">Apply Filter</button>
        </form>

        <div class="metrics-grid">
            <div class="metric-card">
                <span class="metric-label">Sales Count</span>
                <div class="metric-val"><%= totalSales %></div>
            </div>
            <div class="metric-card">
                <span class="metric-label">Order Amount</span>
                <div class="metric-val">₹<%= totalAmount.toLocaleString() %></div>
            </div>
            <div class="metric-card">
                <span class="metric-label">Total Discount</span>
                <div class="metric-val" style="color: #e74c3c;">₹<%= totalDiscount.toLocaleString() %></div>
            </div>
            <div class="metric-card">
                <span class="metric-label">Net Revenue</span>
                <div class="metric-val">₹<%= (totalAmount - totalDiscount).toLocaleString() %></div>
            </div>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Date</th>
                       <th>Customer</th>  
                    <th>Status</th>
                    <th>Payment</th>
                    <th>Discount</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody>
                <% orders.forEach(order => { %>
                <tr>
                    <td><%= order.orderId %></td>
                    <td><%= new Date(order.createdAt).toLocaleDateString('en-GB') %></td>
                     <td><%= order.userId?.name || 'N/A' %></td> 
                    <td><span style="font-weight: 700; font-size: 0.6rem;"><%= order.orderStatus %></span></td>
                    <td><%= order.paymentMethod %></td>
                    <td style="color: #e74c3c;">₹<%= order.discount || 0 %></td>
                    <td style="font-weight: 600;">₹<%= order.totalPrice.toLocaleString() %></td>
                </tr>
                <% }) %>
                <% if (orders.length === 0) { %>
                <tr>
                    <td colspan="6" style="text-align: center; color: #ccc; padding: 50px;">No records found for this period</td>
                </tr>
                <% } %>
            </tbody>
        </table>
        <!-- Add this after </table> and before </main> -->
<div style="display: flex; justify-content: center; gap: 8px; margin-top: 30px;">
  <% for (let i = 1; i <= pagination.totalPages; i++) { %>
    <a href="/admin/salesreport?filter=<%= filter %>&startDate=<%= startDate %>&endDate=<%= endDate %>&page=<%= i %>"
       style="
         padding: 8px 14px;
         font-size: 0.65rem;
         letter-spacing: 1.5px;
         text-transform: uppercase;
         text-decoration: none;
         border: 1px solid #000;
         font-weight: 700;
         background: <%= pagination.currentPage === i ? '#000' : '#fff' %>;
         color: <%= pagination.currentPage === i ? '#fff' : '#000' %>;
       ">
      <%= i %>
    </a>
  <% } %>
</div>

<!-- Page info -->
<p style="text-align:center; margin-top: 15px; font-size: 0.65rem; color: #999; letter-spacing: 1.5px; text-transform: uppercase;">
  Page <%= pagination.currentPage %> of <%= pagination.totalPages %> 
  &nbsp;|&nbsp; 
  Total Orders: <%= pagination.totalItems %>
</p>
    </main>
    

    <script>
        function exportReport(type) {
            const form = document.getElementById('reportForm');
            const params = new URLSearchParams(new FormData(form)).toString();
            const baseUrl = type === 'pdf' ? '/admin/salesreport/pdf' : '/admin/salesreport/excel';
            window.location.href = `${baseUrl}?${params}`;
        }
    </script>
</body>
</html>