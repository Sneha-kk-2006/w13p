<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Sales Report</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0" />
    <style>
        :root {
            --sidebar-bg: #e2dcd5;
            --main-bg: #f3f4f6;
            --snova-orange: #c86d4d;
            --text-main: #1f2937;
            --text-muted: #6b7280;
            --white: #ffffff;
            --border-color: #e5e7eb;
            --status-paid: #dcfce7;
            --status-delivered: #dcfce7;
            --status-shipped: #dbeafe;
            --status-pending: #fef3c7;
            --status-cancelled: #fee2e2;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: var(--main-bg); display: flex; height: 100vh; overflow: hidden; }

        /* Sidebar - Same as Dashboard for consistency */
        .sidebar { width: 240px; background-color: var(--sidebar-bg); display: flex; flex-direction: column; padding: 20px 0; border-right: 1px solid var(--border-color); }
        .logo-container { padding: 0 20px 30px; }
        .logo { background-color: var(--snova-orange); color: white; padding: 8px 15px; border-radius: 8px; font-weight: bold; font-size: 18px; display: inline-flex; align-items: center; gap: 8px; }
        .nav-item { padding: 12px 20px; display: flex; align-items: center; gap: 12px; color: var(--text-main); text-decoration: none; font-size: 14px; }
        .nav-item.active { background-color: #d1d5db; font-weight: 600; }
        .user-profile { margin-top: auto; padding: 15px 20px; display: flex; align-items: center; gap: 10px; }
        .user-profile img { width: 35px; height: 35px; border-radius: 50%; }

        /* Main Content */
        .main-content { flex: 1; overflow-y: auto; padding: 30px; }
        .report-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .header-actions { display: flex; gap: 10px; }
        .action-btn { background: white; border: 1px solid var(--border-color); padding: 8px 16px; border-radius: 20px; font-size: 12px; display: flex; align-items: center; gap: 8px; cursor: pointer; }

        /* Metric Cards */
        .metrics-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px; }
        .metric-card { background: white; padding: 20px; border-radius: 12px; border: 1px solid var(--border-color); position: relative; }
        .metric-label { font-size: 12px; color: var(--text-muted); margin-bottom: 15px; }
        .metric-icon { position: absolute; top: 15px; right: 15px; background: #e0f2fe; color: #0ea5e9; padding: 5px; border-radius: 50%; font-size: 14px; }
        .metric-value { font-size: 22px; font-weight: 700; margin-bottom: 5px; }
        .metric-sub { font-size: 11px; color: #10b981; font-weight: 600; }

        /* Charts Layout */
        .charts-row { display: grid; grid-template-columns: 1.8fr 1.2fr; gap: 20px; margin-bottom: 30px; }
        .chart-container { background: white; padding: 25px; border-radius: 12px; border: 1px solid var(--border-color); }
        .chart-title { font-size: 15px; font-weight: 600; margin-bottom: 5px; }
        .chart-sub { font-size: 12px; color: var(--text-muted); margin-bottom: 20px; }
        .chart-placeholder { width: 100%; height: 200px; border-left: 1px solid #ddd; border-bottom: 1px solid #ddd; position: relative; }

        /* Transactions Table */
        .transactions-card { background: white; padding: 25px; border-radius: 12px; border: 1px solid var(--border-color); }
        .table-toolbar { display: flex; justify-content: space-between; margin-bottom: 20px; }
        .search-box { background: #f9fafb; border: 1px solid var(--border-color); padding: 8px 15px; border-radius: 8px; width: 300px; display: flex; align-items: center; gap: 10px; }
        .search-box input { border: none; background: transparent; outline: none; font-size: 13px; width: 100%; }
        
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 12px; font-size: 12px; color: var(--text-muted); font-weight: 500; border-bottom: 1px solid var(--border-color); }
        td { padding: 15px 12px; font-size: 13px; border-bottom: 1px solid var(--border-color); }
        
        .status { padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }
        .status.paid { background: var(--status-paid); color: #15803d; }
        .status.shipped { background: var(--status-shipped); color: #1d4ed8; }
        .status.pending { background: var(--status-pending); color: #b45309; }
        .status.cancelled { background: var(--status-cancelled); color: #b91c1c; }

        /* Pagination */
        .pagination { display: flex; justify-content: space-between; align-items: center; margin-top: 20px; font-size: 12px; color: var(--text-muted); }
        .page-controls { display: flex; gap: 15px; align-items: center; }
        .page-controls span { cursor: pointer; }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="logo-container">
            <div class="logo"><span class="material-symbols-outlined">storefront</span> SNOVA</div>
        </div>
        <nav>
            <a href="#" class="nav-item"><span class="material-symbols-outlined">grid_view</span> Dashboard</a>
            <a href="#" class="nav-item"><span class="material-symbols-outlined">shopping_bag</span> Orders</a>
            <a href="#" class="nav-item"><span class="material-symbols-outlined">inventory_2</span> Products</a>
            <a href="#" class="nav-item"><span class="material-symbols-outlined">category</span> Categories</a>
            <a href="#" class="nav-item"><span class="material-symbols-outlined">confirmation_number</span> Coupons</a>
            <a href="#" class="nav-item"><span class="material-symbols-outlined">local_offer</span> Offers</a>
        </nav>
        <div class="user-profile">
            <img src="https://ui-avatars.com/api/?name=sneha-kk&background=c86d4d&color=fff" alt="">
            <div style="font-size: 12px;"><strong>sneha kk</strong><br><span style="color:var(--text-muted)">sneha@gmail.com</span></div>
        </div>
    </aside>

    <main class="main-content">
        <header class="report-header">
            <h2 style="font-size: 24px;">Sales Report</h2>
            <div class="header-actions">
                <button class="action-btn"><span class="material-symbols-outlined" style="font-size:16px;">calendar_month</span> Oct 24, 2023 - Nov 24, 2023</button>
                <button class="action-btn" style="background: #111; color: white;"><span class="material-symbols-outlined" style="font-size:16px;">download</span> Download PDF</button>
            </div>
        </header>

        <div class="metrics-grid">
            <div class="metric-card">
                <div class="metric-label">Total Revenue</div>
                <span class="material-symbols-outlined metric-icon">payments</span>
                <div class="metric-value">₹145,231.89</div>
                <div class="metric-sub">↗ +20.1%</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Total Orders</div>
                <span class="material-symbols-outlined metric-icon" style="color:#6366f1; background:#eef2ff;">shopping_cart</span>
                <div class="metric-value">+2,350</div>
                <div class="metric-sub">↗ +180</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Products Sold</div>
                <span class="material-symbols-outlined metric-icon" style="color:#f59e0b; background:#fff7ed;">inventory_2</span>
                <div class="metric-value">12,234</div>
                <div class="metric-sub">↗ +12%</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Discounts Given</div>
                <span class="material-symbols-outlined metric-icon" style="color:#ec4899; background:#fdf2f8;">confirmation_number</span>
                <div class="metric-value">₹3,203.00</div>
                <div class="metric-sub" style="color:var(--text-muted)">Across 142 orders</div>
            </div>
        </div>

        <div class="charts-row">
            <div class="chart-container">
                <h3 class="chart-title">Revenue Overview (DAILY)</h3>
                <p class="chart-sub">Daily revenue performance for the current period</p>
                <div class="chart-placeholder">
                    <svg viewBox="0 0 500 100" preserveAspectRatio="none" style="width:100%; height:100%;">
                        <path d="M0,80 Q50,60 100,70 T200,40 T300,50 T400,20 T500,40 L500,100 L0,100 Z" fill="#bae6fd" opacity="0.5"/>
                        <path d="M0,80 Q50,60 100,70 T200,40 T300,50 T400,20 T500,40" fill="none" stroke="#0ea5e9" stroke-width="2"/>
                    </svg>
                </div>
            </div>
            <div class="chart-container">
                <h3 class="chart-title">Revenue Overview (Monthly)</h3>
                <p class="chart-sub">Monthly revenue performance for current year</p>
                <div class="chart-placeholder">
                    <svg viewBox="0 0 500 100" preserveAspectRatio="none" style="width:100%; height:100%;">
                        <polyline points="0,90 100,80 200,60 300,65 400,50 500,20" fill="none" stroke="#ef4444" stroke-width="2"/>
                    </svg>
                </div>
            </div>
        </div>

        <div class="transactions-card">
            <h3 class="chart-title" style="margin-bottom: 20px;">Recent Transactions</h3>
            <div class="table-toolbar">
                <div class="search-box">
                    <span class="material-symbols-outlined" style="font-size:18px; color:var(--text-muted)">search</span>
                    <input type="text" placeholder="Search order ID or customer...">
                </div>
                <div style="display:flex; gap:10px;">
                    <select class="action-btn"><option>All Status</option></select>
                    <select class="action-btn"><option>All Methods</option></select>
                </div>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Date</th>
                        <th>Customers</th>
                        <th>Status</th>
                        <th>Payment</th>
                        <th>Amount</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>ORD-289</td>
                        <td>Nov 24, 2023</td>
                        <td>Sarah Johnson</td>
                        <td><span class="status paid">Paid</span></td>
                        <td>Razorpay</td>
                        <td>₹314.50</td>
                        <td><span class="material-symbols-outlined">more_horiz</span></td>
                    </tr>
                    <tr>
                        <td>ORD-002</td>
                        <td>Nov 24, 2023</td>
                        <td>Michael Ross</td>
                        <td><span class="status paid" style="background:#dcfce7; color:#166534;">Delivered</span></td>
                        <td>Wallet</td>
                        <td>₹850.00</td>
                        <td><span class="material-symbols-outlined">more_horiz</span></td>
                    </tr>
                    <tr>
                        <td>ORD-332</td>
                        <td>Nov 23, 2023</td>
                        <td>Anna Kim</td>
                        <td><span class="status shipped">Shipped</span></td>
                        <td>Razorpay</td>
                        <td>₹145.99</td>
                        <td><span class="material-symbols-outlined">more_horiz</span></td>
                    </tr>
                </tbody>
            </table>
            <div class="pagination">
                <div>Showing <strong>1-5</strong> of <strong>240</strong> transactions</div>
                <div class="page-controls">
                    <span>< Previous</span>
                    <span style="font-weight:bold; color:black;">1</span>
                    <span>2</span>
                    <span>3</span>
                    <span>Next ></span>
                </div>
            </div>
        </div>
    </main>
</body>
</html>