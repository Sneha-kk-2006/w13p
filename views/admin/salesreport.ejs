<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Financial Analysis</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', sans-serif; }
        body { background-color: #fbfbfb; display: flex; min-height: 100vh; }
        
        .admin-main { flex: 1; padding: 60px 40px; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px; }
        .page-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; text-transform: uppercase; letter-spacing: -1px; }

        .btn-minimal { background: transparent; border: 1px solid #000; padding: 12px 25px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .btn-minimal:hover { background: #000; color: #fff; }

        .metrics-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 50px; }
        .metric-card { background: #fff; padding: 30px; border: 0.5px solid #eee; }
        .metric-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2px; color: #999; margin-bottom: 15px; font-weight: 700; }
        .metric-value { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: #000; margin-bottom: 5px; }
        .metric-change { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; color: #000; font-weight: 700; }

        .chart-section { display: grid; grid-template-columns: 2fr 1fr; gap: 30px; margin-bottom: 50px; }
        .chart-box { background: #fff; padding: 40px; border: 0.5px solid #eee; height: 400px; display: flex; flex-direction: column; }
        .chart-title { font-family: 'Playfair Display', serif; font-size: 1.2rem; text-transform: uppercase; margin-bottom: 30px; border-bottom: 1px solid #000; display: inline-block; padding-bottom: 5px; }

        .data-card { background: #fff; border: 0.5px solid #eee; overflow: hidden; }
        .data-table { width: 100%; border-collapse: collapse; }
        .data-table th { text-align: left; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2px; color: #999; padding: 20px; border-bottom: 0.5px solid #eee; }
        .data-table td { padding: 20px; font-size: 0.75rem; border-bottom: 0.5px solid #eee; text-transform: uppercase; letter-spacing: 0.5px; }

        .status-badge { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; background: #f0f0f0; padding: 4px 10px; }
    </style>
</head>
<body>

    <%- include('../partials/admin/header', { activePage: 'sales' }) %>

    <main class="admin-main">
        <header class="page-header">
            <h1 class="page-title">Financial Report</h1>
            <div style="display: flex; gap: 15px;">
                <button class="btn-minimal">Date Filter</button>
                <button class="btn-minimal" style="background:#000; color:#fff;">Export CSV</button>
            </div>
        </header>

        <section class="metrics-grid">
            <div class="metric-card">
                <div class="metric-label">Gross Revenue</div>
                <div class="metric-value">₹452,310</div>
                <div class="metric-change">+ 24.5% OVER PERIOD</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Orders Logged</div>
                <div class="metric-value">1,248</div>
                <div class="metric-change">+ 120 ARTICLES</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Incentives Given</div>
                <div class="metric-value">₹12,400</div>
                <div class="metric-change">2.7% REDUCTION</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Retention Rate</div>
                <div class="metric-value">68%</div>
                <div class="metric-change">STABLE PERFORMANCE</div>
            </div>
        </section>

        <section class="chart-section">
            <div class="chart-box">
                <h3 class="chart-title">Growth Trajectory</h3>
                <div style="flex:1; border-bottom: 1px solid #eee; position: relative;">
                    <!-- Minimalist SVG Chart Content -->
                    <svg viewBox="0 0 800 200" preserveAspectRatio="none" style="width:100%; height:100%;">
                        <path d="M0,150 Q200,120 400,80 T800,20" fill="none" stroke="#000" stroke-width="2.5" />
                        <path d="M0,150 Q200,120 400,80 T800,20 L800,200 L0,200 Z" fill="rgba(0,0,0,0.03)" />
                    </svg>
                </div>
            </div>
            <div class="chart-box">
                <h3 class="chart-title">Payment Modality</h3>
                <div style="flex:1; display:flex; flex-direction:column; justify-content:center; gap:20px;">
                    <div style="display:flex; justify-content:space-between; font-size:0.7rem; text-transform:uppercase; letter-spacing:1px;">
                        <span>Digital Wallet</span>
                        <span style="font-weight:700;">45%</span>
                    </div>
                    <div style="background:#eee; height:2px;"><div style="background:#000; width:45%; height:100%;"></div></div>
                    
                    <div style="display:flex; justify-content:space-between; font-size:0.7rem; text-transform:uppercase; letter-spacing:1px;">
                        <span>Direct Banking</span>
                        <span style="font-weight:700;">30%</span>
                    </div>
                    <div style="background:#eee; height:2px;"><div style="background:#000; width:30%; height:100%;"></div></div>

                    <div style="display:flex; justify-content:space-between; font-size:0.7rem; text-transform:uppercase; letter-spacing:1px;">
                        <span>Cash Settlements</span>
                        <span style="font-weight:700;">25%</span>
                    </div>
                    <div style="background:#eee; height:2px;"><div style="background:#000; width:25%; height:100%;"></div></div>
                </div>
            </div>
        </section>

        <div class="data-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Identity</th>
                        <th>Timestamp</th>
                        <th>Beneficiary</th>
                        <th>Validation</th>
                        <th>Modality</th>
                        <th style="text-align: right;">Valuation</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="color:#999;">#ORD-9021</td>
                        <td>OCT 24, 2024</td>
                        <td style="font-weight:600;">ALEXANDER WANG</td>
                        <td><span class="status-badge">Settled</span></td>
                        <td>DIGITAL</td>
                        <td style="text-align: right; font-weight:600;">₹4,250.00</td>
                    </tr>
                    <tr>
                        <td style="color:#999;">#ORD-9022</td>
                        <td>OCT 24, 2024</td>
                        <td style="font-weight:600;">CHRISTOPHER LEMAIR</td>
                        <td><span class="status-badge">Transit</span></td>
                        <td>BANKING</td>
                        <td style="text-align: right; font-weight:600;">₹12,800.00</td>
                    </tr>
                    <tr>
                        <td style="color:#999;">#ORD-9023</td>
                        <td>OCT 23, 2024</td>
                        <td style="font-weight:600;">SYBIL VANE</td>
                        <td><span class="status-badge" style="background:#000; color:#fff;">Delivered</span></td>
                        <td>CASH</td>
                        <td style="text-align: right; font-weight:600;">₹1,150.00</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>

</body>
</html>