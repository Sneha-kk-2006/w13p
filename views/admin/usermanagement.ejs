<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SNOVA | User Management</title>

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />

<style>

:root {
--sidebar-bg: #e2dcd5;
--main-bg: #f3f4f6;
--snova-orange: #c86d4d;
--text-muted: #6b7280;
--border-color: #e5e7eb;
}

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{
background:var(--main-bg);
display:flex;
height:100vh;
overflow:hidden;
}

/* MAIN */

.main-content{
flex:1;
overflow-y:auto;
padding:40px;
}

/* HEADER */

.page-header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:40px;
}

.page-title{
font-size:32px;
font-weight:800;
border-bottom:3px solid #111;
padding-bottom:5px;
font-style:italic;
}

.add-user-btn{
background:#666;
color:white;
border:none;
padding:10px 20px;
border-radius:8px;
display:flex;
align-items:center;
gap:8px;
cursor:pointer;
}

/* CARD */

.user-card{
background:white;
border-radius:15px;
padding:30px;
border:1px solid var(--border-color);
}

/* CARD HEADER */

.card-header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:30px;
}

.controls{
display:flex;
gap:10px;
align-items:center;
}

/* SEARCH */

.search-box{
background:#f3f4f6;
border-radius:8px;
padding:8px 15px;
display:flex;
align-items:center;
gap:10px;
}

.search-box input{
border:none;
background:transparent;
outline:none;
font-size:13px;
}

/* BUTTONS */

.search-btn{
background:#444;
color:white;
border:none;
padding:8px 15px;
border-radius:6px;
cursor:pointer;
}

.clear-btn{
background:#ddd;
padding:8px 15px;
border-radius:6px;
text-decoration:none;
color:black;
}

/* TABLE */

table{
width:100%;
border-collapse:collapse;
}

th{
text-align:left;
padding:15px 10px;
font-size:13px;
border-bottom:2px solid #eee;
}

td{
padding:15px 10px;
font-size:13px;
border-bottom:1px solid #f3f4f6;
}

/* STATUS */

.active{
color:green;
font-weight:bold;
}

.blocked{
color:red;
font-weight:bold;
}

/* PAGINATION */

.footer-info{
display:flex;
justify-content:space-between;
align-items:center;
margin-top:25px;
}

.pagination-controls{
display:flex;
gap:10px;
}

.page-num{
padding:6px 12px;
background:#eee;
border-radius:4px;
text-decoration:none;
color:black;
}

.page-num.active{
background:#111;
color:white;
}

</style>
</head>

<body>

<%- include('../partials/admin/header') %>

<main class="main-content">

<header class="page-header">

<h1 class="page-title">User Management</h1>

<button class="add-user-btn">
<span class="material-symbols-outlined">person_add</span>
Add User
</button>

</header>

<div class="user-card">

<div class="card-header">

<h3>Users</h3>

<form method="GET" action="/admin/usermanagement" class="controls">

<div class="search-box">
<span class="material-symbols-outlined">search</span>

<input
type="text"
name="search"
value="<%= search || '' %>"
placeholder="Search users..."
>

</div>

<button type="submit" class="search-btn">
Search
</button>

<a href="/admin/usermanagement" class="clear-btn">
Clear
</a>

</form>

</div>

<table>

<thead>

<tr>
<th>Si.No</th>
<th>Name</th>
<th>Email</th>
<th>User ID</th>
<th>Status</th>
<th>Joined At</th>
<th>Action</th>
</tr>

</thead>
 <% let limit = 10 %>
<tbody>

<% users.forEach((user,index)=>{ %>

<tr>

<td>
   
<%= (currentPage - 1) * limit + index + 1 %>
</td>

<td><%= user.name %></td>

<td><%= user.email %></td>

<td><%= user._id %></td>

<td>

<% if(user.isBlocked){ %>

<span class="blocked">Blocked</span>

<% }else{ %>

<span class="active">Active</span>

<% } %>

</td>

<td>
<%= user.createdAt ? new Date(user.createdAt).toDateString() : "N/A" %>
</td>

<td>

<% if(!user.isBlocked){ %>

<a
href="/admin/blockUser?id=<%= user._id %>"
onclick="return confirm('Block this user?')"
>
Block
</a>

<% }else{ %>

<a
href="/admin/unblockUser?id=<%= user._id %>"
onclick="return confirm('Unblock this user?')"
>
Unblock
</a>

<% } %>

</td>

</tr>

<% }) %>

</tbody>

</table>

<div class="footer-info">

<div>
Showing page <strong><%= currentPage %></strong> of <strong><%= totalPages %></strong>
</div>

<div class="pagination-controls">

<% if(currentPage > 1){ %>

<a
href="/admin/usermanagement?page=<%= currentPage-1 %>&search=<%= search %>"
class="page-num"
>
Previous
</a>

<% } %>

<% for(let i=1;i<=totalPages;i++){ %>

<a
href="/admin/usermanagement?page=<%= i %>&search=<%= search %>"
class="page-num <%= currentPage === i ? 'active' : '' %>"
>
<%= i %>
</a>

<% } %>

<% if(currentPage < totalPages){ %>

<a
href="/admin/usermanagement?page=<%= currentPage+1 %>&search=<%= search %>"
class="page-num"
>
Next
</a>

<% } %>

</div>

</div>

</div>

</main>

</body>
</html>