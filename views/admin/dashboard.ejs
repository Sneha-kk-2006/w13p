<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --border-gray: #eee;
            --text-muted: #999;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body { background: var(--off-white); display: flex; min-height: 100vh; }

        .admin-main { flex: 1; padding: 40px; overflow-x: hidden; }

        .dash-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; border-bottom: 1px solid var(--border-gray); padding-bottom: 20px; }
        .dash-title { font-family: 'Playfair Display', serif; font-size: 2rem; letter-spacing: -1px; }

        .header-actions { display: flex; gap: 15px; }
        .btn-action { border: 1px solid #000; background: transparent; padding: 10px 20px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .btn-action:hover { background: #000; color: #fff; }
        .btn-primary { background: #000; color: #fff; }

        /* Stats */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .stat-card { padding: 30px; border: 1px solid var(--border-gray); display: flex; flex-direction: column; gap: 10px; }
        .stat-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2px; color: var(--text-muted); font-weight: 700; }
        .stat-val { font-size: 1.8rem; font-weight: 400; letter-spacing: -1px; }

        /* Analytics Layout */
        .analytics-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 30px; margin-bottom: 40px; }
        .card { background: #fff; padding: 30px; border: 1px solid var(--border-gray); }
        .card-title { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center; }

        .filter-select { border: none; border-bottom: 1px solid #000; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; outline: none; padding: 5px; cursor: pointer; }

        /* Table */
        .minimal-table { width: 100%; border-collapse: collapse; }
        .minimal-table th { text-align: left; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); padding: 15px 0; border-bottom: 1px solid var(--border-gray); }
        .minimal-table td { padding: 15px 0; font-size: 0.7rem; border-bottom: 1px solid var(--border-gray); text-transform: uppercase; }

        .identity-img-wrapper { 
            width: 40px; 
            height: 40px; 
            background: #f8f8f8; 
            overflow: hidden; 
            border: 1px solid #eee; 
            transition: transform 0.3s ease;
            cursor: pointer;
        }
        .identity-img-wrapper:hover {
            transform: scale(2.5);
            z-index: 10;
            position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            border-color: #000;
        }

        .progress-container { margin-bottom: 20px; }
        .progress-info { display: flex; justify-content: space-between; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; margin-bottom: 8px; }
        .progress-track { height: 2px; background: #f0f0f0; width: 100%; }
        .progress-bar { height: 100%; background: #000; }

        @media (max-width: 1024px) { .analytics-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

    <%- include('../partials/admin/header', { activePage: 'dashboard' }) %>

    <main class="admin-main">
        <header class="dash-header">
            <h1 class="dash-title">Executive Summary</h1>
            <div class="header-actions">
                <button class="btn-action" onclick="location.href='/admin/ledger'">Ledger Book</button>
                <button class="btn-action btn-primary" onclick="location.href='/admin/salesreport'">Sales Report</button>
            </div>
        </header>

        <div class="stats-grid">
            <div class="stat-card">
                <span class="stat-label">Gross Revenue</span>
                <div class="stat-val">₹<%= summary.totalRevenue.toLocaleString() %></div>
            </div>
            <div class="stat-card">
                <span class="stat-label">Total Orders</span>
                <div class="stat-val"><%= summary.totalOrders %></div>
            </div>
            <div class="stat-card" style="position: relative; overflow: hidden;">
                <span class="stat-label">Top Category</span>
                <div class="stat-val"><%= topCategories[0] ? topCategories[0].name : 'N/A' %></div>
                <% if (topCategories[0] && topCategories[0].image) { %>
                    <img src="<%= topCategories[0].image %>" style="position: absolute; right: -10px; bottom: -10px; width: 80px; height: 80px; object-fit: cover; opacity: 0.1; filter: grayscale(100%);">
                <% } %>
            </div>
            <div class="stat-card" style="position: relative; overflow: hidden;">
                <span class="stat-label">Best Selling Product</span>
                <div class="stat-val" style="font-size: 1.2rem; margin-top: 5px; line-height: 1.2;"><%= topProducts[0] ? topProducts[0].name : 'N/A' %></div>
                <% if (topProducts[0] && topProducts[0].image) { %>
                    <img src="<%= topProducts[0].image %>" style="position: absolute; right: 10px; bottom: 10px; width: 60px; height: 60px; object-fit: cover; border-radius: 50%; border: 2px solid #000;">
                <% } %>
            </div>
        </div>

        <div class="analytics-grid">
            <div class="card">
                <div class="card-title">
                    <span>Performance Overview</span>
                    <form action="/admin/dashboard" method="GET" id="filterForm">
                        <select name="filter" class="filter-select" onchange="this.form.submit()">
                            <option value="weekly" <%= filter === 'weekly' ? 'selected' : '' %>>Weekly</option>
                            <option value="monthly" <%= filter === 'monthly' ? 'selected' : '' %>>Monthly</option>
                            <option value="yearly" <%= filter === 'yearly' ? 'selected' : '' %>>Yearly</option>
                        </select>
                    </form>
                </div>
                <div style="height: 350px;">
                    <canvas id="performanceChart"></canvas>
                </div>
            </div>

            <div class="card">
                <div class="card-title">Category Share</div>
                <% topCategories.forEach(cat => { 
                    let percent = Math.round((cat.revenue / summary.totalRevenue) * 100) || 0;
                    if (percent > 100) percent = 100;
                %>
                <div class="progress-container">
                    <div class="progress-info">
                        <span><%= cat.name %></span>
                        <span><%= percent %>%</span>
                    </div>
                    <div class="progress-track"><div class="progress-bar" style="width: <%= percent %>%"></div></div>
                </div>
                <% }) %>
            </div>
        </div>

        <div class="analytics-grid">
            <!-- Best Selling Products -->
            <div class="card">
                <div class="card-title">Top 10 Products</div>
                <table class="minimal-table">
                    <thead>
                        <tr>
                            <th style="width: 40px;">#</th>
                            <th style="width: 60px;">Image</th>
                            <th>Product</th>
                            <th style="text-align: center;">Qty</th>
                            <th style="text-align: right;">Revenue</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% topProducts.forEach((prod, index) => { 
                            let finalImg = prod.image;
                            if (finalImg && !finalImg.startsWith('/') && !finalImg.startsWith('http')) {
                                finalImg = '/uploads/products/' + finalImg;
                            }
                        %>
                        <tr style="transition: background 0.3s;" onmouseover="this.style.background='#fcfcfc'" onmouseout="this.style.background='transparent'">
                            <td style="color: #ccc; font-weight: 700; font-size: 0.6rem;"><%= index + 1 %></td>
                            <td>
                                <div class="identity-img-wrapper" style="border-radius: 4px;">
                                    <img src="<%= finalImg %>" alt="" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='https://placehold.co/100x100?text=SNOVA'">
                                </div>
                            </td>
                            <td style="font-weight: 500; font-size: 0.75rem;"><%= prod.name %></td>
                            <td style="font-weight: 700; text-align: center;"><%= prod.totalQty %></td>
                            <td style="text-align: right; font-weight: 600;">₹<%= prod.revenue.toLocaleString('en-IN') %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- Best Selling Categories -->
            <div class="card">
                <div class="card-title">Top 10 Categories</div>
                <table class="minimal-table">
                    <thead>
                        <tr>
                            <th style="width: 40px;">#</th>
                            <th>Category Name</th>
                            <th style="text-align: center;">Qty</th>
                            <th style="text-align: right;">Revenue</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% topCategories.forEach((cat, index) => { %>
                        <tr style="transition: background 0.3s;" onmouseover="this.style.background='#fcfcfc'" onmouseout="this.style.background='transparent'">
                            <td style="color: #ccc; font-weight: 700; font-size: 0.6rem;"><%= index + 1 %></td>
                            <td style="font-weight: 500; font-size: 0.75rem;"><%= cat.name %></td>
                            <td style="font-weight: 700; text-align: center;"><%= cat.totalQty %></td>
                            <td style="text-align: right; font-weight: 600;">₹<%= cat.revenue.toLocaleString('en-IN') %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        const ctx = document.getElementById('performanceChart').getContext('2d');
        const salesData = <%- JSON.stringify(salesData) %>;

        const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        const labels = salesData.map(d => {
            if (d._id.month) {
                return `${monthNames[d._id.month - 1]} ${d._id.year}`;
            }
            if (d._id.week) {
                return `Week ${d._id.week}, ${d._id.year}`;
            }
            return d._id.year;
        });

        const revenue = salesData.map(d => d.revenue);

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Revenue',
                    data: revenue,
                    backgroundColor: '#000',
                    borderWidth: 0,
                    barThickness: 20
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#f8f8f8' },
                        ticks: { font: { size: 9 }, color: '#999' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { font: { size: 9 }, color: '#999' }
                    }
                }
            }
        });
    </script>
</body>
</html>