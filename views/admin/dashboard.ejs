<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .admin-main {
            flex: 1;
            padding: 60px 40px;
        }

        .dash-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 50px;
        }

        .dash-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        .btn-report {
            border: 1px solid #000;
            background: transparent;
            padding: 12px 25px;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-report:hover {
            background: #000;
            color: #fff;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card-minimal {
            background: #fff;
            padding: 30px;
            border: 0.5px solid #eee;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .stat-label {
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #999;
            font-weight: 700;
        }

        .stat-val {
            font-size: 1.8rem;
            font-weight: 400;
            letter-spacing: -0.5px;
        }

        .stat-meta {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        .meta-pos { color: #2ecc71; }
        .meta-neg { color: #e74c3c; }

        /* Charts Section */
        .analytics-row {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
        }

        .analytics-card {
            background: #fff;
            padding: 40px;
            border: 0.5px solid #eee;
        }

        .card-h {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Table */
        .minimal-table {
            width: 100%;
            border-collapse: collapse;
        }

        .minimal-table th {
            text-align: left;
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #999;
            padding: 15px 0;
            border-bottom: 0.5px solid #eee;
        }

        .minimal-table td {
            padding: 20px 0;
            font-size: 0.75rem;
            border-bottom: 0.5px solid #eee;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .p-thumb {
            width: 40px;
            aspect-ratio: 1/1;
            object-fit: cover;
            background: #f8f8f8;
        }

        .progress-track {
            height: 2px;
            background: #f0f0f0;
            margin-top: 10px;
        }

        .progress-bar {
            height: 100%;
            background: #000;
        }
    </style>
</head>
<body>

    <%- include('../partials/admin/header', { activePage: 'dashboard' }) %>

    <main class="admin-main">
        <header class="dash-header">
            <h1 class="dash-title">Executive Summary</h1>
            <button class="btn-report" onclick="location.href='/admin/salesreport'">Sales Report</button>
        </header>

        <div class="stats-grid">
            <div class="stat-card-minimal">
                <span class="stat-label">Gross Revenue</span>
                <div class="stat-val">₹45,231</div>
                <div class="stat-meta meta-pos">+20.1% VS PREV MONTH</div>
            </div>
            <div class="stat-card-minimal">
                <span class="stat-label">Total Volume</span>
                <div class="stat-val">2,350</div>
                <div class="stat-meta meta-pos">+15% VS PREV MONTH</div>
            </div>
            <div class="stat-card-minimal">
                <span class="stat-label">Unfulfilled</span>
                <div class="stat-val">48</div>
                <div class="stat-meta" style="color: #f39c12;">REQUIRES ATTENTION</div>
            </div>
            <div class="stat-card-minimal">
                <span class="stat-label">User Base</span>
                <div class="stat-val">12,234</div>
                <div class="stat-meta meta-pos">+7% VS PREV MONTH</div>
            </div>
        </div>

        <div class="analytics-row">
            <div class="analytics-card">
                <div class="card-h">
                    <span>Performance Overview</span>
                    <i class="fa-solid fa-ellipsis-vertical"></i>
                </div>
                <div style="height: 300px; display: flex; align-items: flex-end; gap: 10px; border-bottom: 0.5px solid #eee;">
                    <!-- Minimalist bar chart representation -->
                    <div style="flex:1; height: 40%; background: #000; opacity: 0.1;"></div>
                    <div style="flex:1; height: 60%; background: #000; opacity: 0.2;"></div>
                    <div style="flex:1; height: 35%; background: #000; opacity: 0.3;"></div>
                    <div style="flex:1; height: 80%; background: #000; opacity: 0.4;"></div>
                    <div style="flex:1; height: 55%; background: #000; opacity: 0.6;"></div>
                    <div style="flex:1; height: 90%; background: #000;"></div>
                </div>
            </div>

            <div class="analytics-card">
                <div class="card-h">Recent Sales</div>
                <div class="space-y-6">
                    <div class="flex items-center justify-between pb-4 border-bottom border-gray-50">
                        <div class="flex items-center gap-3">
                            <img src="https://ui-avatars.com/api/?name=OM&background=f0f0f0" class="w-8 h-8 rounded-full">
                            <div>
                                <div class="text-[10px] font-bold">OLIVIA MARTIN</div>
                                <div class="text-[9px] text-gray-400 lowercase">olivia@email.com</div>
                            </div>
                        </div>
                        <div class="text-[11px] font-bold">+₹1,999</div>
                    </div>
                    <!-- Item 2 -->
                    <div class="flex items-center justify-between pb-4 border-bottom border-gray-50">
                        <div class="flex items-center gap-3">
                            <img src="https://ui-avatars.com/api/?name=JL&background=f0f0f0" class="w-8 h-8 rounded-full">
                            <div>
                                <div class="text-[10px] font-bold">JACKSON LEE</div>
                                <div class="text-[9px] text-gray-400 lowercase">jackson@email.com</div>
                            </div>
                        </div>
                        <div class="text-[11px] font-bold">+₹2,450</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="analytics-row">
            <div class="analytics-card">
                <div class="card-h">Top Performing Inventory</div>
                <table class="minimal-table">
                    <thead>
                        <tr>
                            <th>Preview</th>
                            <th>Identity</th>
                            <th>Category</th>
                            <th>Units</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><img src="https://m.media-amazon.com/images/I/61H+Vf5V5dL._AC_UY1100_.jpg" class="p-thumb"></td>
                            <td>PRETTY WOMEN TOPS</td>
                            <td>WOMEN</td>
                            <td>342</td>
                            <td>₹1,95,390</td>
                        </tr>
                        <tr>
                            <td><img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcR_DqMvH9u094XhVn5yqf37iPz7q8vX8w9a2A&s" class="p-thumb"></td>
                            <td>PARTY WEAR SELECTION</td>
                            <td>WOMEN</td>
                            <td>288</td>
                            <td>₹99,388</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="analytics-card">
                <div class="card-h">Category Share</div>
                <div class="space-y-8 mt-10">
                    <div>
                        <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest">
                            <span>Menswear</span>
                            <span>45%</span>
                        </div>
                        <div class="progress-track"><div class="progress-bar" style="width: 45%;"></div></div>
                    </div>
                    <div>
                        <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest">
                            <span>Womenswear</span>
                            <span>28%</span>
                        </div>
                        <div class="progress-track"><div class="progress-bar" style="width: 28%;"></div></div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.tailwindcss.com"></script>
</body>
</html>