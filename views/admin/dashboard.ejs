<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Admin Dashboard</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0" />
    <style>
        :root {
            --sidebar-bg: #e2dcd5;
            --main-bg: #f3f4f6;
            --snova-orange: #c86d4d;
            --text-main: #1f2937;
            --text-muted: #6b7280;
            --white: #ffffff;
            --border-color: #e5e7eb;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }

        body { background-color: var(--main-bg); display: flex; height: 100vh; overflow: hidden; }

        /* Sidebar Styling */
        .sidebar { width: 240px; background-color: var(--sidebar-bg); display: flex; flex-direction: column; padding: 20px 0; border-right: 1px solid var(--border-color); }
        .logo-container { padding: 0 20px 30px; }
        .logo { background-color: var(--snova-orange); color: white; padding: 8px 15px; border-radius: 8px; font-weight: bold; font-size: 20px; display: inline-flex; align-items: center; gap: 8px; }
        
        .nav-section { margin-bottom: 25px; }
        .section-title { padding: 0 20px; font-size: 11px; text-transform: uppercase; color: var(--text-muted); letter-spacing: 1px; margin-bottom: 10px; }
        .nav-item { padding: 10px 20px; display: flex; align-items: center; gap: 12px; color: var(--text-main); text-decoration: none; font-size: 14px; transition: 0.2s; }
        .nav-item:hover, .nav-item.active { background-color: rgba(0,0,0,0.05); }
        .nav-item.active { font-weight: 600; background-color: #d1d5db; }
        .nav-item span { font-size: 20px; }

        .user-profile { margin-top: auto; padding: 15px 20px; display: flex; align-items: center; gap: 10px; border-top: 1px solid rgba(0,0,0,0.05); }
        .user-profile img { width: 35px; height: 35px; border-radius: 50%; object-fit: cover; }
        .user-info h4 { font-size: 13px; color: var(--text-main); }
        .user-info p { font-size: 11px; color: var(--text-muted); }

        /* Main Content */
        .main-content { flex: 1; overflow-y: auto; padding: 30px; }
        .header { display: flex; justify-content: flex-end; margin-bottom: 30px; }
        .view-report-btn { background-color: #d1d5db; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 500; cursor: pointer; }

        /* Dashboard Grid */
        .grid-container { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 25px; }
        .stat-card { background: var(--white); padding: 20px; border-radius: 12px; border: 1px solid var(--border-color); }
        .stat-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; color: var(--text-muted); font-size: 13px; }
        .stat-value { font-size: 24px; font-weight: 700; color: var(--text-main); }
        .stat-growth { font-size: 12px; margin-top: 5px; }
        .growth-pos { color: #10b981; }

        /* Middle Section: Chart and Recent Sales */
        .middle-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 25px; }
        .chart-card, .sales-card { background: var(--white); padding: 25px; border-radius: 12px; border: 1px solid var(--border-color); }
        .card-title { font-size: 16px; font-weight: 600; margin-bottom: 5px; }
        .card-subtitle { font-size: 13px; color: var(--text-muted); margin-bottom: 20px; }

        .sales-item { display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px; }
        .sales-user { display: flex; align-items: center; gap: 10px; }
        .sales-user img { width: 32px; height: 32px; border-radius: 50%; }
        .sales-details h5 { font-size: 13px; }
        .sales-details p { font-size: 11px; color: var(--text-muted); }
        .sales-amount { font-weight: 600; font-size: 14px; }

        /* Bottom Section: Table and Categories */
        .bottom-grid { display: grid; grid-template-columns: 2.2fr 1fr; gap: 20px; }
        .table-card { background: var(--white); padding: 25px; border-radius: 12px; border: 1px solid var(--border-color); }
        .table-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; font-size: 12px; color: var(--text-muted); padding-bottom: 15px; font-weight: 400; border-bottom: 1px solid var(--border-color); }
        td { padding: 12px 0; font-size: 13px; border-bottom: 1px solid var(--border-color); }
        .product-cell { display: flex; align-items: center; gap: 10px; }
        .product-cell img { width: 40px; height: 40px; border-radius: 4px; object-fit: cover; }

        /* Categories Progress */
        .category-item { margin-bottom: 15px; }
        .cat-info { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 5px; }
        .progress-bar { height: 8px; background: #f3f4f6; border-radius: 4px; overflow: hidden; }
        .progress-fill { height: 100%; background: #4b5563; border-radius: 4px; }
    </style>
</head>
<body>
 <%- include('../partials/admin/header') %>
     <main class="main-content">
        <header class="header">
            <button class="view-report-btn">view sales report</button>
        </header>

        <div class="grid-container">
            <div class="stat-card">
                <div class="stat-header">Total Revenue <span class="material-symbols-outlined" style="font-size: 16px;">help</span></div>
                <div class="stat-value">₹45,231.89</div>
                <div class="stat-growth growth-pos">↗ +20.1% from last month</div>
            </div>
            <div class="stat-card">
                <div class="stat-header">Total Orders <span class="material-symbols-outlined" style="font-size: 16px;">shopping_cart</span></div>
                <div class="stat-value">+2,350</div>
                <div class="stat-growth growth-pos">↗ +15% from last month</div>
            </div>
            <div class="stat-card">
                <div class="stat-header">Pending Orders <span class="material-symbols-outlined" style="font-size: 16px; color: orange;">stop</span></div>
                <div class="stat-value">48</div>
                <div class="stat-growth" style="color: var(--text-muted);">Requires attention</div>
            </div>
            <div class="stat-card">
                <div class="stat-header">Active Users <span class="material-symbols-outlined" style="font-size: 16px;">person_add</span></div>
                <div class="stat-value">+12,234</div>
                <div class="stat-growth growth-pos">↗ +7% from last month</div>
            </div>
        </div>

        <div class="middle-grid">
            <div class="chart-card">
                <h3 class="card-title">Revenue Overview</h3>
                <p class="card-subtitle">Monthly revenue performance for current year</p>
                <svg viewBox="0 0 500 200" style="width: 100%; height: 180px;">
                    <polyline fill="none" stroke="#10b981" stroke-width="3" 
                        points="0,180 50,160 100,150 150,130 200,90 250,90 300,85 350,70 400,30" />
                    <line x1="0" y1="190" x2="500" y2="190" stroke="#ddd" />
                </svg>
            </div>
            <div class="sales-card">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                    <h3 class="card-title">Recent Sales</h3>
                    <button style="border:none; background:#eee; padding:4px 10px; border-radius:4px; font-size:11px;">view more</button>
                </div>
                <p class="card-subtitle">You made 265 sales this month.</p>
                <div class="sales-list">
                    <div class="sales-item">
                        <div class="sales-user">
                            <img src="https://i.pravatar.cc/150?u=olivia" alt="">
                            <div class="sales-details"><h5>Olivia Martin</h5><p>olivia.martin@email.com</p></div>
                        </div>
                        <div class="sales-amount">₹ 1,999.00</div>
                    </div>
                    <div class="sales-item">
                        <div class="sales-user">
                            <img src="https://i.pravatar.cc/150?u=jackson" alt="">
                            <div class="sales-details"><h5>Jackson Lee</h5><p>jackson.lee@email.com</p></div>
                        </div>
                        <div class="sales-amount">₹ 39.00</div>
                    </div>
                    <div class="sales-item">
                        <div class="sales-user">
                            <img src="https://i.pravatar.cc/150?u=isabella" alt="">
                            <div class="sales-details"><h5>Isabella Nguyen</h5><p>isabella.nguyen@email.com</p></div>
                        </div>
                        <div class="sales-amount">₹ 299.00</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bottom-grid">
            <div class="table-card">
                <div class="table-header">
                    <div>
                        <h3 class="card-title">Top Trending Products</h3>
                        <p class="card-subtitle">Best performing items this week</p>
                    </div>
                    <button style="background:none; border:none; color:var(--text-muted); font-size:12px; cursor:pointer;">View All Products →</button>
                </div>
                <table>
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Product Name</th>
                            <th>Category</th>
                            <th>Sales</th>
                            <th>Revenue</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="product-cell"><img src="https://m.media-amazon.com/images/I/61H+Vf5V5dL._AC_UY1100_.jpg" alt=""></td>
                            <td>pretty women tops</td>
                            <td>Women</td>
                            <td>342</td>
                            <td>₹1,95,390</td>
                        </tr>
                        <tr>
                            <td class="product-cell"><img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcR_DqMvH9u094XhVn5yqf37iPz7q8vX8w9a2A&s" alt=""></td>
                            <td>part wear</td>
                            <td>women</td>
                            <td>288</td>
                            <td>₹99,388.00</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="table-card">
                <h3 class="card-title">Top Categories</h3>
                <p class="card-subtitle">Revenue share by category</p>
                <div class="category-item">
                    <div class="cat-info"><span>mens</span><span>45%</span></div>
                    <div class="progress-bar"><div class="progress-fill" style="width: 45%;"></div></div>
                </div>
                <div class="category-item">
                    <div class="cat-info"><span>women</span><span>28%</span></div>
                    <div class="progress-bar"><div class="progress-fill" style="width: 28%; background: #374151;"></div></div>
                </div>
                <button style="width:100%; padding:10px; margin-top:10px; border:none; background:#eee; border-radius:8px; font-size:12px;">View Categories</button>
            </div>
        </div>
    </main>

</body>
</html>