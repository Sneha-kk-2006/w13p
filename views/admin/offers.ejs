<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Offer Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        body {
            background-color: var(--off-white);
            color: var(--primary-black);
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
            margin: 0;
        }

        .admin-main { flex: 1; padding: 60px 40px; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px; }
        .page-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; text-transform: uppercase; letter-spacing: -1px; }
        
        .btn-minimal { background: transparent; border: 1px solid #000; padding: 12px 25px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .btn-minimal:hover { background: #000; color: #fff; }

        .data-table { width: 100%; border-collapse: collapse; background: #fff; border: 0.5px solid #eee; }
        .data-table th { text-align: left; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2px; color: #999; padding: 20px; border-bottom: 0.5px solid #eee; }
        .data-table td { padding: 20px; font-size: 0.75rem; border-bottom: 0.5px solid #eee; text-transform: uppercase; letter-spacing: 0.5px; }

        /* Modal Overlay */
        .modal-overlay { position: fixed; inset: 0; background: rgba(255,255,255,0.95); z-index: 1000; display: none; align-items: center; justify-content: center; overflow-y: auto; padding: 40px 0; }
        .modal-box { width: 90%; max-width: 500px; padding: 40px; background: #fff; box-shadow: 0 20px 80px rgba(0,0,0,0.05); }
        .modal-box h3 { font-family: 'Playfair Display', serif; font-size: 1.8rem; text-transform: uppercase; margin-bottom: 30px; }
        
        .form-group { margin-bottom: 25px; }
        .form-label { display: block; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; color: #999; margin-bottom: 8px; }
        .modal-form input, .modal-form select { width: 100%; border: none; border-bottom: 1px solid #000; padding: 12px 0; font-size: 0.85rem; outline: none; background: transparent; text-transform: uppercase; }
        .modal-form input::placeholder { color: #ccc; }

        .action-icon { cursor: pointer; font-size: 10px; margin-right: 15px; text-decoration: underline; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; background: none; border: none; padding: 0; }
        
        .status-badge { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; padding: 4px 8px; border: 1px solid #000; cursor: pointer; }
        .status-badge.inactive { color: #999; border-color: #eee; }

        .error-msg { font-size: 0.6rem; color: #ff0000; text-transform: uppercase; letter-spacing: 1px; margin-top: 5px; display: none; }
    </style>
</head>
<body style="display: flex;">

    <%- include('../partials/admin/header', { activePage: 'offers' }) %>

    <main class="admin-main">
        <header class="page-header">
            <h1 class="page-title">Offers</h1>
            <button class="btn-minimal" onclick="openModal('addOfferModal')">New Offer</button>
        </header>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Offer Name</th>
                    <th>Type</th>
                    <th>Target</th>
                    <th>Discount</th>
                    <th>Expiry</th>
                    <th>Status</th>
                    <th style="text-align: right;">Action</th>
                </tr>
            </thead>
            <tbody>
                <% if(typeof offers !== 'undefined' && offers.length > 0) { %>
                    <% offers.forEach((offer) => { %>
                        <tr>
                            <td style="font-weight: 700;"><%= offer.name %></td>
                            <td><%= offer.offerType %></td>
                            <td>
                                <% if(offer.offerType === 'product' && offer.product) { %>
                                    <%= offer.product.name %>
                                <% } else if(offer.offerType === 'category' && offer.category) { %>
                                    <%= offer.category.name %>
                                <% } else { %>
                                    General
                                <% } %>
                            </td>
                            <td><%= offer.discount %>%</td>
                            <td><%= new Date(offer.endDate).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }).toUpperCase() %></td>
                            <td>
                                <span class="status-badge <%= offer.isActive ? '' : 'inactive' %>" onclick="toggleStatus('<%= offer._id %>')">
                                    <%= offer.isActive ? 'Active' : 'Inactive' %>
                                </span>
                            </td>
                            <td style="text-align: right;">
                                <button class="action-icon" style="color: #e74c3c" onclick="confirmDelete('<%= offer._id %>')">Delete</button>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="7" style="text-align: center; color: #999; padding: 60px;">No offers found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </main>

    <!-- Create Offer Modal -->
    <div class="modal-overlay" id="addOfferModal">
        <div class="modal-box">
            <h3>New Offer</h3>
            <form id="addOfferForm" class="modal-form">
                <div class="form-group">
                    <label class="form-label">Offer Name</label>
                    <input type="text" id="offerName" placeholder="E.G. SUMMER SALE" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Offer Type</label>
                    <select id="offerType" required onchange="handleTypeChange()">
                        <option value="">SELECT TYPE</option>
                        <option value="product">PRODUCT</option>
                        <option value="category">CATEGORY</option>
                    </select>
                </div>

                <div class="form-group" id="targetContainer" style="display: none;">
                    <label class="form-label">Target Item</label>
                    <select id="referenceId" required>
                        <!-- Options populated via JS -->
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Discount (%)</label>
                    <input type="number" id="offerDiscount" placeholder="10" min="1" max="100" required>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group">
                        <label class="form-label">Start Date</label>
                        <input type="date" id="startDate" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">End Date</label>
                        <input type="date" id="endDate" required>
                    </div>
                </div>

                <button type="submit" class="btn-minimal w-full" style="margin-top: 20px;">Create Offer</button>
                <button type="button" class="btn-minimal w-full mt-4" style="border:none; color:#999;" onclick="closeModal('addOfferModal')">Cancel</button>
            </form>
        </div>
    </div>

    <script>
        const products = <%- JSON.stringify(typeof products !== 'undefined' ? products : []) %>;
        const categories = <%- JSON.stringify(typeof categories !== 'undefined' ? categories : []) %>;

        function openModal(id) { document.getElementById(id).style.display = 'flex'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }

        function handleTypeChange() {
            const type = document.getElementById('offerType').value;
            const container = document.getElementById('targetContainer');
            const select = document.getElementById('referenceId');
            
            select.innerHTML = '<option value="">SELECT ITEM</option>';
            
            if(type === 'product') {
                products.forEach(p => select.innerHTML += `<option value="${p._id}">${p.name}</option>`);
                container.style.display = 'block';
                select.required = true;
            } else if(type === 'category') {
                categories.forEach(c => select.innerHTML += `<option value="${c._id}">${c.name}</option>`);
                container.style.display = 'block';
                select.required = true;
            } else {
                container.style.display = 'none';
                select.required = false;
            }
        }

        function showToast(msg, type = 'success') {
            Toastify({
                text: msg.toUpperCase(), duration: 3000, gravity: "top", position: "center",
                style: { background: type === 'success' ? "#000" : "#ff0000", padding: "15px 40px", fontSize: "0.7rem", letterSpacing: "1.5px" }
            }).showToast();
        }

        document.getElementById('addOfferForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const payload = {
                name: document.getElementById('offerName').value,
                offerType: document.getElementById('offerType').value,
                referenceId: document.getElementById('referenceId').value,
                discount: parseInt(document.getElementById('offerDiscount').value),
                startDate: document.getElementById('startDate').value,
                endDate: document.getElementById('endDate').value
            };

            try {
                const res = await fetch('/admin/offers/add', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
                });
                const data = await res.json();
                if (data.success) { showToast("OFFER CREATED"); setTimeout(() => location.reload(), 1000); }
                else showToast(data.message || "ERROR", 'error');
            } catch (err) { showToast("SERVER ERROR", 'error'); }
        });

        async function toggleStatus(id) {
            try {
                const res = await fetch(`/admin/offers/toggle/${id}`, { method: "PATCH" });
                const data = await res.json();
                if(data.success) location.reload();
                else showToast("ERROR", 'error');
            } catch(e) { showToast("SERVER ERROR", 'error'); }
        }

        function confirmDelete(id) {
            Swal.fire({
                title: 'DELETE OFFER?', text: "CANNOT BE UNDONE", showCancelButton: true, confirmButtonColor: '#000', cancelButtonColor: '#999', confirmButtonText: 'DELETE'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const res = await fetch(`/admin/offers/delete/${id}`, { method: "DELETE" });
                        const data = await res.json();
                        if (data.success) { showToast("OFFER DELETED"); setTimeout(() => location.reload(), 1000); }
                        else showToast("ERROR", 'error');
                    } catch (err) { showToast("SERVER ERROR", 'error'); }
                }
            });
        }
    </script>
</body>
</html>
