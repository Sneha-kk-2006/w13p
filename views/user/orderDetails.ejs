<%- include("../partials/user/header") %>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

<style>
    :root {
        --primary: #1a1a1a;
        --accent: #d4af37;
        --bg-soft: #f8f9fa;
        --border-color: #e5e5e5;
        --text-muted: #6c757d;
    }

    body {
        background-color: var(--bg-soft);
        font-family: 'Inter', sans-serif;
    }

    .order-details-container {
        max-width: 1000px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .breadcrumb {
        font-size: 0.85rem;
        margin-bottom: 24px;
        color: var(--text-muted);
    }

    .breadcrumb a {
        color: var(--primary);
        text-decoration: none;
    }

    .order-header {
        background: white;
        padding: 32px;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        border: 1px solid var(--border-color);
    }

    .order-header h1 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 800;
    }

    .status-badge {
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .status-pending { background: #fff4e5; color: #b76e00; }
    .status-shipped { background: #e5f1ff; color: #0066cc; }
    .status-delivered { background: #e6fffa; color: #008767; }
    .status-cancelled { background: #ffe5e5; color: #cc0000; }
    .status-return-requested { background: #fff8e1; color: #ff8f00; }
    .status-returned { background: #e8f5e9; color: #2e7d32; }
    .status-return-rejected { background: #ffebee; color: #c62828; }

    .btn-download-invoice {
        width: 100%;
        padding: 14px;
        background-color: #000;
        color: #fff;
        border: 1px solid #000;
        border-radius: 8px;
        font-weight: 600;
        margin-top: 10px;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
    }

    .btn-download-invoice:hover {
        background-color: #333;
    }

    .btn-return-order {
        width: 100%;
        padding: 14px;
        background-color: transparent;
        color: #ff8f00;
        border: 1px solid #ff8f00;
        border-radius: 8px;
        font-weight: 600;
        margin-top: 20px;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .btn-return-order:hover {
        background-color: #fff8e1;
    }

    .details-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 24px;
    }

    @media (max-width: 992px) {
        .details-grid { grid-template-columns: 1fr; }
    }

    .card {
        background: white;
        border-radius: 16px;
        padding: 32px;
        border: 1px solid var(--border-color);
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        margin-bottom: 24px;
    }

    .card-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 24px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border-color);
    }

    .order-item {
        display: flex;
        gap: 20px;
        margin-bottom: 24px;
        padding-bottom: 24px;
        border-bottom: 1px solid var(--border-color);
    }

    .order-item:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .item-img {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 12px;
    }

    .item-info h4 {
        margin: 0 0 8px 0;
        font-size: 1.1rem;
    }

    .item-info p {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-size: 0.95rem;
    }

    .summary-row.total {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 2px solid var(--primary);
        font-weight: 800;
        font-size: 1.2rem;
    }

    .address-info p {
        margin: 0 0 8px 0;
        line-height: 1.6;
        color: var(--text-muted);
    }

    .address-info strong {
        color: var(--primary);
        display: block;
        margin-bottom: 4px;
    .btn-cancel-order {
        width: 100%;
        padding: 14px;
        background-color: transparent;
        color: #cc0000;
        border: 1px solid #cc0000;
        border-radius: 8px;
        font-weight: 600;
        margin-top: 20px;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .btn-cancel-order:hover {
        background-color: #ffe5e5;
    }
</style>

<div class="order-details-container">
    <div class="breadcrumb">
        <a href="/profile">My Account</a> / <a href="/profile">Orders</a> / Order #<%= order.orderId %>
    </div>

    <div class="order-header">
        <div>
            <h1>Order #<%= order.orderId %></h1>
            <p style="color: var(--text-muted); margin: 4px 0 0 0; font-size: 0.9rem;">
                Placed on <%= new Date(order.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %>
            </p>
        </div>
        <span class="status-badge status-<%= order.orderStatus.toLowerCase().replace(/ /g, '-') %>">
            <%= order.orderStatus %>
        </span>
    </div>

    <!-- Status Tracker -->
    <% if (!['Cancelled', 'Returned', 'Return Requested', 'Return Rejected'].includes(order.orderStatus)) { %>
        <% 
            const statuses = ['Pending', 'Shipped', 'Out for Delivery', 'Delivered'];
            const currentIndex = statuses.indexOf(order.orderStatus);
            const progressWidth = (currentIndex / (statuses.length - 1)) * 100;
        %>
        <div class="card status-tracker-card">
            <div class="tracker-container">
                <div class="progress-track">
                    <div class="progress-bar" style="width: <%= progressWidth %>%"></div>
                    <div class="truck-icon" style="left: calc(<%= progressWidth %>% - 20px)">
                        <i class="fa-solid fa-truck-fast"></i>
                    </div>
                </div>
                <div class="status-steps">
                    <% statuses.forEach((status, index) => { %>
                        <div class="step <%= index <= currentIndex ? 'active' : '' %>">
                            <div class="step-dot"></div>
                            <span class="step-label"><%= status %></span>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    <% } %>

    <style>
        .status-tracker-card {
            padding: 40px 60px !important;
            margin-bottom: 24px;
        }
        .tracker-container {
            position: relative;
            padding-top: 20px;
        }
        .progress-track {
            position: relative;
            height: 4px;
            background: #eee;
            border-radius: 2px;
            margin-bottom: 20px;
        }
        .progress-bar {
            position: absolute;
            height: 100%;
            background: var(--primary);
            border-radius: 2px;
            transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .truck-icon {
            position: absolute;
            top: -30px;
            font-size: 24px;
            color: var(--primary);
            transition: left 1s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 2;
            background: white;
            padding: 5px;
        }
        .status-steps {
            display: flex;
            justify-content: space-between;
            position: relative;
        }
        .step {
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
            position: relative;
        }
        .step-dot {
            width: 12px;
            height: 12px;
            background: #eee;
            border-radius: 50%;
            margin-bottom: 12px;
            border: 2px solid white;
            box-shadow: 0 0 0 2px #eee;
            z-index: 1;
            transition: 0.3s;
        }
        .step.active .step-dot {
            background: var(--primary);
            box-shadow: 0 0 0 2px var(--primary);
        }
        .step-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
            color: #999;
            transition: 0.3s;
        }
        .step.active .step-label {
            color: var(--primary);
        }
        @media (max-width: 576px) {
            .status-tracker-card { padding: 30px 20px !important; }
            .step-label { font-size: 0.5rem; }
        }
    </style>

    <div class="details-grid">
        <div class="details-left">
            <div class="card">
                <h3 class="card-title">Order Items</h3>
                <% order.orderItems.forEach(item => { %>
                    <% 
                        let displayImg = '';
                        if (item.product) {
                            if (item.product.images && item.product.images.length > 0) {
                                displayImg = item.product.images[0];
                            } else if (item.product.variants && item.product.variants.length > 0) {
                                const varWithImg = item.product.variants.find(v => v.images && v.images.length > 0);
                                if (varWithImg) displayImg = varWithImg.images[0];
                            }
                        }
                    %>
                    <div class="order-item">
                        <% if (item.product) { %>
                            <% 
                                let finalImage = displayImg || '';
                                let displaySrc = finalImage;
                                
                                // Ensure path is correct based on how it's stored
                                if (finalImage && !finalImage.startsWith('/') && !finalImage.startsWith('http')) {
                                    displaySrc = '/uploads/products/' + finalImage;
                                }
                            %>
                            <img src="<%= displaySrc %>" 
                                 alt="<%= item.product.name %>" 
                                 class="item-img" 
                                 onerror="this.onerror=null; 
                                          if(!this.src.includes('/uploads/')) {
                                              this.src='/uploads/products/'+'<%= finalImage %>';
                                          } else if(this.src.includes('/uploads/products/')) {
                                              this.src='/uploads/'+'<%= finalImage %>';
                                          } else {
                                              this.src='https://placehold.co/300x400?text=SNOVA';
                                          }">
                        <% } else { %>
                            <img src="https://placehold.co/300x400?text=Removed" class="item-img">
                        <% } %>
                        <div class="item-info">
                            <h4><%= item.product ? item.product.name : 'Product Removed' %></h4>
                            <% 
                                let itemSize = '';
                                let itemColor = '';
                                if (item.variantId && item.product && item.product.variants) {
                                    const variant = item.product.variants.find(v => v._id.toString() === item.variantId.toString());
                                    if (variant) {
                                        itemSize = variant.size;
                                        itemColor = variant.color;
                                    }
                                }
                            %>
                            <p style="margin-bottom: 4px;">Quantity: <%= item.quantity %></p>
                            <% if (itemSize || itemColor) { %>
                                <p style="margin-bottom: 4px; font-size: 0.85rem;">
                                    <% if (itemSize) { %>Size: <strong><%= itemSize %></strong><% } %>
                                    <% if (itemSize && itemColor) { %> | <% } %>
                                    <% if (itemColor) { %>Color: <strong><%= itemColor %></strong><% } %>
                                </p>
                            <% } %>
                            <p style="font-weight: 600; color: var(--primary); margin-top: 8px;">₹<%= item.price %></p>
                        </div>
                        <div class="item-actions" style="margin-left: auto; text-align: right; min-width: 150px;">
                            <% const itemStatus = item.status || order.orderStatus; %>
                            <span class="status-badge status-<%= itemStatus.toLowerCase().replace(/ /g, '-') %>" style="display: block; margin-bottom: 10px; font-size: 0.7rem;">
                                <%= itemStatus %>
                            </span>
                            <% if (itemStatus === 'Pending') { %>
                                <button class="btn-item-cancel" onclick="promptCancelItem('<%= order._id %>', '<%= item._id %>')" style="background: none; border: 1px solid #cc0000; color: #cc0000; padding: 5px 10px; font-size: 0.65rem; font-weight: 700; cursor: pointer; text-transform: uppercase;">Cancel Item</button>
                            <% } else if (itemStatus === 'Delivered') { %>
                                <button class="btn-item-return" onclick="promptReturnItem('<%= order._id %>', '<%= item._id %>')" style="background: none; border: 1px solid #ff8f00; color: #ff8f00; padding: 5px 10px; font-size: 0.65rem; font-weight: 700; cursor: pointer; text-transform: uppercase;">Return Item</button>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>

        <div class="details-right">
            <div class="card">
                <h3 class="card-title">Shipping Address</h3>
                <div class="address-info">
                    <strong><%= order.shippingAddress.fullName %></strong>
                    <p><%= order.shippingAddress.addressline1 %></p>
                    <p><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %></p>
                    <p><%= order.shippingAddress.country %> - <%= order.shippingAddress.pincode %></p>
                    <p>Phone: <%= order.shippingAddress.phone %></p>
                </div>
            </div>

            <div class="card">
                <h3 class="card-title">Payment Info</h3>
                <div class="summary-row">
                    <span>Method</span>
                    <span style="font-weight: 600;"><%= order.paymentMethod %></span>
                </div>
                <div class="summary-row">
                    <span>Status</span>
                    <span style="font-weight: 600;"><%= order.paymentStatus %></span>
                </div>
                <% if (order.paymentMethod === 'Razorpay' && (order.paymentStatus === 'Failed' || order.paymentStatus === 'Pending') && order.orderStatus !== 'Cancelled') { %>
                    <button onclick="retryPayment('<%= order._id %>')" class="btn-download-invoice" style="background: transparent; color: #000; margin-top: 15px;">
                        RETRY PAYMENT
                    </button>
                <% } %>
            </div>

            <div class="card">
                <h3 class="card-title">Order Summary</h3>
                <% 
                    let originalSubtotal = 0;
                    let cancellationReduction = 0;
                    order.orderItems.forEach(item => {
                        const lineTotal = item.price * item.quantity;
                        originalSubtotal += lineTotal;
                        if (item.status === 'Cancelled') {
                            cancellationReduction += lineTotal;
                        }
                    });
                %>
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>₹<%= originalSubtotal.toLocaleString() %></span>
                </div>
                <% if (cancellationReduction > 0) { %>
                    <div class="summary-row">
                        <span>Cancellation Adjustment</span>
                        <span style="color: #cc0000;">- ₹<%= cancellationReduction.toLocaleString() %></span>
                    </div>
                <% } %>
                <div class="summary-row">
                    <span>Discount</span>
                    <span style="color: #28a745;">- ₹<%= (order.discount || 0).toLocaleString() %></span>
                </div>
                <div class="summary-row">
                    <span>GST (18%)</span>
                    <span>+ ₹<%= (order.gst || 0).toLocaleString() %></span>
                </div>
                <div class="summary-row">
                    <span>Shipping</span>
                    <span style="color: #28a745;">Free</span>
                </div>
                <div class="summary-row total">
                    <span>Grand Total</span>
                    <span>₹<%= order.totalPrice.toLocaleString() %></span>
                </div>

                <% if (order.orderStatus === 'Delivered') { %>
                    <a href="/order/invoice/<%= order._id %>" class="btn-download-invoice">
                        <i class="fas fa-file-pdf"></i> Download Invoice
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
function promptCancelItem(orderId, itemId) {
    Swal.fire({
        title: 'CANCEL ITEM',
        text: 'PLEASE SELECT A REASON FOR CANCELLATION:',
        input: 'select',
        inputOptions: {
            'Changed my mind': 'Changed my mind',
            'Found a better price': 'Found a better price',
            'Ordered by mistake': 'Ordered by mistake',
            'Delivery takes too long': 'Delivery takes too long',
            'Other': 'Other'
        },
        inputPlaceholder: 'SELECT A REASON',
        showCancelButton: true,
        confirmButtonText: 'CONFIRM CANCELLATION',
        cancelButtonText: 'KEEP ITEM',
        confirmButtonColor: '#000',
        cancelButtonColor: '#999',
        inputValidator: (value) => {
            return new Promise((resolve) => {
                if (value) {
                    resolve();
                } else {
                    resolve('YOU NEED TO SELECT A REASON');
                }
            });
        }
    }).then((result) => {
        if (result.isConfirmed) {
            cancelItemRequest(orderId, itemId, result.value);
        }
    });
}

async function cancelItemRequest(orderId, itemId, reason) {
    try {
        const res = await fetch(`/order/cancel/${orderId}/${itemId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason })
        });
        const data = await res.json();
        
        if (data.success) {
            Toastify({
                text: "ITEM HAS BEEN CANCELLED",
                duration: 2000,
                gravity: "top",
                position: "center",
                style: { background: "#000", borderRadius: "0px" }
            }).showToast();
            setTimeout(() => { location.reload(); }, 2000);
        } else {
            Toastify({
                text: (data.message || "SOMETHING WENT WRONG").toUpperCase(),
                duration: 3000,
                gravity: "top",
                position: "center",
                style: { background: "#ff0000", borderRadius: "0px" }
            }).showToast();
        }
    } catch(err) {
        console.error(err);
        Toastify({
            text: "SERVER ERROR. PLEASE TRY AGAIN LATER",
            duration: 3000,
            gravity: "top",
            position: "center",
            style: { background: "#ff0000", borderRadius: "0px" }
        }).showToast();
    }
}

function promptReturnItem(orderId, itemId) {
    Swal.fire({
        title: 'RETURN ITEM',
        text: 'PLEASE SELECT A REASON FOR RETURN:',
        input: 'select',
        inputOptions: {
            'Defective product': 'Defective product',
            'Wrong item received': 'Wrong item received',
            'Product not as described': 'Product not as described',
            'Quality issues': 'Quality issues',
            'Other': 'Other'
        },
        inputPlaceholder: 'SELECT A REASON',
        showCancelButton: true,
        confirmButtonText: 'SUBMIT REQUEST',
        cancelButtonText: 'CANCEL',
        confirmButtonColor: '#000',
        cancelButtonColor: '#999',
        inputValidator: (value) => {
            return new Promise((resolve) => {
                if (value) {
                    resolve();
                } else {
                    resolve('YOU NEED TO SELECT A REASON');
                }
            });
        }
    }).then((result) => {
        if (result.isConfirmed) {
            returnItemRequest(orderId, itemId, result.value);
        }
    });
}

async function returnItemRequest(orderId, itemId, reason) {
    try {
        const res = await fetch(`/order/return/${orderId}/${itemId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason })
        });
        const data = await res.json();
        
        if (data.success) {
            Toastify({
                text: "RETURN REQUEST SUBMITTED",
                duration: 2000,
                gravity: "top",
                position: "center",
                style: { background: "#000", borderRadius: "0px" }
            }).showToast();
            setTimeout(() => { location.reload(); }, 2000);
        } else {
            Toastify({
                text: (data.message || "SOMETHING WENT WRONG").toUpperCase(),
                duration: 3000,
                gravity: "top",
                position: "center",
                style: { background: "#ff0000", borderRadius: "0px" }
            }).showToast();
        }
    } catch(err) {
        console.error(err);
        Toastify({
            text: "SERVER ERROR. PLEASE TRY AGAIN LATER",
            duration: 3000,
            gravity: "top",
            position: "center",
            style: { background: "#ff0000", borderRadius: "0px" }
        }).showToast();
    }
}

async function retryPayment(orderId) {
    try {
        const response = await fetch(`/order/retry-payment/${orderId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const data = await response.json();
        
        if (!data.success) {
            return Toastify({
                text: (data.message || "Failed to initiate payment").toUpperCase(),
                duration: 3000, gravity: "top", position: "center",
                style: { background: "#ff0000", borderRadius: "0px" }
            }).showToast();
        }

        const options = {
            key: data.keyId,
            amount: data.amount,
            currency: data.currency,
            name: "SNOVA",
            description: "Retry Order Payment",
            order_id: data.orderId,
            handler: async function (response) {
                try {
                    const verifyRes = await fetch(`/order/verify-retry/${orderId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            razorpay_order_id: response.razorpay_order_id,
                            razorpay_payment_id: response.razorpay_payment_id,
                            razorpay_signature: response.razorpay_signature
                        })
                    });
                    
                    const verifyData = await verifyRes.json();
                    
                    if (verifyData.success) {
                        window.location.href = `/checkout/success/${orderId}`;
                    } else {
                        Toastify({
                            text: (verifyData.message || "PAYMENT VERIFICATION FAILED").toUpperCase(),
                            duration: 3000, gravity: "top", position: "center",
                            style: { background: "#ff0000", borderRadius: "0px" }
                        }).showToast();
                    }
                } catch (err) {
                    Toastify({
                        text: "ERROR VERIFYING PAYMENT",
                        duration: 3000, gravity: "top", position: "center",
                        style: { background: "#ff0000", borderRadius: "0px" }
                    }).showToast();
                }
            },
            theme: { color: "#000000" }
        };

        const rzp = new window.Razorpay(options);
        rzp.on('payment.failed', function (response) {
            Toastify({
                text: "PAYMENT CANCELLED OR FAILED",
                duration: 3000, gravity: "top", position: "center",
                style: { background: "#ff0000", borderRadius: "0px" }
            }).showToast();
        });
        rzp.open();

    } catch (error) {
        Toastify({
            text: "SOMETHING WENT WRONG",
            duration: 3000, gravity: "top", position: "center",
            style: { background: "#ff0000", borderRadius: "0px" }
        }).showToast();
    }
}
</script>

<%- include("../partials/user/footer") %>
