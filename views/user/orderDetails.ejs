<%- include("../partials/user/header") %>

<style>
    :root {
        --primary: #1a1a1a;
        --accent: #d4af37;
        --bg-soft: #f8f9fa;
        --border-color: #e5e5e5;
        --text-muted: #6c757d;
    }

    body {
        background-color: var(--bg-soft);
        font-family: 'Inter', sans-serif;
    }

    .order-details-container {
        max-width: 1000px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .breadcrumb {
        font-size: 0.85rem;
        margin-bottom: 24px;
        color: var(--text-muted);
    }

    .breadcrumb a {
        color: var(--primary);
        text-decoration: none;
    }

    .order-header {
        background: white;
        padding: 32px;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        border: 1px solid var(--border-color);
    }

    .order-header h1 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 800;
    }

    .status-badge {
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .status-pending { background: #fff4e5; color: #b76e00; }
    .status-shipped { background: #e5f1ff; color: #0066cc; }
    .status-delivered { background: #e6fffa; color: #008767; }
    .status-cancelled { background: #ffe5e5; color: #cc0000; }
    .status-return-requested { background: #fff8e1; color: #ff8f00; }
    .status-returned { background: #e8f5e9; color: #2e7d32; }
    .status-return-rejected { background: #ffebee; color: #c62828; }

    .btn-download-invoice {
        width: 100%;
        padding: 14px;
        background-color: #000;
        color: #fff;
        border: 1px solid #000;
        border-radius: 8px;
        font-weight: 600;
        margin-top: 10px;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
    }

    .btn-download-invoice:hover {
        background-color: #333;
    }

    .btn-return-order {
        width: 100%;
        padding: 14px;
        background-color: transparent;
        color: #ff8f00;
        border: 1px solid #ff8f00;
        border-radius: 8px;
        font-weight: 600;
        margin-top: 20px;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .btn-return-order:hover {
        background-color: #fff8e1;
    }

    .details-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 24px;
    }

    @media (max-width: 992px) {
        .details-grid { grid-template-columns: 1fr; }
    }

    .card {
        background: white;
        border-radius: 16px;
        padding: 32px;
        border: 1px solid var(--border-color);
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        margin-bottom: 24px;
    }

    .card-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 24px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border-color);
    }

    .order-item {
        display: flex;
        gap: 20px;
        margin-bottom: 24px;
        padding-bottom: 24px;
        border-bottom: 1px solid var(--border-color);
    }

    .order-item:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .item-img {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 12px;
    }

    .item-info h4 {
        margin: 0 0 8px 0;
        font-size: 1.1rem;
    }

    .item-info p {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-size: 0.95rem;
    }

    .summary-row.total {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 2px solid var(--primary);
        font-weight: 800;
        font-size: 1.2rem;
    }

    .address-info p {
        margin: 0 0 8px 0;
        line-height: 1.6;
        color: var(--text-muted);
    }

    .address-info strong {
        color: var(--primary);
        display: block;
        margin-bottom: 4px;
    .btn-cancel-order {
        width: 100%;
        padding: 14px;
        background-color: transparent;
        color: #cc0000;
        border: 1px solid #cc0000;
        border-radius: 8px;
        font-weight: 600;
        margin-top: 20px;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .btn-cancel-order:hover {
        background-color: #ffe5e5;
    }
</style>

<div class="order-details-container">
    <div class="breadcrumb">
        <a href="/profile">My Account</a> / <a href="/profile">Orders</a> / Order #<%= order.orderId %>
    </div>

    <div class="order-header">
        <div>
            <h1>Order #<%= order.orderId %></h1>
            <p style="color: var(--text-muted); margin: 4px 0 0 0; font-size: 0.9rem;">
                Placed on <%= new Date(order.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %>
            </p>
        </div>
        <span class="status-badge status-<%= order.orderStatus.toLowerCase().replace(/ /g, '-') %>">
            <%= order.orderStatus %>
        </span>
    </div>

    <!-- Status Tracker -->
    <% if (!['Cancelled', 'Returned', 'Return Requested', 'Return Rejected'].includes(order.orderStatus)) { %>
        <% 
            const statuses = ['Pending', 'Shipped', 'Out for Delivery', 'Delivered'];
            const currentIndex = statuses.indexOf(order.orderStatus);
            const progressWidth = (currentIndex / (statuses.length - 1)) * 100;
        %>
        <div class="card status-tracker-card">
            <div class="tracker-container">
                <div class="progress-track">
                    <div class="progress-bar" style="width: <%= progressWidth %>%"></div>
                    <div class="truck-icon" style="left: calc(<%= progressWidth %>% - 20px)">
                        <i class="fa-solid fa-truck-fast"></i>
                    </div>
                </div>
                <div class="status-steps">
                    <% statuses.forEach((status, index) => { %>
                        <div class="step <%= index <= currentIndex ? 'active' : '' %>">
                            <div class="step-dot"></div>
                            <span class="step-label"><%= status %></span>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    <% } %>

    <style>
        .status-tracker-card {
            padding: 40px 60px !important;
            margin-bottom: 24px;
        }
        .tracker-container {
            position: relative;
            padding-top: 20px;
        }
        .progress-track {
            position: relative;
            height: 4px;
            background: #eee;
            border-radius: 2px;
            margin-bottom: 20px;
        }
        .progress-bar {
            position: absolute;
            height: 100%;
            background: var(--primary);
            border-radius: 2px;
            transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .truck-icon {
            position: absolute;
            top: -30px;
            font-size: 24px;
            color: var(--primary);
            transition: left 1s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 2;
            background: white;
            padding: 5px;
        }
        .status-steps {
            display: flex;
            justify-content: space-between;
            position: relative;
        }
        .step {
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
            position: relative;
        }
        .step-dot {
            width: 12px;
            height: 12px;
            background: #eee;
            border-radius: 50%;
            margin-bottom: 12px;
            border: 2px solid white;
            box-shadow: 0 0 0 2px #eee;
            z-index: 1;
            transition: 0.3s;
        }
        .step.active .step-dot {
            background: var(--primary);
            box-shadow: 0 0 0 2px var(--primary);
        }
        .step-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
            color: #999;
            transition: 0.3s;
        }
        .step.active .step-label {
            color: var(--primary);
        }
        @media (max-width: 576px) {
            .status-tracker-card { padding: 30px 20px !important; }
            .step-label { font-size: 0.5rem; }
        }
    </style>

    <div class="details-grid">
        <div class="details-left">
            <div class="card">
                <h3 class="card-title">Order Items</h3>
                <% order.orderItems.forEach(item => { %>
                    <% 
                        let displayImg = '';
                        if (item.product) {
                            if (item.product.images && item.product.images.length > 0) {
                                displayImg = item.product.images[0];
                            } else if (item.product.variants && item.product.variants.length > 0) {
                                const varWithImg = item.product.variants.find(v => v.images && v.images.length > 0);
                                if (varWithImg) displayImg = varWithImg.images[0];
                            }
                        }
                    %>
                    <div class="order-item">
                        <% if (item.product) { %>
                            <% 
                                let finalSrc = displayImg;
                                if (finalSrc && !finalSrc.startsWith('/') && !finalSrc.startsWith('http')) {
                                    finalSrc = '/uploads/products/' + finalSrc;
                                }
                            %>
                            <img src="<%= finalSrc %>" 
                                 alt="<%= item.product.name %>" 
                                 class="item-img" 
                                 onerror="this.onerror=null; if(!this.src.includes('/uploads/products/')) this.src='/uploads/products/'+'<%= displayImg %>'; else this.src='/uploads/'+'<%= displayImg %>'; this.onerror=function(){ this.src='https://placehold.co/300x400?text=SNOVA'; }">
                        <% } else { %>
                            <img src="https://placehold.co/300x400?text=Removed" class="item-img">
                        <% } %>
                        <div class="item-info">
                            <h4><%= item.product ? item.product.name : 'Product Removed' %></h4>
                            <% 
                                let itemSize = '';
                                let itemColor = '';
                                if (item.variantId && item.product && item.product.variants) {
                                    const variant = item.product.variants.find(v => v._id.toString() === item.variantId.toString());
                                    if (variant) {
                                        itemSize = variant.size;
                                        itemColor = variant.color;
                                    }
                                }
                            %>
                            <p style="margin-bottom: 4px;">Quantity: <%= item.quantity %></p>
                            <% if (itemSize || itemColor) { %>
                                <p style="margin-bottom: 4px; font-size: 0.85rem;">
                                    <% if (itemSize) { %>Size: <strong><%= itemSize %></strong><% } %>
                                    <% if (itemSize && itemColor) { %> | <% } %>
                                    <% if (itemColor) { %>Color: <strong><%= itemColor %></strong><% } %>
                                </p>
                            <% } %>
                            <p style="font-weight: 600; color: var(--primary); margin-top: 8px;">₹<%= item.price %></p>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>

        <div class="details-right">
            <div class="card">
                <h3 class="card-title">Shipping Address</h3>
                <div class="address-info">
                    <strong><%= order.shippingAddress.fullName %></strong>
                    <p><%= order.shippingAddress.addressline1 %></p>
                    <p><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %></p>
                    <p><%= order.shippingAddress.country %> - <%= order.shippingAddress.pincode %></p>
                    <p>Phone: <%= order.shippingAddress.phone %></p>
                </div>
            </div>

            <div class="card">
                <h3 class="card-title">Payment Info</h3>
                <div class="summary-row">
                    <span>Method</span>
                    <span style="font-weight: 600;"><%= order.paymentMethod %></span>
                </div>
                <div class="summary-row">
                    <span>Status</span>
                    <span style="font-weight: 600;"><%= order.paymentStatus %></span>
                </div>
            </div>

            <div class="card">
                <h3 class="card-title">Order Summary</h3>
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>₹<%= order.totalPrice %></span>
                </div>
                <div class="summary-row">
                    <span>Shipping</span>
                    <span style="color: #28a745;">Free</span>
                </div>
                <div class="summary-row total">
                    <span>Total</span>
                    <span>₹<%= order.totalPrice %></span>
                </div>
                <% if (order.orderStatus === 'Pending') { %>
                    <button class="btn-cancel-order" onclick="promptCancelOrder('<%= order._id %>')">Cancel Order</button>
                <% } else if (order.orderStatus === 'Delivered') { %>
                    <button class="btn-return-order" onclick="promptReturnOrder('<%= order._id %>')">Return Order</button>
                    <a href="/order/invoice/<%= order._id %>" class="btn-download-invoice">
                        <i class="fas fa-file-pdf"></i> Download Invoice
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
function promptCancelOrder(orderId) {
    Swal.fire({
        title: 'Cancel Order',
        text: 'Please select a reason for cancellation:',
        input: 'select',
        inputOptions: {
            'Changed my mind': 'Changed my mind',
            'Found a better price': 'Found a better price',
            'Ordered by mistake': 'Ordered by mistake',
            'Delivery takes too long': 'Delivery takes too long',
            'Other': 'Other'
        },
        inputPlaceholder: 'Select a reason',
        showCancelButton: true,
        confirmButtonText: 'Confirm Cancellation',
        cancelButtonText: 'Keep Order',
        confirmButtonColor: '#000',
        cancelButtonColor: '#999',
        inputValidator: (value) => {
            return new Promise((resolve) => {
                if (value) {
                    resolve();
                } else {
                    resolve('You need to select a reason');
                }
            });
        }
    }).then((result) => {
        if (result.isConfirmed) {
            cancelOrderRequest(orderId, result.value);
        }
    });
}

async function cancelOrderRequest(orderId, reason) {
    try {
        const res = await fetch(`/order/cancel/${orderId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason })
        });
        const data = await res.json();
        
        if (data.success) {
            Swal.fire({
                title: 'Cancelled',
                text: 'Your order has been cancelled.',
                icon: 'success',
                confirmButtonColor: '#000'
            }).then(() => {
                location.reload();
            });
        } else {
            Swal.fire('Error', data.message || 'Something went wrong', 'error');
        }
    } catch(err) {
        console.error(err);
        Swal.fire('Error', 'Server error. Please try again later.', 'error');
    }
}
function promptReturnOrder(orderId) {
    Swal.fire({
        title: 'Return Order',
        text: 'Please select a reason for return:',
        input: 'select',
        inputOptions: {
            'Defective product': 'Defective product',
            'Wrong item received': 'Wrong item received',
            'Product not as described': 'Product not as described',
            'Quality issues': 'Quality issues',
            'Other': 'Other'
        },
        inputPlaceholder: 'Select a reason',
        showCancelButton: true,
        confirmButtonText: 'Submit Request',
        cancelButtonText: 'Cancel',
        confirmButtonColor: '#ff8f00',
        cancelButtonColor: '#999',
        inputValidator: (value) => {
            return new Promise((resolve) => {
                if (value) {
                    resolve();
                } else {
                    resolve('You need to select a reason');
                }
            });
        }
    }).then((result) => {
        if (result.isConfirmed) {
            returnOrderRequest(orderId, result.value);
        }
    });
}

async function returnOrderRequest(orderId, reason) {
    try {
        const res = await fetch(`/order/return/${orderId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason })
        });
        const data = await res.json();
        
        if (data.success) {
            Swal.fire({
                title: 'Requested',
                text: 'Your return request has been submitted.',
                icon: 'success',
                confirmButtonColor: '#000'
            }).then(() => {
                location.reload();
            });
        } else {
            Swal.fire('Error', data.message || 'Something went wrong', 'error');
        }
    } catch(err) {
        console.error(err);
        Swal.fire('Error', 'Server error. Please try again later.', 'error');
    }
}
</script>

<%- include("../partials/user/footer") %>
