<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | My Orders</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--primary-black);
            -webkit-font-smoothing: antialiased;
        }

        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }

        .main-content {
            flex: 1;
            padding: 60px 5%;
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            text-transform: uppercase;
            letter-spacing: -1px;
            margin-bottom: 50px;
        }

        .orders-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .orders-table th {
            text-align: left;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #999;
            padding: 20px;
            border-bottom: 1px solid #000;
        }

        .orders-table td {
            padding: 25px 20px;
            border-bottom: 0.5px solid var(--border-light);
            font-size: 0.8rem;
            vertical-align: middle;
        }

        .order-id {
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .status-badge {
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 4px;
        }

        .status-pending { background: #fff4e5; color: #b76e00; }
        .status-shipped { background: #e5f1ff; color: #0066cc; }
        .status-delivered { background: #e6fffa; color: #008767; }
        .status-cancelled { background: #ffe5e5; color: #cc0000; }

        .view-link {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
            text-decoration: underline;
            color: #000;
        }

        .btn-clear {
            background: transparent;
            color: #cc0000;
            border: 1px solid #cc0000;
            padding: 8px 16px;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-clear:hover {
            background: #ffe5e5;
        }

        @media (max-width: 768px) {
            .dashboard-container { flex-direction: column; }
            .orders-table th:nth-child(3), .orders-table td:nth-child(3) { display: none; }
            .page-header-container { flex-direction: column; gap: 20px; align-items: flex-start !important; }
        }
    </style>
</head>
<body>

    <%- include('../partials/user/header') %>

    <div class="dashboard-container">
        <% var activePage = 'orders'; %>
        <%- include('../partials/user/sidebar', { activePage: 'orders' }) %>

        <main class="main-content">
            <div class="page-header-container" style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 50px;">
                <h1 class="page-title" style="margin-bottom: 0;">MY ORDERS</h1>
                <div style="display: flex; gap: 15px; align-items: center;">
                    <div style="position: relative; display: flex; align-items: center; border-bottom: 1px solid #000; padding-bottom: 5px;">
                        <input type="text" id="orderSearch" placeholder="SEARCH ORDER ID..." value="<%= typeof search !== 'undefined' ? search : '' %>" 
                               onkeypress="if(event.key==='Enter') searchOrders()"
                               style="border: none; outline: none; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; width: 200px; background: transparent;">
                        <i class="fa-solid fa-magnifying-glass" onclick="searchOrders()" style="font-size: 0.8rem; cursor: pointer;"></i>
                    </div>
                    <% if (orders && orders.length > 0) { %>
                        <button class="btn-clear" onclick="clearOrderHistory()">Clear History</button>
                    <% } %>
                </div>
            </div>

            <% if (orders && orders.length > 0) { %>
                <table class="orders-table">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Date</th>
                            <th>Payment</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(order => { %>
                            <tr>
                                <td class="order-id">#<%= order.orderId %></td>
                                <td><%= new Date(order.createdAt).toLocaleDateString('en-GB') %></td>
                                <td style="text-transform: uppercase; font-size: 0.7rem;"><%= order.paymentMethod %></td>
                                <td>
                                    <span class="status-badge status-<%= order.orderStatus.toLowerCase().replace(/ /g, '-') %>">
                                        <%= order.orderStatus %>
                                    </span>
                                </td>
                                <td style="font-weight: 600;">₹<%= order.totalPrice %></td>
                                <td style="text-align: right; display: flex; align-items: center; justify-content: flex-end; gap: 15px;">
                                    <% if (order.paymentMethod === 'Razorpay' && (order.paymentStatus === 'Failed' || order.paymentStatus === 'Pending') && order.orderStatus !== 'Cancelled') { %>
                                        <button onclick="retryPayment('<%= order._id %>')" class="btn-clear" style="color: #000; border-color: #000; padding: 4px 10px;">Retry Payment</button>
                                    <% } %>
                                    <% if (order.orderStatus === 'Delivered') { %>
                                        <a href="/order/invoice/<%= order._id %>" title="Download Invoice" style="color: #000; font-size: 0.9rem;">
                                            <i class="fa-solid fa-file-pdf"></i>
                                        </a>
                                    <% } %>
                                    <a href="/order-details/<%= order._id %>" class="view-link">View Details</a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <div style="text-align: center; padding: 100px 0;">
                    <i class="fa-solid fa-bag-shopping" style="font-size: 3rem; color: #eee; margin-bottom: 20px;"></i>
                    <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem; color: #999;">You haven't placed any orders yet.</p>
                    <a href="/products" class="view-link" style="display: block; margin-top: 20px;">Start Shopping</a>
                </div>
            <% } %>
        </main>
    </div>
   <% if (totalPages > 1) { %>
  <div style="display:flex; justify-content:center; align-items:center; gap:10px; margin-top:40px; padding-bottom:40px;">
    
    <% if (currentPage > 1) { %>
      <a href="/orders?page=<%= currentPage - 1 %>&search=<%= search %>"
         style="padding:8px 16px; border:1px solid #000; font-size:0.65rem; text-transform:uppercase; letter-spacing:2px; text-decoration:none; color:#000;">
        Prev
      </a>
    <% } %>

    <% for (let i = 1; i <= totalPages; i++) { %>
      <a href="/orders?page=<%= i %>&search=<%= search %>"
         style="padding:8px 14px; 
                border:1px solid <%= i === currentPage ? '#000' : '#eee' %>; 
                background:<%= i === currentPage ? '#000' : 'transparent' %>; 
                color:<%= i === currentPage ? '#fff' : '#999' %>; 
                font-size:0.65rem; text-transform:uppercase; letter-spacing:1px; text-decoration:none;">
        <%= i %>
      </a>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <a href="/orders?page=<%= currentPage + 1 %>&search=<%= search %>"
         style="padding:8px 16px; border:1px solid #000; font-size:0.65rem; text-transform:uppercase; letter-spacing:2px; text-decoration:none; color:#000;">
        Next
      </a>
    <% } %>

  </div>
<% } %>

<p style="text-align:center; font-size:0.65rem; color:#999; text-transform:uppercase; letter-spacing:1px; margin-top:10px;">
  Page <%= currentPage %> of <%= totalPages %>
</p>
    <%- include('../partials/user/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        function searchOrders() {
            const search = document.getElementById('orderSearch').value.trim();
            window.location.href = `/orders?search=${encodeURIComponent(search)}`;
        }

        function clearOrderHistory() {
            Swal.fire({
                title: 'CLEAR ORDER HISTORY?',
                text: "THIS ACTION WILL PERMANENTLY REMOVE ALL PAST ORDERS FROM YOUR ACCOUNT.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#000',
                cancelButtonColor: '#999',
                confirmButtonText: 'YES, CLEAR HISTORY',
                cancelButtonText: 'GO BACK'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const response = await fetch('/orders/clear', {
                            method: 'DELETE',
                            headers: { 'Content-Type': 'application/json' }
                        });
                        const data = await response.json();
                        
                        if (data.success) {
                            Toastify({
                                text: "ORDER HISTORY HAS BEEN PERMANENTLY REMOVED",
                                duration: 2000,
                                gravity: "top",
                                position: "center",
                                style: { background: "#000", borderRadius: "0px" }
                            }).showToast();
                            setTimeout(() => { location.reload(); }, 2000);
                        } else {
                            Toastify({
                                text: (data.message || "COULD NOT CLEAR HISTORY").toUpperCase(),
                                duration: 3000,
                                gravity: "top",
                                position: "center",
                                style: { background: "#ff0000", borderRadius: "0px" }
                            }).showToast();
                        }
                    } catch (error) {
                        Toastify({
                            text: "AN UNEXPECTED ERROR OCCURRED",
                            duration: 3000,
                            gravity: "top",
                            position: "center",
                            style: { background: "#ff0000", borderRadius: "0px" }
                        }).showToast();
                    }
                }
            });
        }

        async function retryPayment(orderId) {
            try {
                const response = await fetch(`/order/retry-payment/${orderId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                const data = await response.json();
                
                if (!data.success) {
                    return Toastify({
                        text: (data.message || "Failed to initiate payment").toUpperCase(),
                        duration: 3000, gravity: "top", position: "center",
                        style: { background: "#ff0000", borderRadius: "0px" }
                    }).showToast();
                }

                const options = {
                    key: data.keyId,
                    amount: data.amount,
                    currency: data.currency,
                    name: "SNOVA",
                    description: "Retry Order Payment",
                    order_id: data.orderId,
                    handler: async function (response) {
                        try {
                            const verifyRes = await fetch(`/order/verify-retry/${orderId}`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    razorpay_order_id: response.razorpay_order_id,
                                    razorpay_payment_id: response.razorpay_payment_id,
                                    razorpay_signature: response.razorpay_signature
                                })
                            });
                            
                            const verifyData = await verifyRes.json();
                            
                            if (verifyData.success) {
                                window.location.href = `/checkout/success/${orderId}`;
                            } else {
                                Toastify({
                                    text: (verifyData.message || "PAYMENT VERIFICATION FAILED").toUpperCase(),
                                    duration: 3000, gravity: "top", position: "center",
                                    style: { background: "#ff0000", borderRadius: "0px" }
                                }).showToast();
                            }
                        } catch (err) {
                            Toastify({
                                text: "ERROR VERIFYING PAYMENT",
                                duration: 3000, gravity: "top", position: "center",
                                style: { background: "#ff0000", borderRadius: "0px" }
                            }).showToast();
                        }
                    },
                    theme: { color: "#000000" }
                };

                const rzp = new window.Razorpay(options);
                rzp.on('payment.failed', function (response) {
                    Toastify({
                        text: "PAYMENT CANCELLED OR FAILED",
                        duration: 3000, gravity: "top", position: "center",
                        style: { background: "#ff0000", borderRadius: "0px" }
                    }).showToast();
                });
                rzp.open();

            } catch (error) {
                Toastify({
                    text: "SOMETHING WENT WRONG",
                    duration: 3000, gravity: "top", position: "center",
                    style: { background: "#ff0000", borderRadius: "0px" }
                }).showToast();
            }
        }

    </script>
</body>
</html>
