<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Reset Password</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

    <style>
        :root {
            --primary-black: #000000;
            --off-white: #ffffff;
            --text-gray: #666;
            --border-gray: #e5e5e5;
            --error-red: #d32f2f;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', sans-serif; }
        body { background-color: var(--off-white); color: var(--primary-black); min-height: 100vh; -webkit-font-smoothing: antialiased; display: flex; align-items: center; justify-content: center; }

        .form-wrapper { width: 100%; max-width: 400px; padding: 40px; }

        .header { margin-bottom: 50px; }
        .header h1 { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 400; letter-spacing: -1px; text-transform: uppercase; margin-bottom: 15px; }
        .header p { font-size: 0.7rem; color: var(--text-gray); text-transform: uppercase; letter-spacing: 2px; line-height: 1.6; }

        .form-group { margin-bottom: 35px; position: relative; }
        .form-group label { display: block; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px; font-weight: 600; }

        .input-box { position: relative; display: flex; align-items: center; }
        .form-group input {
            width: 100%; padding: 12px 0; border: none;
            border-bottom: 1.5px solid var(--primary-black);
            font-size: 0.9rem; outline: none; background: transparent;
            transition: border-color 0.2s;
        }
        .form-group input.input-error { border-bottom-color: var(--error-red); }

        .toggle-btn {
            position: absolute; right: 0; top: 50%; transform: translateY(-50%);
            background: none; border: none; font-size: 0.6rem; text-transform: uppercase;
            letter-spacing: 1.5px; font-weight: 700; cursor: pointer; color: #999;
        }

        .error-msg {
            font-size: 0.6rem; color: var(--error-red); text-transform: uppercase;
            letter-spacing: 1px; margin-top: 8px; display: block; min-height: 14px;
        }

        /* Password strength bar */
        .strength-bar { display: flex; gap: 4px; margin-top: 10px; }
        .strength-bar span { height: 3px; flex: 1; background: #e0e0e0; border-radius: 2px; transition: background 0.3s; }

        .strength-label {
            font-size: 0.55rem; text-transform: uppercase; letter-spacing: 1px;
            margin-top: 6px; color: #999;
        }

        /* Server-side flash banner */
        .alert-banner {
            padding: 14px 18px; font-size: 0.65rem; text-transform: uppercase;
            letter-spacing: 1.5px; font-weight: 600; margin-bottom: 30px; border-left: 3px solid;
        }
        .alert-banner.error { background: #fff5f5; color: var(--error-red); border-color: var(--error-red); }

        .btn-minimal {
            width: 100%; padding: 20px;
            background: var(--primary-black); color: var(--off-white);
            border: 1px solid var(--primary-black);
            text-transform: uppercase; letter-spacing: 3px; font-size: 0.75rem; font-weight: 600;
            cursor: pointer; transition: 0.3s; margin-top: 10px;
        }
        .btn-minimal:hover:not(:disabled) { background: transparent; color: var(--primary-black); }
        .btn-minimal:disabled { opacity: 0.5; cursor: not-allowed; }

        .footer-links { margin-top: 40px; text-align: center; }
        .footer-links a { color: var(--primary-black); text-decoration: none; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; border-bottom: 1px solid transparent; transition: 0.3s; }
        .footer-links a:hover { border-bottom: 1px solid var(--primary-black); }
    </style>
</head>
<body>
    <div class="form-wrapper">
        <header class="header">
            <div onclick="location.href='/'" style="cursor: pointer; font-family: 'Playfair Display', serif; font-size: 1.5rem; letter-spacing: 4px; margin-bottom: 60px; text-align: center;">SNOVA</div>
            <h1>Reset Password</h1>
            <p>Create a strong new password for your account.</p>
        </header>

        <%# Server-side error banner (page-reload fallback) %>
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert-banner error"><%= message %></div>
        <% } %>

        <form id="resetForm" novalidate>
            <div class="form-group">
                <label for="pass">New Password</label>
                <div class="input-box">
                    <input type="password" name="password" id="pass" placeholder="Min 8 chars" autocomplete="new-password">
                    <button type="button" class="toggle-btn" onclick="togglePassword('pass', this)">Show</button>
                </div>
                <!-- Password strength bar -->
                <div class="strength-bar" id="strengthBar">
                    <span id="s1"></span>
                    <span id="s2"></span>
                    <span id="s3"></span>
                    <span id="s4"></span>
                </div>
                <span class="strength-label" id="strengthLabel"></span>
                <span class="error-msg" id="passError"></span>
            </div>

            <div class="form-group">
                <label for="confirm-pass">Confirm Password</label>
                <div class="input-box">
                    <input type="password" name="confirmPassword" id="confirm-pass" placeholder="Repeat password" autocomplete="new-password">
                    <button type="button" class="toggle-btn" onclick="togglePassword('confirm-pass', this)">Show</button>
                </div>
                <span class="error-msg" id="confirmError"></span>
            </div>

            <button type="submit" id="submitBtn" class="btn-minimal">Update Password</button>
        </form>

        <div class="footer-links">
            <a href="/login">Return to Login</a>
        </div>
    </div>

    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
        const strongPassword = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*()\-_=+[\]{};:'",.<>?/\\|`~]).{8,}$/;

        function togglePassword(id, btn) {
            const input = document.getElementById(id);
            input.type = input.type === 'password' ? 'text' : 'password';
            btn.textContent = input.type === 'password' ? 'Show' : 'Hide';
        }

        // ── Password strength meter ──────────────────────────────────
        function getStrength(pwd) {
            let score = 0;
            if (pwd.length >= 8) score++;
            if (/[A-Z]/.test(pwd) && /[a-z]/.test(pwd)) score++;
            if (/\d/.test(pwd)) score++;
            if (/[!@#$%^&*()\-_=+[\]{};:'",.<>?/\\|`~]/.test(pwd)) score++;
            return score;
        }

        const colors = ['#d32f2f', '#ff6f00', '#fbc02d', '#2e7d32'];
        const labels = ['Weak', 'Fair', 'Good', 'Strong'];

        document.getElementById('pass').addEventListener('input', function () {
            const pwd = this.value;
            const score = pwd ? getStrength(pwd) : 0;
            const bars = [document.getElementById('s1'), document.getElementById('s2'), document.getElementById('s3'), document.getElementById('s4')];
            const labelEl = document.getElementById('strengthLabel');

            bars.forEach((b, i) => {
                b.style.background = i < score ? colors[score - 1] : '#e0e0e0';
            });
            labelEl.textContent = pwd ? labels[score - 1] || '' : '';
            labelEl.style.color = score > 0 ? colors[score - 1] : '#999';

            // Clear error while typing
            if (document.getElementById('passError').textContent) {
                setFieldError('passError', 'pass', '');
            }
            // Live confirm-match feedback
            const confirm = document.getElementById('confirm-pass').value;
            if (confirm && pwd !== confirm) {
                setFieldError('confirmError', 'confirm-pass', 'Passwords do not match');
            } else if (confirm && pwd === confirm) {
                setFieldError('confirmError', 'confirm-pass', '');
            }
        });

        document.getElementById('confirm-pass').addEventListener('input', function () {
            const pwd = document.getElementById('pass').value;
            if (this.value && pwd !== this.value) {
                setFieldError('confirmError', 'confirm-pass', 'Passwords do not match');
            } else {
                setFieldError('confirmError', 'confirm-pass', '');
            }
        });

        // ── Helpers ──────────────────────────────────────────────────
        function setFieldError(errId, inputId, msg) {
            document.getElementById(errId).textContent = msg;
            if (inputId) {
                document.getElementById(inputId).classList.toggle('input-error', !!msg);
            }
        }

        function clearErrors() {
            setFieldError('passError', 'pass', '');
            setFieldError('confirmError', 'confirm-pass', '');
        }

        // ── Submit ───────────────────────────────────────────────────
        document.getElementById('resetForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            clearErrors();

            const password = document.getElementById('pass').value;
            const confirmPassword = document.getElementById('confirm-pass').value;
            const btn = document.getElementById('submitBtn');
            let valid = true;

            if (!password) {
                setFieldError('passError', 'pass', 'Password is required');
                valid = false;
            } else if (!strongPassword.test(password)) {
                setFieldError('passError', 'pass', 'Min 8 chars with uppercase, lowercase, number & symbol');
                valid = false;
            }

            if (!confirmPassword) {
                setFieldError('confirmError', 'confirm-pass', 'Please confirm your password');
                valid = false;
            } else if (password && confirmPassword && password !== confirmPassword) {
                setFieldError('confirmError', 'confirm-pass', 'Passwords do not match');
                valid = false;
            }

            if (!valid) return;

            btn.disabled = true;
            btn.textContent = 'Updating...';

            try {
                const res = await fetch('/resetPassword', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ password, confirmPassword })
                });

                const data = await res.json();

                if (data.success) {
                    showToast('Password updated successfully!', '#000');
                    setTimeout(() => window.location.href = data.redirectUrl || '/login', 1500);
                } else {
                    const msg = data.message || 'Something went wrong. Please try again.';

                    // Map server messages to inline field errors
                    if (msg.toLowerCase().includes('match')) {
                        setFieldError('confirmError', 'confirm-pass', msg);
                    } else if (msg.toLowerCase().includes('session') || msg.toLowerCase().includes('expired')) {
                        showToast('Session expired. Please restart the forgot password process.', '#d32f2f');
                        setTimeout(() => window.location.href = '/forgotPassword', 2500);
                    } else if (msg.toLowerCase().includes('same') || msg.toLowerCase().includes('different') || msg.toLowerCase().includes('current')) {
                        setFieldError('passError', 'pass', msg);
                    } else if (msg.toLowerCase().includes('password')) {
                        setFieldError('passError', 'pass', msg);
                    } else {
                        showToast(msg, '#d32f2f');
                    }

                    btn.disabled = false;
                    btn.textContent = 'Update Password';
                }
            } catch (err) {
                console.error(err);
                showToast('Network error. Please check your connection.', '#d32f2f');
                btn.disabled = false;
                btn.textContent = 'Update Password';
            }
        });

        function showToast(msg, bg) {
            Toastify({
                text: (msg || '').toUpperCase(),
                duration: 4000,
                gravity: 'top',
                position: 'center',
                style: {
                    background: bg,
                    color: '#fff',
                    borderRadius: '0px',
                    fontSize: '0.65rem',
                    letterSpacing: '1.5px',
                    fontWeight: '500',
                    fontFamily: "'Inter', sans-serif",
                    padding: '14px 30px',
                    textTransform: 'uppercase'
                }
            }).showToast();
        }
    </script>
</body>
</html>