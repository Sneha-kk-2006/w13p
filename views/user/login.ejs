<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary-black: #000000;
            --off-white: #ffffff;
            --text-gray: #666;
            --border-gray: #e5e5e5;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--primary-black);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        .auth-container {
            display: flex;
            min-height: 100vh;
        }

        .auth-image-side {
            flex: 1;
            background-image: url('/images/editorial/login_side.png');
            background-size: cover;
            background-position: center;
        }

        .auth-form-side {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px;
        }

        .login-wrapper {
            width: 100%;
            max-width: 400px;
        }

        .header {
            margin-bottom: 50px;
            text-align: left;
        }

        .header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            font-weight: 400;
            letter-spacing: -1px;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 0.75rem;
            color: var(--text-gray);
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .form-group {
            margin-bottom: 35px;
            position: relative;
        }

        .form-group label {
            display: block;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 8px;
            color: var(--primary-black);
            font-weight: 600;
        }

        .form-group input {
            width: 100%;
            padding: 12px 0;
            border: none;
            border-bottom: 1px solid var(--primary-black);
            font-size: 0.9rem;
            outline: none;
            background: transparent;
            border-radius: 0;
            transition: border-bottom 0.3s;
        }

        .form-group input:focus {
            border-bottom: 2px solid var(--primary-black);
        }

        .password-input-container {
            position: relative;
            display: flex;
            align-items: center;
        }

        .toggle-btn {
            position: absolute;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-gray);
            font-weight: 600;
            padding: 5px 0;
        }

        .forgot-pass {
            display: block;
            text-align: right;
            font-size: 0.65rem;
            color: var(--text-gray);
            text-decoration: underline;
            margin-top: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-login {
            width: 100%;
            background: var(--primary-black);
            color: white;
            padding: 18px;
            border: none;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 3px;
            cursor: pointer;
            margin-top: 30px;
            transition: opacity 0.3s;
        }

        .btn-login:hover {
            opacity: 0.8;
        }

        .divider {
            position: relative;
            text-align: center;
            margin: 40px 0;
        }

        .divider:before {
            content: "";
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            border-bottom: 0.5px solid var(--border-gray);
            z-index: 1;
        }

        .divider span {
            background: white;
            padding: 0 15px;
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #999;
            position: relative;
            z-index: 2;
        }

        .google-btn {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: white;
            border: 1px solid var(--primary-black);
            padding: 15px;
            cursor: pointer;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-decoration: none;
            color: var(--primary-black);
        }

        .footer-links {
            text-align: center;
            margin-top: 50px;
            font-size: 0.7rem;
            color: var(--text-gray);
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        .footer-links a {
            color: var(--primary-black);
            text-decoration: underline;
            font-weight: 600;
        }

        @media (max-width: 900px) {
            .auth-image-side { display: none; }
            .auth-form-side { padding: 40px 20px; }
        }
    </style>
</head>
<body>

    <div class="auth-container">
        <div class="auth-image-side"></div>
        <div class="auth-form-side">
            <div class="login-wrapper">
                <div class="header">
                    <div style="font-family: 'Playfair Display'; font-size: 1.2rem; letter-spacing: 4px; margin-bottom: 40px; cursor: pointer;" onclick="location.href='/'">SNOVA</div>
                    <h1>LOG IN</h1>
                    <p>Access your personal account</p>
                </div>

                <form action="/login" method="post" id="loginform">
                    <div class="form-group">
                        <label for="email">E-mail</label>
                        <input type="email" id="email" name="email" placeholder="ENTER YOUR E-MAIL">
                    </div>

                    <div class="form-group">
                        <label for="pass">Password</label>
                        <div class="password-input-container">
                            <input type="password" id="pass" name="password" placeholder="ENTER YOUR PASSWORD">
                            <button type="button" class="toggle-btn" id="togglePass">Show</button>
                        </div>
                        <a href="/forgotPassword" class="forgot-pass">Forgot your password?</a>
                    </div>

                    <button type="submit" class="btn-login">Log In</button>
                </form>

                <div class="divider">
                    <span>OR</span>
                </div>

                <a href="/google" class="google-btn">
                    <img src="https://www.svgrepo.com/show/475656/google-color.svg" width="16" alt="Google">
                    Continue with Google
                </a>

                <div class="footer-links">
                    NEED AN ACCOUNT? <a href="signup">REGISTER</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
        function showToast(msg, type = 'success') {
            Toastify({
                text: (msg || "").toUpperCase(),
                duration: 3000,
                gravity: "top",
                position: "center",
                style: { 
                    background: type === 'error' ? "#ff0000" : "#000", 
                    borderRadius: "0px",
                    fontSize: "0.7rem",
                    letterSpacing: "1.5px",
                    fontWeight: "500",
                    fontFamily: "'Inter', sans-serif",
                    padding: "15px 40px"
                }
            }).showToast();
        }

        const passInput = document.getElementById("pass");
        const toggleBtn = document.getElementById("togglePass");

        toggleBtn.addEventListener("click", () => {
            if (passInput.type === "password") {
                passInput.type = "text";
                toggleBtn.textContent = "Hide";
            } else {
                passInput.type = "password";
                toggleBtn.textContent = "Show";
            }
        });

        document.getElementById("loginform").addEventListener("submit", async function (e) {
            e.preventDefault();
            const email = document.getElementById("email").value;
            const password = document.getElementById("pass").value;

            if(!email || !password) {
                showToast("Please fill all fields", "error");
                return;
            }

            try {
                const response = await fetch("/login", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ email, password })
                });

                const data = await response.json();
                if (data.success) {
                    showToast(data.message, 'success');
                    setTimeout(() => window.location.href = "/", 1000);
                } else {
                    showToast(data.message, 'error');
                }
            } catch (err) {
                showToast("Something went wrong", "error");
            }
        });
    </script>
</body>
</html>