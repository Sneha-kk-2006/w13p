<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Security Update</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--primary-black);
            -webkit-font-smoothing: antialiased;
        }

        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }

        .main-content {
            flex: 1;
            padding: 60px 5%;
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            text-transform: uppercase;
            letter-spacing: -1px;
            margin-bottom: 50px;
        }

        .security-section {
            max-width: 500px;
        }

        .form-group {
            margin-bottom: 40px;
            position: relative;
        }

        .form-group label {
            display: block;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            margin-bottom: 15px;
            color: #999;
        }

        .input-box {
            position: relative;
            display: flex;
            align-items: center;
        }

        .form-group input {
            width: 100%;
            border: none;
            border-bottom: 1.5px solid #000;
            padding: 12px 0;
            font-size: 0.9rem;
            outline: none;
            background: transparent;
            
        }

        .toggle-btn {
            position: absolute;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 700;
            cursor: pointer;
            color: #999;
        }

        .error-msg {
            font-size: 0.55rem;
            color: #d32f2f;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 8px;
            display: block;
        }

        .btn-black-minimal {
            width: 100%;
            background: #000;
            color: #fff;
            padding: 20px;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            margin-top: 20px;
            transition: 0.3s;
        }

        .btn-black-minimal:hover { opacity: 0.8; }

        @media (max-width: 768px) {
            .dashboard-container { flex-direction: column; }
        }
    </style>
</head>
<body>

    <%- include('../partials/user/header') %>

    <div class="dashboard-container">
        <% var activePage = 'profile'; %>
        <%- include('../partials/user/sidebar', { activePage: 'profile' }) %>

        <main class="main-content">
            <h1 class="page-title">UPDATE SECURITY</h1>

            <div class="security-section">
                <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; color: #999; margin-bottom: 40px;">Please enter your current and new password below.</p>

                <form id="passwordForm" action="/changePassword" method="POST">
                    
                    <div class="form-group">
                        <label>Current Password</label>
                        <div class="input-box">
                            <input type="password" name="currentPassword" id="currentPassword">
                            <button type="button" class="toggle-btn" onclick="togglePassword('currentPassword', this)">Show</button>
                        </div>
                        <span class="error-msg" id="currentError"></span>
                    </div>

                    <div class="form-group">
                        <label>New Password</label>
                        <div class="input-box">
                            <input type="password" name="newPassword" id="newPassword">
                            <button type="button" class="toggle-btn" onclick="togglePassword('newPassword', this)">Show</button>
                        </div>
                        <span class="error-msg" id="newError"></span>
                    </div>

                    <div class="form-group">
                        <label>Confirm New Password</label>
                        <div class="input-box">
                            <input type="password" name="confirmPassword" id="confirmPassword">
                            <button type="button" class="toggle-btn" onclick="togglePassword('confirmPassword', this)">Show</button>
                        </div>
                        <span class="error-msg" id="confirmError"></span>
                    </div>

                    <button type="submit" class="btn-black-minimal">Update Credentials</button>
                </form>

                <a href="/profile" style="display:inline-block; margin-top:30px; font-size:0.6rem; text-transform:uppercase; letter-spacing:2px; text-decoration:underline;">Back to profile</a>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
        function togglePassword(id, btn) {
            const input = document.getElementById(id);
            if (input.type === "password") {
                input.type = "text";
                btn.textContent = "Hide";
            } else {
                input.type = "password";
                btn.textContent = "Show";
            }
        }

        const strongPassword = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*]).{8,}$/;
        
        document.getElementById("passwordForm").addEventListener("submit", async function (e) {
            e.preventDefault();
            let valid = true;

            const current = document.getElementById("currentPassword").value;
            const newPass = document.getElementById("newPassword").value;
            const confirm = document.getElementById("confirmPassword").value;

            document.querySelectorAll(".error-msg").forEach(el => el.innerText = "");

            if (current.length < 6) {
                document.getElementById("currentError").innerText = "ENTER VALID CURRENT PASSWORD";
                valid = false;
            }

            if (!strongPassword.test(newPass)) {
                document.getElementById("newError").innerText = "MIN 8 CHARS, 1 UPPER, 1 LOWER, 1 NUMBER, 1 SYMBOL";
                valid = false;
            } else if (newPass === current) {
                document.getElementById("newError").innerText = "NEW PASSWORD MUST BE DIFFERENT FROM CURRENT PASSWORD";
                valid = false;
            }

            if (newPass !== confirm) {
                document.getElementById("confirmError").innerText = "PASSWORDS DO NOT MATCH";
                valid = false;
            }

            if (!valid) return;

            try {
                const res = await fetch("/changePassword", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ currentPassword: current, newPassword: newPass, confirmPassword: confirm })
                });

                const data = await res.json();
                if (data.success) {
                    Toastify({ text: "PASSWORD UPDATED SUCCESSFULLY", duration: 3000, gravity: "top", position: "right", backgroundColor: "#000" }).showToast();
                    setTimeout(() => window.location.href = "/login", 2000);
                } else {
                    const msg = data.message || "Something went wrong";
                    // Map server errors to the correct inline field
                    if (msg.toLowerCase().includes("current password")) {
                        document.getElementById("currentError").innerText = msg.toUpperCase();
                    } else if (msg.toLowerCase().includes("different") || msg.toLowerCase().includes("same")) {
                        document.getElementById("newError").innerText = msg.toUpperCase();
                    } else if (msg.toLowerCase().includes("match")) {
                        document.getElementById("confirmError").innerText = msg.toUpperCase();
                    } else {
                        // Fallback: show as toast
                        Toastify({ text: msg.toUpperCase(), duration: 4000, gravity: "top", position: "right", backgroundColor: "#d32f2f" }).showToast();
                    }
                }
            } catch (err) { console.error(err); }
        });
    </script>
</body>
</html>