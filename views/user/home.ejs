<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SNOVA | Official Store</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --primary-black: #000000;
      --off-white: #ffffff;
      --text-gray: #666;
      --accent-gray: #f2f2f2;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--off-white);
      color: var(--primary-black);
      font-family: 'Inter', sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* Minimalist Zara-style Hero */
    .zara-hero {
      position: relative;
      height: 100vh;
      width: 100%;
      overflow: hidden;
    }

    .hero-slide {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-size: cover;
      background-position: center;
      transition: opacity 0.8s ease;
    }

    .hero-overlay {
      position: absolute;
      bottom: 10%;
      left: 5%;
      z-index: 10;
    }

    .hero-overlay h1 {
      font-family: 'Playfair Display', serif;
      font-size: 4rem;
      font-weight: 400;
      line-height: 0.9;
      margin-bottom: 20px;
      letter-spacing: -2px;
    }

    .hero-cta {
      display: inline-block;
      padding: 10px 0;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--primary-black);
      text-decoration: none;
      border-bottom: 1px solid var(--primary-black);
      transition: 0.3s;
    }

    .hero-cta:hover {
      padding-right: 20px;
    }

    /* Editorial Grid */
    .editorial-container {
      padding: 40px 2%;
    }

    .editorial-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }

    .editorial-item {
      position: relative;
      overflow: hidden;
      aspect-ratio: 2/3;
    }

    .editorial-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .editorial-item:hover img {
      transform: scale(1.05);
    }

    .item-label {
      position: absolute;
      bottom: 20px;
      left: 20px;
      color: white;
    }

    .item-label h3 {
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 1.5px;
      font-weight: 500;
      text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }

    /* Section Headers */
    .section-title {
      padding: 80px 5% 40px;
      text-align: center;
    }

    .section-title h2 {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 400;
      margin-bottom: 10px;
    }

    .section-title p {
      font-size: 0.8rem;
      color: var(--text-gray);
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    /* Minimal Product Card */
    .z-product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      padding: 0 2% 80px;
      gap: 10px;
    }

    .z-card {
      text-decoration: none;
      color: inherit;
    }

    .z-img-box {
      aspect-ratio: 3/4;
      background: #f8f8f8;
      overflow: hidden;
      margin-bottom: 12px;
    }

    .z-img-box img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .z-info {
      font-size: 0.75rem;
      line-height: 1.5;
    }

    .z-name {
      font-weight: 400;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .z-price {
      font-weight: 600;
    }

    /* Footer adjustments */
    .newsletter-section {
      background: var(--accent-gray);
      padding: 100px 5%;
      text-align: center;
    }

    .newsletter-section h4 {
      text-transform: uppercase;
      font-size: 0.7rem;
      letter-spacing: 3px;
      margin-bottom: 30px;
    }

    .newsletter-form {
      display: flex;
      max-width: 500px;
      margin: 0 auto;
      border-bottom: 1px solid var(--primary-black);
    }

    .newsletter-form input {
      flex: 1;
      border: none;
      background: transparent;
      padding: 15px 0;
      outline: none;
      font-size: 0.8rem;
    }

    .newsletter-form button {
      background: transparent;
      border: none;
      text-transform: uppercase;
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 2px;
      cursor: pointer;
    }

    @media (max-width: 1024px) {
      .hero-overlay h1 { font-size: 3rem; }
      .z-product-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      .editorial-grid { grid-template-columns: 1fr; }
      .hero-overlay h1 { font-size: 2.5rem; }
    }
  </style>
</head>
<body>

  <%- include('../partials/user/header') %>

  <!-- Full Screen Hero Slide -->
  <main class="zara-hero">
    <div class="hero-slide" style="background-image: url('/images/editorial/hero_editorial_1.png')"></div>
    <div class="hero-overlay">
      <h1>NEW<br>CATEGORIES</h1>
      <a href="/products" class="hero-cta">View Everything</a>
    </div>
  </main>

  <!-- Editorial Category Grid -->
  <section class="editorial-container">
    <div class="editorial-grid">
      <div class="editorial-item">
        <img src="https://images.unsplash.com/photo-1539109136881-3be0616acf4b?auto=format&fit=crop&w=800&q=80" alt="Woman Fashion">
        <div class="item-label">
          <a href="/category?category=WOMAN" style="color:white; text-decoration:none;"><h3>Woman</h3></a>
        </div>
      </div>
      <div class="editorial-item">
        <img src="/images/editorial/hero_editorial_2.png" alt="Man Fashion">
        <div class="item-label">
          <a href="/category?category=MAN" style="color:white; text-decoration:none;"><h3>Man</h3></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trending Products Section -->
  <section class="section-title">
    <p>Handpicked for you</p>
    <h2>TRENDING NOW</h2>
  </section>

  <section class="z-product-grid">
    <!-- Simplified Zara-style card -->
    <a href="/products" class="z-card">
      <div class="z-img-box">
        <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=500&q=80" alt="">
      </div>
      <div class="z-info">
        <div class="z-name">Oversized Poplin Shirt</div>
        <div class="z-price">₹2,990.00</div>
      </div>
    </a>

    <a href="/products" class="z-card">
      <div class="z-img-box">
        <img src="https://images.unsplash.com/photo-1543076447-215ad9ba6923?auto=format&fit=crop&w=500&q=80" alt="">
      </div>
      <div class="z-info">
        <div class="z-name">Ribbed Knit Top</div>
        <div class="z-price">₹1,590.00</div>
      </div>
    </a>

    <a href="/products" class="z-card">
      <div class="z-img-box">
        <img src="https://images.unsplash.com/photo-1509631179647-0177331693ae?auto=format&fit=crop&w=500&q=80" alt="">
      </div>
      <div class="z-info">
        <div class="z-name">Linen Blend Trousers</div>
        <div class="z-price">₹4,990.00</div>
      </div>
    </a>

    <a href="/products" class="z-card">
      <div class="z-img-box">
        <img src="https://images.unsplash.com/photo-1496747611176-843222e1e57c?auto=format&fit=crop&w=500&q=80" alt="">
      </div>
      <div class="z-info">
        <div class="z-name">Floral Midi Dress</div>
        <div class="z-price">₹3,290.00</div>
      </div>
    </a>
  </section>

  <!-- Newsletter Section -->
  <section class="newsletter-section">
    <h4>JOIN OUR NEWSLETTER</h4>
    <form class="newsletter-form">
      <input type="email" placeholder="ENTER YOUR EMAIL ADDRESS">
      <button type="submit">Subscribe</button>
    </form>
  </section>

  <%- include('../partials/user/footer') %>

</body>
</html>