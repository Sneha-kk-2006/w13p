          <div class="ti__lbl"><span>Category</span><a href="/products">Dresses</a></div>
        </div>
        <div class="ti"><img
            src="<%= getProductImg(13, 'https://images.unsplash.com/photo-1583846717393-dc2412c95ed7?auto=format&fit=crop&w=700&q=80') %>"
            alt="Knitwear" loading="lazy">
          <div class="ti__lbl"><span>Category</span><a href="/products">Knitwear</a></div>
        </div>
        <div class="ti"><img
            src="<%= getProductImg(14, 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=700&q=80') %>"
            alt="Outerwear" loading="lazy">
          <div class="ti__lbl"><span>Category</span><a href="/products">Outerwear</a></div>
        </div>
      </div>

      <!-- MORE PRODUCTS -->
      <div class="sh rv"><span class="sh__t">Trending Now</span><a href="/products" class="sh__a">View All</a></div>
      <div class="pgrid rv">
        <% if (typeof products !=='undefined' && products.length> 4) { %>
          <% products.slice(4, 8).forEach(product=> { %>
            <a href="/product/<%= product._id %>" class="pc">
              <div class="pc__box">
                <% 
                  let primaryImg = '';
                  let secondaryImg = '';
                  if (product.images && product.images[0]) {
                    primaryImg = product.images[0];
                    secondaryImg = product.images[1] || product.images[0];
                  }
                  
                  /* If secondary is still empty or same as primary, try variants */
                  if ((!secondaryImg || secondaryImg === primaryImg) && product.variants && product.variants.length > 0) {
                    const variantWithImg = product.variants.find(v => v.images && v.images[0] && v.images[0] !== primaryImg);
                    if (variantWithImg) {
                      secondaryImg = variantWithImg.images[0];
                    } else if (!primaryImg && product.variants[0].images && product.variants[0].images[0]) {
                      primaryImg = product.variants[0].images[0];
                      secondaryImg = (product.variants[0].images[1]) || (product.variants[1] && product.variants[1].images && product.variants[1].images[0]) || primaryImg;
                    }
                  }

                  const getFmt = (img) => img ? (img.startsWith('/') ? img : '/uploads/products/' + img) : '';
                  let finalPrimary = getFmt(primaryImg);
                  let finalSecondary = getFmt(secondaryImg);
                %>
                  <img src="<%= finalPrimary %>" alt="<%= product.name %>" class="pc__img--primary" loading="lazy">
                  <img src="<%= finalSecondary %>" alt="<%= product.name %>" class="pc__img--secondary" loading="lazy">
                  <span class="pc__badge">Trending</span>
              </div>

              <div class="pc__n">
                <%= product.name %>
              </div>
              <div class="pc__p">₹<%= product.price %>
              </div>
            </a>
            <% }) %>
              <% } else { %>
                <p style="grid-column: 1/-1; text-align:center; color:#999; font-size:0.8rem; padding: 20px;">More items
                  coming soon</p>
                <% } %>
      </div>

      <!-- LOOKBOOK -->
      <div class="sh rv"><span class="sh__t">The Lookbook</span><a href="/products" class="sh__a">View Looks</a></div>
      <div class="lb rv">
        <div class="lb__grid">
          <div class="li tall"><img
              src="<%= getProductImg(15, 'https://images.unsplash.com/photo-1487222477894-8943e31ef7b2?auto=format&fit=crop&w=900&q=80') %>"
              alt="" loading="lazy"></div>
          <div class="li"><img
              src="<%= getProductImg(16, 'https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=600&q=80') %>"
              alt="" loading="lazy"></div>
          <div class="li"><img
              src="<%= getProductImg(17, 'https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&w=600&q=80') %>"
              alt="" loading="lazy"></div>
          <div class="li"><img
              src="<%= getProductImg(18, 'https://images.unsplash.com/photo-1558618047-3c8c76ca7d13?auto=format&fit=crop&w=600&q=80') %>"
              alt="" loading="lazy"></div>
          <div class="li"><img
              src="<%= getProductImg(19, 'https://images.unsplash.com/photo-1434389677669-e08b4cac3105?auto=format&fit=crop&w=600&q=80') %>"
              alt="" loading="lazy"></div>
        </div>
      </div>

      <!-- BANNER ROW -->
      <div class="brow rv">
        <div class="bi"><img
            src="<%= getProductImg(11, 'https://images.unsplash.com/photo-1554568218-0f1715e72254?auto=format&fit=crop&w=800&q=80') %>"
            alt="" loading="lazy">
          <div class="bi__info">
            <p>The Edit</p><a href="/products">Evening Essentials</a>
          </div>
        </div>
        <div class="bi"><img
            src="<%= getProductImg(12, 'https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&w=800&q=80') %>"
            alt="" loading="lazy">
          <div class="bi__info">
            <p>The Edit</p><a href="/products">Weekend Casual</a>
