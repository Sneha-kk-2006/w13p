<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Shopping Cart</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap');

        body {
            background-color: #fdf2f2;
            color: #d4c7c7;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .cart-card {
            background-color: #f5f7fc;
            border: 1px solid #141414;
            transition: all 0.3s ease;
        }

        .summary-card {
            background-color: #64666c;
            border: 1px solid #2d3748;
        }

        .checkout-btn {
            background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
            color: #0e0e0e;
            transition: all 0.3s ease;
        }

        .checkout-btn:hover {
            background: #ffffff;
            transform: translateY(-2px);
        }

        .quantity-control {
            background-color: white;
            border: 1px solid #2d3748;
        }

        /* ── MODAL ── */
        #confirm-modal {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 9998;
            align-items: center;
            justify-content: center;
        }

        #confirm-modal.show {
            display: flex;
        }

        .modal-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.65);
            backdrop-filter: blur(4px);
        }

        .modal-box {
            position: relative;
            background: #1c1c2e;
            border: 1px solid #2d3748;
            border-radius: 1.25rem;
            padding: 2rem;
            width: 90%;
            max-width: 380px;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5);
            animation: popIn 0.2s ease;
        }

        @keyframes popIn {
            from {
                transform: scale(0.9);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        /* ── TOAST ── */
        #toast-container {
            position: fixed;
            top: 1.25rem;
            right: 1.25rem;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .toast {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            padding: 0.75rem 1.1rem;
            border-radius: 0.85rem;
            font-size: 0.82rem;
            font-weight: 600;
            color: #fff;
            min-width: 220px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
            animation: slideIn 0.3s ease;
        }

        .toast.success { background: #16a34a; }
        .toast.error   { background: #dc2626; }
        .toast.info    { background: #2563eb; }

        .toast.fade-out {
            animation: slideOut 0.35s ease forwards;
        }

        @keyframes slideIn {
            from { transform: translateX(110%); opacity: 0; }
            to   { transform: translateX(0);    opacity: 1; }
        }

        @keyframes slideOut {
            from { transform: translateX(0);    opacity: 1; }
            to   { transform: translateX(110%); opacity: 0; }
        }
    </style>
</head>

<body>

    <%- include('../partials/user/header') %>

    <!-- ── TOAST CONTAINER ── -->
    <div id="toast-container"></div>

    <!-- ── CONFIRMATION MODAL ── -->
    <div id="confirm-modal">
        <div class="modal-overlay" onclick="closeModal()"></div>
        <div class="modal-box">
            <div class="flex justify-center mb-4">
                <div style="background:#3f1010; border-radius:9999px; width:56px; height:56px; display:flex; align-items:center; justify-content:center;">
                    <i class="fa-solid fa-trash-can text-red-500 text-xl"></i>
                </div>
            </div>
            <h3 id="modal-title" class="text-center text-white font-black text-lg mb-1">Remove Item?</h3>
            <p id="modal-desc" class="text-center text-gray-400 text-sm mb-6">This item will be removed from your cart.</p>
            <div class="flex gap-3">
                <button onclick="closeModal()"
                    style="flex:1; padding:0.75rem; border-radius:0.75rem; border:1px solid #374151; color:#9ca3af; font-weight:700; font-size:0.8rem; background:transparent; cursor:pointer;">
                    Cancel
                </button>
                <button id="modal-confirm-btn"
                    style="flex:1; padding:0.75rem; border-radius:0.75rem; background:#dc2626; color:white; font-weight:700; font-size:0.8rem; border:none; cursor:pointer;">
                    Yes, Remove
                </button>
            </div>
        </div>
    </div>

    <!-- ── PAGE CONTENT ── -->
    <div class="p-4 md:p-10">

        <!-- Page Title Section (NOT a site header — the EJS partial above handles that) -->
        <div class="mb-10 flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-black">Shopping Cart</h1>
                <p class="text-gray-400 text-sm mt-1">
                    <%= items.length %> item<%= items.length !== 1 ? 's' : '' %> in your cart
                </p>
            </div>

            <% if (items.length > 0) { %>
                <button onclick="confirmClearCart()"
                    class="flex items-center gap-2 text-sm font-bold text-red-400 hover:text-red-500 border border-red-400 hover:border-red-500 px-5 py-2 rounded-full transition-all">
                    <i class="fa-solid fa-trash-can"></i>
                    Clear Cart
                </button>
            <% } %>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

            <!-- ── CART ITEMS ── -->
            <div class="lg:col-span-2 space-y-6">
                <div class="hidden md:grid grid-cols-5 text-[10px] font-bold uppercase tracking-[0.2em] text-gray-500 border-b border-gray-800 pb-4 px-6">
                    <div class="col-span-2">Product</div>
                    <div class="text-center">Quantity</div>
                    <div class="text-right">Price</div>
                    <div class="text-right">Action</div>
                </div>

                <% if (items.length > 0) { %>
                    <% items.forEach(item => { %>
                        <div id="cart-item-<%= item._id %>"
                            class="cart-card rounded-2xl p-6 flex flex-col md:grid md:grid-cols-5 items-center gap-6">

                            <!-- Product Info -->
                            <div class="col-span-2 flex items-center w-full">
                                <div class="w-24 h-24 rounded-xl overflow-hidden bg-gray-900 border border-gray-800 shrink-0">
                                    <img src="<%= item.productImage %>" alt="<%= item.productName %>" class="w-full h-full object-cover">
                                </div>
                                <div class="ml-6">
                                    <h3 class="font-bold text-lg leading-tight"><%= item.productName %></h3>
                                    <div class="text-[11px] text-gray-500 mt-2 space-y-1">
                                        <p>COLOR: <span class="text-gray-300 uppercase"><%= item.color %></span></p>
                                        <p>SIZE:  <span class="text-gray-300"><%= item.size %></span></p>
                                        <p>PRICE: <span class="text-gray-300">₹<%= item.unitPrice %></span></p>
                                    </div>
                                </div>
                            </div>

                            <!-- Quantity -->
                            <div class="flex justify-center w-full">
                                <div class="quantity-control flex items-center rounded-xl p-1">
                                    <button class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-white transition-colors"
                                        onclick="updateQty('<%= item._id %>', -1)">
                                        <i class="fa-solid fa-minus text-[10px]"></i>
                                    </button>
                                    <span class="w-10 text-center font-bold text-sm"><%= item.quantity %></span>
                                    <button class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-white transition-colors"
                                        onclick="updateQty('<%= item._id %>', 1)">
                                        <i class="fa-solid fa-plus text-[10px]"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Price -->
                            <div class="text-right w-full">
                                <p class="text-xs line-through mb-1">₹<%= item.oldPrice %></p>
                                <p class="text-xl font-black tracking-tighter text-white">₹<%= item.totalPrice %></p>
                            </div>

                            <!-- Remove -->
                            <div class="text-right w-full">
                                <button class="text-gray-500 hover:text-red-500 transition-colors p-2"
                                    data-item-id="<%= item._id %>"
                                    data-product-name="<%= item.productName %>"
                                    onclick="handleRemoveClick(this)">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-center py-20 bg-gray-900/30 rounded-3xl border border-dashed border-gray-800">
                        <i class="fa-solid fa-cart-shopping text-4xl text-gray-700 mb-4"></i>
                        <p class="text-gray-500">Your cart is empty.</p>
                    </div>
                <% } %>

                <div class="pt-6">
                    <a href="/products"
                        class="inline-flex items-center space-x-3 text-sm font-bold text-gray-400 hover:text-white transition-all border border-gray-800 px-8 py-3 rounded-full hover:bg-gray-800">
                        <i class="fa-solid fa-arrow-left-long"></i>
                        <span>Continue Shopping</span>
                    </a>
                </div>
            </div>

            <!-- ── ORDER SUMMARY ── -->
            <div class="lg:col-span-1">
                <div class="summary-card rounded-3xl p-8 sticky top-10">
                    <h2 class="text-xl font-bold mb-8" style="color: white;">Order Summary</h2>
                    <div class="space-y-4 mb-8">
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Subtotal</span>
                            <span class="font-bold text-gray-300">₹<%= subtotal %></span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Discount</span>
                            <span class="font-bold text-green-500">-₹<%= discount %></span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Shipping Estimate</span>
                            <span class="font-bold text-green-500">FREE</span>
                        </div>
                        <div class="border-t border-gray-700 pt-4 mt-4 flex justify-between items-end">
                            <span class="text-lg font-bold" style="color: white;">Total</span>
                            <span class="text-3xl font-black tracking-tighter" style="color: white;">₹<%= subtotal %></span>
                        </div>
                    </div>
                    <button onclick="window.location.href='/checkout'"
                        class="checkout-btn w-full py-5 rounded-2xl font-black uppercase tracking-widest text-xs flex items-center justify-center group">
                        Proceed to Checkout
                        <i class="fa-solid fa-arrow-right ml-3 transform group-hover:translate-x-1 transition-transform"></i>
                    </button>
                    <div class="mt-6 flex items-center justify-center space-x-2 text-[10px] text-gray-400 font-bold uppercase tracking-widest">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Secure SSL Checkout</span>
                    </div>
                </div>
            </div>

        </div>
    </div><!-- /page content -->

    <script>
        // ── TOAST ──────────────────────────────────────────
        function showToast(message, type = 'success') {
            const icons = { success: 'fa-circle-check', error: 'fa-circle-xmark', info: 'fa-circle-info' };
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `<i class="fa-solid ${icons[type]}"></i> ${message}`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('fade-out');
                toast.addEventListener('animationend', () => toast.remove());
            }, 3000);
        }

        // ── MODAL ──────────────────────────────────────────
        let _pendingAction = null;

        function openModal(title, desc, onConfirm) {
            document.getElementById('modal-title').textContent = title;
            document.getElementById('modal-desc').textContent = desc;
            document.getElementById('confirm-modal').classList.add('show');
            _pendingAction = onConfirm;
            const btn = document.getElementById('modal-confirm-btn');
            btn.onclick = () => { const fn = _pendingAction; closeModal(); if (fn) fn(); };
        }

        function closeModal() {
            document.getElementById('confirm-modal').classList.remove('show');
        }

        // ── REMOVE SINGLE ITEM ─────────────────────────────
        function handleRemoveClick(btn) {
            const itemId = btn.getAttribute('data-item-id');
            const productName = btn.getAttribute('data-product-name');
            openModal('Remove Item?', `"${productName}" will be removed from your cart.`, () => removeItem(itemId));
        }

        async function removeItem(itemId) {
            const itemElement = document.getElementById(`cart-item-${itemId}`);
            try {
                if (itemElement) { itemElement.style.opacity = '0.5'; itemElement.style.pointerEvents = 'none'; }
                const res  = await fetch('/cart/remove', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ itemId }) });
                const data = await res.json();
                if (data.success) {
                    if (itemElement) itemElement.remove();
                    showToast('Item removed', 'success');
                    data.isEmpty ? location.reload() : setTimeout(() => location.reload(), 800);
                } else {
                    if (itemElement) { itemElement.style.opacity = '1'; itemElement.style.pointerEvents = 'auto'; }
                    showToast(data.msg || 'Error removing item', 'error');
                }
            } catch (err) {
                if (itemElement) { itemElement.style.opacity = '1'; itemElement.style.pointerEvents = 'auto'; }
                showToast('Something went wrong', 'error');
            }
        }

        // ── CLEAR ENTIRE CART ──────────────────────────────
        function confirmClearCart() {
            openModal('Clear Cart?', 'All items will be removed from your cart.', () => clearCart());
        }

        async function clearCart() {
            try {
                const res  = await fetch('/cart/clearCart', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                const data = await res.json();
                if (data.success) {
                    document.querySelectorAll('.cart-card').forEach(el => el.remove());
                    showToast('Cart cleared!', 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(data.msg || 'Failed to clear cart', 'error');
                }
            } catch (err) {
                showToast('Something went wrong', 'error');
            }
        }

        // ── UPDATE QUANTITY ────────────────────────────────
        async function updateQty(itemId, change) {
            try {
                const res  = await fetch('/cart/updateQty', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ itemId, change }) });
                const data = await res.json();
                if (data.success) { location.reload(); }
                else { showToast(data.msg || 'Error updating quantity', 'error'); }
            } catch {
                showToast('Something went wrong', 'error');
            }
        }
    </script>
</body>

</html>
