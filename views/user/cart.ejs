<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Shopping Cart</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap');
        
        body { 
            background-color: #fdf2f2; 
            color: #d4c7c7; 
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        
        .cart-card { 
            background-color: #f5f7fc; 
            border: 1px solid #141414; 
            transition: all 0.3s ease;
        }
        
        .summary-card {
            background-color: #64666c;
            border: 1px solid #2d3748;
        }

        .checkout-btn {
            background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
            color: #0e0e0e;
            transition: all 0.3s ease;
        }
        .checkout-btn:hover {
            background: #ffffff;
            transform: translateY(-2px);
        }

        .quantity-control {
            background-color:white;
            border: 1px solid #2d3748;
        }
    </style>
</head>
<body class="p-4 md:p-10">

    <header class="mb-10">
        <div class="flex items-center space-x-3 mb-2">
            <div class="text-2xl font-black text-black">SNOVA<span class="text-green-500">.</span></div>
        </div>
        <h1 class="text-3xl font-bold tracking-tight">Shopping Cart</h1>
        <p class="text-gray-400 text-sm mt-1"><%= items.length %> items in your cart</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        
        <div class="lg:col-span-2 space-y-6">
            <div class="hidden md:grid grid-cols-5 text-[10px] font-bold uppercase tracking-[0.2em] text-gray-500 border-b border-gray-800 pb-4 px-6">
                <div class="col-span-2">Product</div>
                <div class="text-center">Quantity</div>
                <div class="text-right">Price</div>
                <div class="text-right">Action</div>
            </div>

            <% if(items.length > 0) { %>
                <% items.forEach(item => { %>
                    <div class="cart-card rounded-2xl p-6 flex flex-col md:grid md:grid-cols-5 items-center gap-6">
                        
                        <div class="col-span-2 flex items-center w-full">
                            <div class="w-24 h-24 rounded-xl overflow-hidden bg-gray-900 border border-gray-800 shrink-0">
                                <img src="<%= item.productImage %>" alt="<%= item.productName %>" class="w-full h-full object-cover">
                            </div>
                            <div class="ml-6">
                                <h3 class="font-bold text-lg leading-tight"><%= item.productName %></h3>
                                <div class="text-[11px] text-gray-500 mt-2 space-y-1">
                                    <p>COLOR: <span class="text-gray-300 uppercase"><%= item.color %></span></p>
                                    <p>SIZE: <span class="text-gray-300"><%= item.size %></span></p>
                                    <p>PRICE: <span class="text-gray-300">₹<%= item.unitPrice %></span></p>
                                </div>
                            </div>
                        </div>

                        <div class="flex justify-center w-full">
                            <div class="quantity-control flex items-center rounded-xl p-1">
                                <button class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-white transition-colors" onclick="updateQty('<%= item.id %>', -1)">
                                    <i class="fa-solid fa-minus text-[10px]"></i>
                                </button>
                                <span class="w-10 text-center font-bold text-sm"><%= item.quantity %></span>
                                <button class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-white transition-colors" onclick="updateQty('<%= item.id %>', 1)">
                                    <i class="fa-solid fa-plus text-[10px]"></i>
                                </button>
                            </div>
                        </div>

                        <div class="text-right w-full">
                            <p class="text-xs text-black-500 line-through mb-1">₹<%= item.oldPrice %></p>
                            <p class="text-xl font-black tracking-tighter text-white">₹<%= item.totalPrice %></p>
                        </div>

                        <div class="text-right w-full">
                            <button class="text-gray-500 hover:text-red-500 transition-colors p-2">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center py-20 bg-gray-900/30 rounded-3xl border border-dashed border-gray-800">
                    <i class="fa-solid fa-cart-shopping text-4xl text-gray-700 mb-4"></i>
                    <p class="text-gray-500">Your cart is empty.</p>
                </div>
            <% } %>

            <div class="pt-6">
                <a href="/products" class="inline-flex items-center space-x-3 text-sm font-bold text-gray-400 hover:text-white transition-all border border-gray-800 px-8 py-3 rounded-full hover:bg-gray-800">
                    <i class="fa-solid fa-arrow-left-long"></i>
                    <span>Continue Shopping</span>
                </a>
            </div>
        </div>

        <div class="lg:col-span-1">
            <div class="summary-card rounded-3xl p-8 sticky top-10">
                <h2 class="text-xl font-bold mb-8" style="color: white;">Order Summary</h2>
                
                <div class="space-y-4 mb-8">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">Subtotal</span>
                        <span class="font-bold text-gray-300">₹<%= subtotal %></span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">Discount</span>
                        <span class="font-bold text-green-500">-₹<%= discount %></span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">Shipping Estimate</span>
                        <span class="font-bold text-green-500">FREE</span>
                    </div>
                    <div class="border-t border-gray-800 pt-4 mt-4 flex justify-between items-end">
                        <span class="text-lg font-bold" style="color: white;">Total</span>
                        <span class="text-3xl font-black tracking-tighter" style="color: white;">₹<%= total %></span>
                    </div>
                </div>

                <button class="checkout-btn w-full py-5 rounded-2xl font-black uppercase tracking-widest text-xs flex items-center justify-center group">
                    Proceed to Checkout
                    <i class="fa-solid fa-arrow-right ml-3 transform group-hover:translate-x-1 transition-transform"></i>
                </button>

                <div class="mt-6 flex items-center justify-center space-x-2 text-[10px] text-gray-600 font-bold uppercase tracking-widest">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span>Secure SSL Checkout</span>
                </div>
            </div>
        </div>
    </div>

</body>
<script>
    async function addToCart(productId) {
  try {
    const res = await fetch('/cart/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productId })
    });
    const data = await res.json();
    if (data.success) {
      window.location.href = '/cart'; // ✅ redirect to cart page
    } else {
      alert(data.msg || 'Could not add to cart');
    }
  } catch (err) {
    alert('Something went wrong');
  }
}



async function updateQty(itemId, change) {
    try {
        const res = await fetch('/cart/update-qty', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ itemId, change })
        });

        const data = await res.json();

        if (data.success) {
            location.reload(); // 🔥 simplest & correct
        } else {
            alert(data.msg || 'Error updating quantity');
        }
    } catch (err) {
        alert('Something went wrong');
    }
}




async function removeItem(itemId) {
    const res = await fetch('/cart/remove', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ itemId })
    });

    const data = await res.json();

    if (data.success) location.reload();
}


</script>
</html>