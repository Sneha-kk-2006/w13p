<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Edit Address</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style>
        :root {
            --primary-green: #10b981;
            --dark-blue-bg: #1a2332;
            --sidebar-teal: #c9e2e2;
            --text-dark: #111111;
            --text-gray: #64748b;
            --input-bg: #bcc8cd;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', sans-serif; }
        body { background-color: #0f172a; min-height: 100vh; }

        /* Navbar */
        .navbar { background: #000; padding: 15px 5%; display: flex; justify-content: space-between; align-items: center; }
        .logo { color: var(--primary-green); font-size: 24px; font-weight: bold; text-decoration: none; }
        .nav-tools { display: flex; gap: 20px; align-items: center; color: white; }

        /* Container */
        .dashboard-container { display: flex; width: 95%; max-width: 1200px; margin: 30px auto; background: var(--dark-blue-bg); border-radius: 12px; overflow: hidden; }

        /* Sidebar */
        .sidebar { width: 260px; background: var(--sidebar-teal); padding: 30px 20px; display: flex; flex-direction: column; gap: 12px; }
        .side-link { display: flex; align-items: center; gap: 12px; padding: 12px 20px; background: white; border-radius: 10px; text-decoration: none; color: var(--text-dark); font-weight: 600; }
        .side-link.active { background: #9aa7ad; }

        /* Main Content */
        .main-content { flex: 1; padding: 40px; background: #f8fafc; display: flex; justify-content: center; }
        
        .form-card { background: white; width: 100%; max-width: 800px; border-radius: 20px; padding: 40px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }

        .header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 1px solid #f1f5f9; padding-bottom: 15px; }
        .header-row h2 { font-size: 22px; font-weight: 700; color: #1e293b; }
        .go-back { display: flex; align-items: center; gap: 5px; color: var(--primary-green); font-weight: 700; text-decoration: none; font-size: 14px; }

        /* Form Grid */
        .address-form { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .full-width { grid-column: span 2; }

        .field-group { display: flex; flex-direction: column; gap: 8px; }
        .field-group label { font-size: 12px; font-weight: 700; color: #334155; }
        .field-group label span { color: #ef4444; }

        .input-box { background: var(--input-bg); padding: 12px 15px; border-radius: 12px; display: flex; align-items: center; gap: 10px; }
        .input-box input, .input-box select { background: transparent; border: none; outline: none; width: 100%; font-size: 14px; font-weight: 600; color: #1e293b; }

        /* Checkbox Section */
        .checkbox-row { display: flex; align-items: center; gap: 10px; margin-top: 10px; font-weight: 600; font-size: 14px; color: #1e293b; }
        .checkbox-row input { accent-color: var(--primary-green); width: 18px; height: 18px; cursor: pointer; }

        /* Footer Buttons */
        .form-footer { margin-top: 35px; display: flex; gap: 15px; }
        .btn-save { flex: 2; background: #111; color: white; border: none; padding: 15px; border-radius: 12px; font-weight: bold; cursor: pointer; transition: 0.3s; }
        .btn-save:hover { background: #333; }
        .btn-cancel { flex: 1; background: #f1f5f9; color: #64748b; border: none; padding: 15px; border-radius: 12px; font-weight: bold; cursor: pointer; }

    </style>
</head>
<body>

    <header class="navbar">
        <a href="#" class="logo">SNOVA</a>
        <div class="nav-tools">
            <span class="material-symbols-outlined">favorite</span>
            <span class="material-symbols-outlined">shopping_cart</span>
            <span class="material-symbols-outlined" style="color:var(--primary-green)">account_circle</span>
        </div>
    </header>

    <div class="dashboard-container">
        <aside class="sidebar">
            <a href="#" class="side-link"><span class="material-symbols-outlined">person</span> Profile</a>
            <a href="#" class="side-link active"><span class="material-symbols-outlined">location_on</span> Address</a>
            <a href="#" class="side-link"><span class="material-symbols-outlined">package</span> My Orders</a>
            <a href="#" class="side-link"><span class="material-symbols-outlined">favorite</span> Wishlist</a>
            <a href="#" class="side-link"><span class="material-symbols-outlined">account_balance_wallet</span> Wallet</a>
        </aside>

        <main class="main-content">
            <div class="form-card">
                <div class="header-row">
                    <h2>Edit Address</h2>
                    <a href="addresses" class="go-back">
                        <span class="material-symbols-outlined">arrow_back</span> Go Back
                    </a>
                </div>

                <form class="address-form">
                    <div class="field-group">
                        <label>Type <span>*</span></label>
                        <div class="input-box">
                            <select>
                                <option value="home" selected>Home</option>
                                <option value="work">Work</option>
                                <option value="others">Others</option>
                            </select>
                        </div>
                    </div>

                    <div class="field-group">
                        <label>Full Name <span>*</span></label>
                        <div class="input-box">
                            <span class="material-symbols-outlined">person</span>
                            <input type="text" value="user" placeholder="Enter full name">
                        </div>
                    </div>

                    <div class="field-group full-width">
                        <label>Address Line 1 <span>*</span></label>
                        <div class="input-box">
                            <span class="material-symbols-outlined">location_on</span>
                            <input type="text" value="manimaghalam house, kondotty 673641" placeholder="Street name, Building No.">
                        </div>
                    </div>

                    <div class="field-group full-width">
                        <label>Address Line 2 (optional)</label>
                        <div class="input-box">
                            <span class="material-symbols-outlined">apartment</span>
                            <input type="text" value="kizhisseri, kondotty" placeholder="Landmark, Area, Floor">
                        </div>
                    </div>

                    <div class="field-group">
                        <label>City <span>*</span></label>
                        <div class="input-box">
                            <input type="text" value="Malappuram">
                        </div>
                    </div>

                    <div class="field-group">
                        <label>State <span>*</span></label>
                        <div class="input-box">
                            <input type="text" value="Kerala">
                        </div>
                    </div>

                    <div class="field-group">
                        <label>Pincode <span>*</span></label>
                        <div class="input-box">
                            <input type="text" value="673641">
                        </div>
                    </div>

                    <div class="field-group">
                        <label>Country <span>*</span></label>
                        <div class="input-box">
                            <input type="text" value="India">
                        </div>
                    </div>

                    <div class="field-group full-width">
                        <label>Phone Number <span>*</span></label>
                        <div class="input-box">
                            <span class="material-symbols-outlined">call</span>
                            <input type="tel" value="+91 9073105805">
                        </div>
                    </div>

                    <div class="checkbox-row full-width">
                        <input type="checkbox" id="isDefault" checked>
                        <label for="isDefault">Set as Default Address</label>
                    </div>

                    <div class="form-footer full-width">
                        <button type="submit" class="btn-save">Save Changes</button>
                        <button type="button" class="btn-cancel" onclick="window.history.back()">Cancel</button>
                    </div>
                </form>
            </div>
        </main>
    </div>

</body>
</html>