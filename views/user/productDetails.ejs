<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | <%= product.name %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        body {
            background-color: var(--off-white);
            color: var(--primary-black);
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .product-page-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 100px 8%;
        }

        .main-grid {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 100px;
        }

        /* Image Section */
        .image-col {
            display: flex;
            gap: 20px;
        }

        .thumb-stack {
            display: flex;
            flex-direction: column;
            gap: 10px;
            width: 80px;
        }

        .thumb {
            width: 80px;
            aspect-ratio: 3/4;
            object-fit: cover;
            cursor: pointer;
            opacity: 0.6;
            transition: 0.3s;
            background: #f8f8f8;
        }

        .thumb:hover, .thumb.active {
            opacity: 1;
        }

        .main-img-box {
            flex: 1;
            aspect-ratio: 3/4;
            background: #f8f8f8;
            overflow: hidden;
            position: relative;
        }

        .main-img { width: 100%; height: 100%; object-fit: cover; }

        /* Zara Style Notifications */
        .zara-toast { background: #000 !important; color: #fff !important; border-radius: 0 !important; font-family: 'Inter', sans-serif !important; font-size: 0.65rem !important; text-transform: uppercase !important; letter-spacing: 2px !important; padding: 15px 40px !important; width: 100% !important; max-width: 600px !important; margin-top: 20px !important; box-shadow: 0 10px 40px rgba(0,0,0,0.2) !important; }
        
        transition: transform 0.3s ease-out;
        }

        /* Details Section */
        .details-col {
            padding-left: 40px;
            max-width: 550px;
        }

        .p-name {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            text-transform: uppercase;
            letter-spacing: -1px;
            margin-bottom: 10px;
            font-weight: 400;
        }

        .p-category {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #999;
            display: block;
            margin-bottom: 30px;
        }

        .p-price-box {
            margin-bottom: 40px;
        }

        .cur-price {
            font-size: 1.5rem;
            font-weight: 600;
        }

        .old-price {
            text-decoration: line-through;
            color: #999;
            margin-left: 15px;
            font-weight: 300;
        }

        .selector-label {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 700;
            margin-bottom: 15px;
            display: block;
        }

        .variant-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
            gap: 10px;
            margin-bottom: 40px;
        }

        .v-opt {
            padding: 12px;
            border: 0.5px solid var(--border-light);
            text-align: center;
            font-size: 0.7rem;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s;
        }

        .v-opt:hover { border-color: #000; }
        .v-opt.active { border-color: #000; background: #000; color: #fff; }

        .btn-bag {
            width: 100%;
            background: #000;
            color: #fff;
            padding: 20px;
            text-transform: uppercase;
            letter-spacing: 3px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-bottom: 20px;
            transition: 0.3s;
        }

        .btn-bag:hover { opacity: 0.8; }

        .btn-wish {
            width: 100%;
            border: 0.5px solid #000;
            padding: 18px;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 0.65rem;
            font-weight: 600;
            margin-bottom: 40px;
        }

        .p-desc {
            font-size: 0.85rem;
            line-height: 1.8;
            color: #444;
            margin-bottom: 40px;
        }

        .section-separator {
            border-top: 0.5px solid var(--border-light);
            padding-top: 40px;
            margin-top: 60px;
        }

        .related-title {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            margin-bottom: 30px;
        }

        @media (max-width: 1024px) {
            .main-grid { grid-template-columns: 1fr; gap: 60px; }
            .details-col { padding-left: 0; margin-top: 50px; max-width: 100%; }
            .image-col { flex-direction: column-reverse; }
            .thumb-stack { flex-direction: row; width: 100%; }
        }
    </style>
</head>
<body>

    <%- include('../partials/user/header') %>

    <div class="product-page-container">
        <div class="main-grid">
            
            <!-- Images -->
            <div class="image-col">
                <div class="thumb-stack">
                    <% 
                        const gallery = [...product.images];
                        if (product.variants) {
                            product.variants.forEach(v => {
                                v.images.forEach(img => { if (!gallery.includes(img)) gallery.push(img); });
                            });
                        }
                    %>
                    <% gallery.forEach((img, i) => { %>
                        <img src="<%= img %>" class="thumb <%= i===0 ? 'active' : '' %>" onclick="changeImage('<%= img %>', this)">
                    <% }) %>
                </div>
                <div class="main-img-box" id="zoom-box">
                    <img src="<%= gallery[0] || 'https://placehold.co/600x800?text=SNOVA' %>" alt="<%= product.name %>" id="main-view" class="main-img">
                </div>
            </div>

            <!-- Details -->
            <div class="details-col">
                <span class="p-category"><%= product.category.name %></span>
                <h1 class="p-name"><%= product.name %></h1>
                
                <div class="p-price-box">
                    <% if (product.discount > 0) { %>
                        <span class="cur-price">₹<%= Math.round(product.price - (product.price * product.discount / 100)).toLocaleString('en-IN') %></span>
                        <span class="old-price">₹<%= product.price.toLocaleString('en-IN') %></span>
                    <% } else { %>
                        <span class="cur-price">₹<%= product.price.toLocaleString('en-IN') %></span>
                    <% } %>
                </div>

                <% if (product.variants && product.variants.length > 0) { %>
                    <span class="selector-label">Select Size / Color</span>
                    <div class="variant-grid">
                        <% const seen = new Set(); %>
                        <% product.variants.forEach((v, idx) => { %>
                            <% const key = `${v.size}-${v.color}`; %>
                            <% if (!seen.has(key)) { seen.add(key); %>
                                <div class="v-opt" onclick="selectVariant(<%= idx %>, this)">
                                    <div class="font-bold"><%= v.size %></div>
                                    <div class="text-[8px] opacity-60"><%= v.color %></div>
                                </div>
                            <% } %>
                        <% }) %>
                    </div>
                    <input type="hidden" id="selected-v" value="">
                <% } %>

                <p class="p-desc"><%= product.description %></p>

                <% if (product.stock > 0) { %>
                    <button class="btn-bag" onclick="addToCart('<%= product._id %>')">Add to bag</button>
                    <button class="btn-wish" onclick="toggleWishlist('<%= product._id %>')">Add to wishlist</button>
                <% } else { %>
                    <button class="btn-bag opacity-30 cursor-not-allowed" disabled>Sold out</button>
                <% } %>

                <div class="text-[10px] uppercase tracking-widest leading-loose text-gray-400">
                    <p>Free standard delivery</p>
                    <p>Return policy: 30 days</p>
                </div>
            </div>
        </div>

        <!-- Related Selection -->
        <% if (relatedProducts && relatedProducts.length > 0) { %>
            <div class="section-separator">
                <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px;">
                    <div>
                        <h3 class="related-title" style="margin-bottom: 5px;">Match With</h3>
                        <p style="font-size: 0.55rem; text-transform: uppercase; letter-spacing: 2px; color: #999;">Curated Selections From the Same Category</p>
                    </div>
                </div>
                
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-16">
                    <% relatedProducts.forEach(item => { %>
                        <a href="/product/<%= item._id %>" class="block group">
                            <div class="aspect-[3/4] overflow-hidden mb-5 bg-gray-50">
                                <% 
                                    let displayImg = '';
                                    if (item.images && item.images[0] && item.images[0] !== '') {
                                        displayImg = item.images[0];
                                    } else if (item.variants && item.variants.length > 0) {
                                        const varWithImg = item.variants.find(v => v.images && v.images[0]);
                                        if (varWithImg) displayImg = varWithImg.images[0];
                                    }
                                    if(!displayImg) displayImg = 'https://placehold.co/600x800?text=SNOVA';
                                %>
                                <img src="<%= displayImg %>" alt="<%= item.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out" onerror="this.src='https://placehold.co/600x800?text=SNOVA'">
                            </div>
                            <div class="flex justify-between items-start">
                                <div style="max-width: 80%;">
                                    <span style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 4px; color: #000;"><%= item.name %></span>
                                    <span style="font-size: 0.55rem; text-transform: uppercase; letter-spacing: 1px; color: #999;"><%= item.category ? item.category.name : 'Category' %></span>
                                </div>
                                <span style="font-size: 0.75rem; font-weight: 500; color: #000;">₹<%= item.price.toLocaleString('en-IN') %></span>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </div>
        <% } %>
    </div>

    <%- include('../partials/user/footer') %>

    <script>
        function changeImage(src, el) {
            document.getElementById('main-view').src = src;
            document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }

        function showToast(msg) {
            Swal.fire({
                text: msg,
                toast: true,
                position: 'top',
                showConfirmButton: false,
                timer: 3000,
                customClass: { popup: 'zara-toast' },
                showClass: { popup: 'animate__animated animate__fadeInDown' }
            });
        }

        const variants = <%- JSON.stringify(product.variants || []) %>;
        function selectVariant(idx, el) {
            document.querySelectorAll('.v-opt').forEach(o => o.classList.remove('active'));
            el.classList.add('active');
            document.getElementById('selected-v').value = variants[idx]._id;
        }

        async function addToCart(productId) {
            const variantId = document.getElementById('selected-v') ? document.getElementById('selected-v').value : null;
            try {
                const res = await fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, variantId })
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Added to bag');
                } else {
                    showToast(data.msg || 'Error');
                }
            } catch (err) { console.error(err); }
        }

        async function toggleWishlist(productId) {
            try {
                const res = await fetch('/wishlist/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId })
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Wishlist updated');
                }
            } catch (err) { console.error(err); }
        }
    </script>
</body>
</html>