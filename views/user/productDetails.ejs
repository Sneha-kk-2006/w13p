<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | <%= product.name %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        body {
            background-color: var(--off-white);
            color: var(--primary-black);
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .product-page-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 100px 8%;
        }

        .main-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
            gap: 80px;
        }

        /* Image Section */
        .image-col {
            display: flex;
            gap: 20px;
            align-items: flex-start;
        }

        .thumb-stack {
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: 80px;
            flex-shrink: 0;
        }

        .thumb {
            width: 80px;
            aspect-ratio: 3/4;
            object-fit: cover;
            cursor: pointer;
            opacity: 0.6;
            transition: all 0.3s ease;
            background: #f8f8f8;
            border: 1px solid transparent;
        }

        .thumb:hover, .thumb.active {
            opacity: 1;
            border-color: #000;
        }

        .main-img-box {
            flex: 1;
            width: 100%;
            aspect-ratio: 3/4;
            background: #f8f8f8;
            overflow: hidden;
            position: relative;
            border: 1px solid var(--border-light);
        }

        .main-img { width: 100%; height: 100%; object-fit: cover; }

        /* Zara Style Notifications */
        .zara-toast { background: #000 !important; color: #fff !important; border-radius: 0 !important; font-family: 'Inter', sans-serif !important; font-size: 0.65rem !important; text-transform: uppercase !important; letter-spacing: 2px !important; padding: 15px 40px !important; width: 100% !important; max-width: 600px !important; margin-top: 20px !important; box-shadow: 0 10px 40px rgba(0,0,0,0.2) !important; }

        /* Details Section */
        .details-col {
            padding-left: 40px;
            max-width: 550px;
        }

        .p-name {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            text-transform: uppercase;
            letter-spacing: -1px;
            margin-bottom: 10px;
            font-weight: 400;
        }

        .p-category {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #999;
            display: block;
            margin-bottom: 30px;
        }

        .p-price-box {
            margin-bottom: 40px;
        }

        .cur-price {
            font-size: 1.5rem;
            font-weight: 600;
        }

        .old-price {
            text-decoration: line-through;
            color: #999;
            margin-left: 15px;
            font-weight: 300;
        }

        .selector-label {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 700;
            margin-bottom: 15px;
            display: block;
        }

        .variant-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
            gap: 10px;
            margin-bottom: 40px;
        }

        .v-opt {
            padding: 12px;
            border: 0.5px solid var(--border-light);
            text-align: center;
            font-size: 0.7rem;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s;
        }

        .v-opt:hover { border-color: #000; }
        .v-opt.active { border: 1.5px solid #000; background: #000; color: #fff; }

        /* --- Colour + Size Selectors --- */
        .selector-section { margin-bottom: 28px; }
        .selector-label { font-size: 0.62rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; margin-bottom: 14px; display: flex; gap: 6px; align-items: baseline; }
        .selector-label span.val { font-weight: 400; color: #555; }

        /* Colour swatches */
        .colour-row { display: flex; gap: 10px; flex-wrap: wrap; }
        .colour-swatch { width: 60px; height: 76px; border: 2px solid transparent; cursor: pointer; overflow: hidden; transition: 0.2s; position: relative; }
        .colour-swatch img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .colour-swatch.active { border: 2px solid #000; }
        .colour-swatch:hover { border-color: #555; }

        /* Size boxes */
        .size-row { display: flex; flex-wrap: wrap; gap: 8px; }
        .size-box { min-width: 52px; padding: 11px 14px; border: 1px solid #ddd; text-align: center; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; transition: 0.2s; color: #000; user-select: none; }
        .size-box:hover { border-color: #000; }
        .size-box.active { border-color: #000; background: #000; color: #fff; }
        .size-box.unavailable { border-color: #eee; color: #ccc; cursor: not-allowed; position: relative; }
        .size-box.unavailable::after { content: ''; position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: #ccc; transform: rotate(-15deg); }

        .size-guide-link { display: none; }


        .btn-bag {
            width: 100%;
            background: #000;
            color: #fff;
            padding: 20px;
            text-transform: uppercase;
            letter-spacing: 3px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-bottom: 20px;
            transition: 0.3s;
        }

        .btn-bag:hover { opacity: 0.8; }

        .btn-wish {
            width: 100%;
            border: 0.5px solid #000;
            padding: 18px;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 0.65rem;
            font-weight: 600;
            margin-bottom: 40px;
        }

        .p-desc {
            font-size: 0.85rem;
            line-height: 1.8;
            color: #444;
            margin-bottom: 40px;
        }

        .section-separator {
            border-top: 0.5px solid var(--border-light);
            padding-top: 40px;
            margin-top: 60px;
        }

        .related-title {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            margin-bottom: 30px;
        }

        @media (max-width: 1024px) {
            .main-grid { grid-template-columns: 1fr; gap: 60px; }
            .details-col { padding-left: 0; margin-top: 50px; max-width: 100%; }
            .image-col { flex-direction: column-reverse; }
            .thumb-stack { flex-direction: row; width: 100%; }
        }
        .main-img-box {
    cursor: zoom-in;
}

.main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform-origin: var(--zoom-x, 50%) var(--zoom-y, 50%);
    transition: transform 0.1s ease-out;
}

.main-img-box:hover .main-img {
    transform: scale(2);
}
    </style>
</head>
<body>

    <%- include('../partials/user/header') %>

    <div class="product-page-container">
        <div class="main-grid">
            
            <!-- Images -->
            <div class="image-col">
                <div class="thumb-stack" id="thumbStack">
                    <% 
                        const gallery = [...product.images];
                        if (product.variants) {
                            product.variants.forEach(v => {
                                v.images.forEach(img => { if (!gallery.includes(img)) gallery.push(img); });
                            });
                        }
                    %>
                    <% gallery.forEach((img, i) => { %>
                        <img src="<%= img %>" class="thumb <%= i===0 ? 'active' : '' %>" onclick="changeImage('<%= img %>', this)">
                    <% }) %>
                </div>
                <div class="main-img-box" id="zoom-box"
     onmousemove="handleZoom(event, this)"
     onmouseleave="resetZoom(this)">
    <img src="<%= gallery[0] || 'https://placehold.co/600x800?text=SNOVA' %>" 
         alt="<%= product.name %>" 
         id="main-view" 
         class="main-img">
</div>
            </div>

            <!-- Details -->
            <div class="details-col">
                <span class="p-category"><%= product.category.name %></span>
                <h1 class="p-name"><%= product.name %></h1>
                
               <div class="p-price-box" id="priceBox">
    <% if (offerPrice) { %>
        <!-- Offer price takes priority -->
        <span class="cur-price" id="curPrice" style="color:#e53935;">
            ₹<%= offerPrice.toLocaleString('en-IN') %>
        </span>
        <span class="old-price" id="oldPrice">
            ₹<%= product.price.toLocaleString('en-IN') %>
        </span>
        <span id="discountBadge" style="
            display: inline-block;
            background: #e53935;
            color: #fff;
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            padding: 4px 10px;
            margin-left: 10px;
            vertical-align: middle;
        ">
            <%= discountPercent %>% OFF
        </span>

        <!-- Offer label box -->
        <div style="
            border: 1px dashed #e53935;
            padding: 10px 14px;
            margin-top: 16px;
            font-size: 0.68rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #e53935;
        ">
            🏷️ <strong><%= offer.name %></strong> —
            Valid till <%= new Date(offer.endDate).toLocaleDateString('en-IN') %>
        </div>

    <% } else if (product.discount > 0) { %>
        <!-- Fallback: product's own discount field -->
        <span class="cur-price" id="curPrice">
            ₹<%= Math.round(product.price - (product.price * product.discount / 100)).toLocaleString('en-IN') %>
        </span>
        <span class="old-price" id="oldPrice">
            ₹<%= product.price.toLocaleString('en-IN') %>
        </span>
        <span id="discountBadge" style="display:none;"></span>

    <% } else { %>
        <!-- No offer, no discount -->
        <span class="cur-price" id="curPrice">
            ₹<%= product.price.toLocaleString('en-IN') %>
        </span>
        <span id="oldPrice" style="display:none;"></span>
        <span id="discountBadge" style="display:none;"></span>
    <% } %>
</div>

                <% if (product.variants && product.variants.length > 0) { %>
                    <%
                        // Group by color — include price per variant
                        const colorMap = {};
                        product.variants.forEach((v, idx) => {
                            if (!colorMap[v.color]) colorMap[v.color] = { images: v.images || [], sizes: [] };
                            colorMap[v.color].sizes.push({ size: v.size, stock: v.stock, price: v.price, idx });
                        });
                        const colorKeys = Object.keys(colorMap);
                        const firstColor = colorKeys[0];
                    %>

                    <!-- COLOUR -->
                    <div class="selector-section">
                        <div class="selector-label">Colour: <span class="val" id="colourLabel"><%= firstColor %></span></div>
                        <div class="colour-row">
                            <% colorKeys.forEach((col, ci) => { %>
                                <%
                                    const swatchImg = colorMap[col].images[0] || product.images[0] || null;
                                %>
                                <div class="colour-swatch <%= ci === 0 ? 'active' : '' %>" 
                                     data-color="<%= col %>"
                                     onclick="selectColour(this, '<%= col %>')">
                                    <% if (swatchImg) { %>
                                        <img src="<%= swatchImg %>" alt="<%= col %>">
                                    <% } else { %>
                                        <div style="width:100%;height:100%;background:<%= col.toLowerCase() === 'white' ? '#f5f5f5' : (col.toLowerCase() === 'black' ? '#111' : col.toLowerCase()) %>"></div>
                                    <% } %>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <!-- SIZE -->
                    <div class="selector-section">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                            <div class="selector-label" style="margin:0;">Size: <span class="val" id="sizeLabel">—</span></div>
                        </div>
                        <div class="size-row" id="sizeRow">
                            <% colorMap[firstColor].sizes.forEach(s => { %>
                                <div class="size-box <%= s.stock <= 0 ? 'unavailable' : '' %>" 
                                     data-idx="<%= s.idx %>" 
                                     data-stock="<%= s.stock %>"
                                     data-size="<%= s.size %>"
                                     data-price="<%= s.price || '' %>"
                                     onclick="<%= s.stock > 0 ? 'selectSize(this)' : '' %>">
                                    <%= s.size %>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <input type="hidden" id="selected-v" value="">

                    <!-- Hidden: full variant data for JS -->
                    <script>
                        const variantColorMap = <%- JSON.stringify(
                            Object.fromEntries(
                                Object.entries(colorMap).map(([col, data]) => [
                                    col, {
                                        images: data.images,
                                        sizes: data.sizes
                                    }
                                ])
                            )
                        ) %>;
                        const basePrice = <%= product.price %>;
                        const baseOfferPrice = <%= offerPrice || 'null' %>;
                        const discountPct = <%= discountPercent || 'null' %>;
                    </script>
                <% } %>

                <p class="p-desc"><%= product.description %></p>

                <% if (product.stock > 0) { %>
                    <button class="btn-bag" onclick="addToCart('<%= product._id %>')">Add to bag</button>
                    <button class="btn-wish" onclick="toggleWishlist('<%= product._id %>')">Add to wishlist</button>
                <% } else { %>
                    <button class="btn-bag opacity-30 cursor-not-allowed" disabled>Sold out</button>
                <% } %>

                <div class="text-[10px] uppercase tracking-widest leading-loose text-gray-400">
                    <p>Free standard delivery</p>
                    <p>Return policy: 30 days</p>
                </div>
            </div>
        </div>


        <!-- Related Products — Zara Style -->
        <% if (relatedProducts && relatedProducts.length > 0) { %>
        <div style="border-top: 0.5px solid #eee; padding-top: 60px; margin-top: 70px;">

            <p style="font-size: 0.58rem; text-transform: uppercase; letter-spacing: 3px; font-weight: 700; color: #b8a06a; margin-bottom: 30px;">You May Be Interested In</p>

            <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; align-items: start;">
                <% relatedProducts.forEach(item => { %>
                    <%
                        let displayImg = '';
                        if (item.images && item.images[0] && item.images[0] !== '') {
                            displayImg = item.images[0];
                        } else if (item.variants && item.variants.length > 0) {
                            const varWithImg = item.variants.find(v => v.images && v.images[0]);
                            if (varWithImg) displayImg = varWithImg.images[0];
                        }
                        if (!displayImg) displayImg = 'https://placehold.co/300x400?text=SNOVA';
                    %>
                    <div style="position: relative;">
                        <a href="/product/<%= item._id %>" style="text-decoration: none; display: block;">
                            <div style="width: 100%; height: 260px; overflow: hidden; background: #f4f4f4; margin-bottom: 10px;">
                                <img src="<%= displayImg %>" 
                                     alt="<%= item.name %>"
                                     onerror="this.src='https://placehold.co/300x400?text=SNOVA'"
                                     style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; display: block;">
                            </div>
                            <div style="padding: 0 2px;">
                            <p style="font-size: 0.7rem; font-weight: 500; color: #333; margin-bottom: 4px;">
    <% if (item.offerPrice) { %>
        <span style="color:#e53935; font-weight:700;">
            ₹<%= item.offerPrice.toLocaleString('en-IN') %>
        </span>
        <span style="text-decoration:line-through; color:#aaa; font-size:0.6rem; margin-left:4px;">
            ₹<%= item.price.toLocaleString('en-IN') %>
        </span>
    <% } else { %>
        ₹<%= item.price.toLocaleString('en-IN') %>
    <% } %>
</p>
                                <p style="font-size: 0.6rem; font-weight: 400; color: #aaa; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    <%= item.name %>
                                </p>
                            </div>
                        </a>
                        <button onclick="quickAdd('<%= item._id %>')"
                                style="display: block; background: none; border: none; cursor: pointer; font-size: 1rem; color: #555; padding: 0 2px; line-height: 1; transition: color 0.2s;"
                                onmouseover="this.style.color='#000'" onmouseout="this.style.color='#555'">+</button>
                    </div>
                <% }) %>
            </div>
        </div>
        <% } %>
    </div>

    <%- include('../partials/user/footer') %>

    <script>
        function changeImage(src, el) {
            document.getElementById('main-view').src = src;
            document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }

        function showToast(msg) {
            Toastify({
                text: (msg || "").toUpperCase(),
                duration: 3000,
                gravity: "top",
                position: "center",
                style: { 
                    background: "#000", 
                    borderRadius: "0px",
                    fontSize: "0.7rem",
                    letterSpacing: "1.5px",
                    fontWeight: "500",
                    fontFamily: "'Inter', sans-serif",
                    padding: "15px 40px"
                }
            }).showToast();
        }

        const variants = <%- JSON.stringify(product.variants || []) %>;
        const allProductImages = <%- JSON.stringify(product.images || []) %>;

        function selectColour(el, color) {
            // Activate swatch
            document.querySelectorAll('.colour-swatch').forEach(s => s.classList.remove('active'));
            el.classList.add('active');
            // Update label
            document.getElementById('colourLabel').textContent = color;
            // Reset size + price
            document.getElementById('selected-v').value = '';
            document.getElementById('sizeLabel').textContent = '\u2014';
            resetPrice();
            // Rebuild size row
            const sizeRow = document.getElementById('sizeRow');
            const data = variantColorMap[color];
            sizeRow.innerHTML = '';
            (data.sizes || []).forEach(s => {
                const box = document.createElement('div');
                box.className = 'size-box' + (s.stock <= 0 ? ' unavailable' : '');
                box.dataset.idx   = s.idx;
                box.dataset.stock = s.stock;
                box.dataset.size  = s.size;
                box.dataset.price = s.price || '';
                box.textContent   = s.size;
                if (s.stock > 0) box.onclick = () => selectSize(box);
                sizeRow.appendChild(box);
            });
            // Rebuild left gallery with this color's images
            const imgs = (data.images && data.images.length > 0) ? data.images : allProductImages;
            const thumbStack = document.getElementById('thumbStack');
            const mainView   = document.getElementById('main-view');
            thumbStack.innerHTML = '';
            imgs.forEach((src, i) => {
                const img     = document.createElement('img');
                img.src       = src;
                img.className = 'thumb' + (i === 0 ? ' active' : '');
                img.onclick   = () => changeImage(src, img);
                thumbStack.appendChild(img);
            });
            mainView.src = imgs[0];
        }

        function selectSize(el) {
            document.querySelectorAll('.size-box').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
            document.getElementById('sizeLabel').textContent = el.dataset.size;
            document.getElementById('selected-v').value = variants[el.dataset.idx]._id;

            // Update price display based on variant price
            const variantPrice = parseFloat(el.dataset.price);
            if (variantPrice && variantPrice > 0) {
                updatePrice(variantPrice);
            } else {
                resetPrice();
            }
        }

        // Update the price display to show variant price (with offer discount applied if applicable)
        function updatePrice(varPrice) {
            const curEl   = document.getElementById('curPrice');
            const oldEl   = document.getElementById('oldPrice');
            const badgeEl = document.getElementById('discountBadge');

            if (discountPct) {
                // Offer exists — apply same discount % to variant price
                const discounted = Math.round(varPrice - (varPrice * discountPct / 100));
                curEl.textContent  = '\u20b9' + discounted.toLocaleString('en-IN');
                curEl.style.color  = '#e53935';
                oldEl.textContent  = '\u20b9' + varPrice.toLocaleString('en-IN');
                oldEl.style.display = '';
                if (badgeEl) { badgeEl.textContent = discountPct + '% OFF'; badgeEl.style.display = ''; }
            } else {
                curEl.textContent  = '\u20b9' + varPrice.toLocaleString('en-IN');
                curEl.style.color  = '';
                oldEl.style.display = 'none';
                if (badgeEl) badgeEl.style.display = 'none';
            }
        }

        // Reset to the base product price
        function resetPrice() {
            const curEl   = document.getElementById('curPrice');
            const oldEl   = document.getElementById('oldPrice');
            const badgeEl = document.getElementById('discountBadge');

            if (baseOfferPrice) {
                curEl.textContent  = '\u20b9' + baseOfferPrice.toLocaleString('en-IN');
                curEl.style.color  = '#e53935';
                oldEl.textContent  = '\u20b9' + basePrice.toLocaleString('en-IN');
                oldEl.style.display = '';
            } else {
                curEl.textContent  = '\u20b9' + basePrice.toLocaleString('en-IN');
                curEl.style.color  = '';
                oldEl.style.display = 'none';
                if (badgeEl) badgeEl.style.display = 'none';
            }
        }

        async function addToCart(productId) {
            const variantId = document.getElementById('selected-v') ? document.getElementById('selected-v').value : null;
            try {
                const res = await fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, variantId })
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Added to bag');
                    updateCartBadge(data.cartCount);
                } else {
                    showToast(data.msg || 'Error');
                }
            } catch (err) { console.error(err); }
        }

        function updateCartBadge(count) {
            const badge = document.getElementById('cartCountBadge');
            if (badge) {
                if (count > 0) {
                    badge.textContent = count > 99 ? '99+' : count;
                    badge.style.display = 'flex';
                } else {
                    badge.style.display = 'none';
                }
            }
        }


        async function toggleWishlist(productId) {
            try {
                const res = await fetch('/wishlist/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId })
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Wishlist updated');
                    if (typeof updateWishlistBadge === 'function') {
                        updateWishlistBadge(data.wishlistCount);
                    }
                }

            } catch (err) { console.error(err); }
        }

        // Quick add from related products grid
        async function quickAdd(productId) {
            try {
                const res = await fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, variantId: null })
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Added to bag ✓');
                    updateCartBadge(data.cartCount);
                } else {
                    showToast(data.msg || 'Please select a variant on product page');
                }
            } catch (err) {
                showToast('Something went wrong');
            }
        }

         

       function handleZoom(e, box) {
    const rect = box.getBoundingClientRect();
    const x = ((e.clientX - rect.left) / rect.width) * 100;
    const y = ((e.clientY - rect.top) / rect.height) * 100;
    const img = box.querySelector('.main-img');
    img.style.transformOrigin = `${x}% ${y}%`;
    img.style.transform = 'scale(2)';
}

function resetZoom(box) {
    const img = box.querySelector('.main-img');
    img.style.transform = 'scale(1)';
    img.style.transformOrigin = '50% 50%';
}







