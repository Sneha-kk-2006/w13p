        document.querySelectorAll('.rel-img').forEach(img => {
            img.parentElement.addEventListener('mouseenter', () => img.style.transform = 'scale(1.04)');
            img.parentElement.addEventListener('mouseleave', () => img.style.transform = 'scale(1)');
        });
    </script>
