<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SNOVA | Modern Fashion Store</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    :root {
      --primary-green: #10b981;
      --dark-bg: #111111;
      --light-pink: #fdf2f2;
      --danger-red: #ff3b3b;
      --text-gray: #666;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    body {
      background-color: var(--light-pink);
      color: #111;
      -webkit-font-smoothing: antialiased;
    }

    /* Navigation Header */
    .navbar {
      background: var(--dark-bg);
      padding: 15px 5%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .logo {
      color: var(--primary-green);
      font-size: 24px;
      font-weight: bold;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav-links {
      display: flex;
      gap: 25px;
    }

    .nav-links a {
      color: white;
      text-decoration: none;
      font-size: 14px;
      transition: 0.3s;
    }

    .nav-links a:hover { color: var(--primary-green); }

    .nav-tools {
      display: flex;
      align-items: center;
      gap: 20px;
      color: white;
    }

    .search-bar {
      background: #222;
      padding: 5px 15px;
      border-radius: 20px;
      display: flex;
      align-items: center;
    }

    .search-bar input {
      background: transparent;
      border: none;
      color: white;
      outline: none;
      width: 150px;
      font-size: 12px;
    }

    /* Hero Section */
    .hero-container { padding: 20px 5%; }
    .hero {
      position: relative;
      background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.2)), 
                  url('https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&w=1200&q=80') center/cover;
      height: 400px;
      border-radius: 15px;
      display: flex;
      align-items: center;
      padding: 0 50px;
      color: white;
    }

    .hero-text h1 { font-size: 42px; line-height: 1.2; margin-bottom: 20px; font-weight: 800; }

    /* Product Grid */
    .section-wrapper { padding: 40px 5%; }
    .section-header { margin-bottom: 30px; border-left: 5px solid var(--primary-green); padding-left: 15px; }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 25px;
    }

    .product-card {
      background: white;
      border-radius: 15px;
      overflow: hidden;
      position: relative;
      box-shadow: 0 10px 20px rgba(0,0,0,0.05);
      transition: 0.3s;
    }
    .product-card:hover { transform: translateY(-10px); }

    .product-img {
      height: 350px;
      width: 100%;
      object-fit: cover;
    }

    .wishlist-icon {
      position: absolute; top: 15px; right: 15px;
      background: white; width: 35px; height: 35px;
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: #ccc; transition: 0.3s;
    }
    .wishlist-icon:hover { color: var(--danger-red); }

    .badge {
      position: absolute; top: 15px; left: 15px;
      background: var(--danger-red); color: white;
      padding: 4px 10px; border-radius: 4px; font-size: 11px; font-weight: bold;
    }

    .product-info { padding: 15px; }
    .product-info h3 { font-size: 16px; margin-bottom: 5px; color: #333; }
    .price-row { display: flex; align-items: center; gap: 10px; margin-top: 5px; }
    .new-price { font-weight: bold; font-size: 18px; color: #111; }
    .old-price { color: #999; text-decoration: line-through; font-size: 14px; }

    .add-cart-btn {
      background: var(--primary-green); color: white; border: none;
      padding: 10px 15px; border-radius: 8px; width: 100%; margin-top: 15px;
      cursor: pointer; font-weight: 600; display: flex; justify-content: center; align-items: center; gap: 8px;
    }

    /* Footer */
    .footer { background: var(--dark-bg); color: #999; padding: 60px 5% 30px; margin-top: 60px; }
    .footer-grid {
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 50px;
      border-bottom: 1px solid #333; padding-bottom: 40px;
    }
    .footer h4 { color: white; margin-bottom: 20px; font-size: 14px; }
    .copyright { text-align: center; padding-top: 30px; font-size: 12px; }

    @media (max-width: 768px) {
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .nav-links { display: none; }
      .product-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
      .product-img { height: 250px; }
    }
  </style>
</head>
<body>
  <%- include('../partials/user/header') %> 

  <div class="section-wrapper">
    <div class="section-header">
      <h2>Featured Products</h2>
      <p style="color: var(--text-gray); font-size: 14px;">Handpicked trends for your wardrobe</p>
    </div>

    <div class="product-grid" id="main-grid">
      </div>
  </div>

  <%- include('../partials/user/footer') %>
  
  <script>
    const productData = [
      { name: "Floral Summer Dress", old: "₹1,299", new: "₹899", tag: "-30%", img: "https://images.unsplash.com/photo-1572804013309-59a88b7e92f1?auto=format&fit=crop&w=500&q=80" },
      { name: "Classic Denim Jacket", old: "₹2,499", new: "₹1,899", tag: "New", img: "https://images.unsplash.com/photo-1551537482-f2075a1d41f2?auto=format&fit=crop&w=500&q=80" },
      { name: "Minimalist Linen Shirt", old: "₹1,199", new: "₹799", tag: "Best Seller", img: "https://images.unsplash.com/photo-1596755094514-f87e34085b2c?auto=format&fit=crop&w=500&q=80" },
      { name: "Boho Maxi Skirt", old: "₹1,599", new: "₹1,299", tag: "-20%", img: "https://images.unsplash.com/photo-1583496661160-fb5886a0aaaa?auto=format&fit=crop&w=500&q=80" },
      { name: "Slim Fit Chinos", old: "₹1,899", new: "₹1,499", tag: null, img: "https://images.unsplash.com/photo-1473966968600-fa801b869a1a?auto=format&fit=crop&w=500&q=80" },
      { name: "Urban Hoodie", old: "₹2,199", new: "₹1,699", tag: "Limited", img: "https://images.unsplash.com/photo-1556821840-3a63f95609a7?auto=format&fit=crop&w=500&q=80" },
      { name: "Silk Wrap Blouse", old: "₹1,499", new: "₹1,199", tag: "-15%", img: "https://images.unsplash.com/photo-1589156229687-496a31ad1d1f?auto=format&fit=crop&w=500&q=80" },
      { name: "velvet evening gown", old: "₹699", new: "₹499", tag: "Eco", img: "https://images.unsplash.com/photo-1566174053879-31528523f8ae?auto=format&fit=crop&w=500&q=80" },
      { name: "floral wrap dress", old: "₹899", new: "₹599", tag: "Hot", img:"https://images.unsplash.com/photo-1572804013309-59a88b7e92f1?auto=format&fit=crop&w=500&q=80" },
      { name: "Leather Chelsea Boots", old: "₹4,999", new: "₹3,499", tag: "-30%", img: "https://images.unsplash.com/photo-1638247025967-b4e38f787b76?auto=format&fit=crop&w=500&q=80" },
      { name: "Casual Striped Tee", old: "₹799", new: "₹499", tag: "New", img: "https://images.unsplash.com/photo-1523381210434-271e8be1f52b?auto=format&fit=crop&w=500&q=80" },
      { name: "mini dress", old: "₹1,299", new: "₹999", tag: null, img:"https://images.unsplash.com/photo-1496747611176-843222e1e57c?auto=format&fit=crop&w=500&q=80"}
    ];

    const grid = document.getElementById('main-grid');
    
    productData.forEach(p => {
      grid.innerHTML += `
        <div class="product-card">
          ${p.tag ? `<span class="badge">${p.tag}</span>` : ''}
          <div class="wishlist-icon"><i class="far fa-heart"></i></div>
          <img src="${p.img}" alt="${p.name}" class="product-img">
          <div class="product-info">
            <h3>${p.name}</h3>
            <div class="price-row">
              <span class="new-price">${p.new}</span>
              <span class="old-price">${p.old}</span>
            </div>
            <button class="add-cart-btn"><i class="fas fa-cart-plus"></i> Add to Cart</button>
          </div>
        </div>
      `;
    });
  </script>
</body>
</html>