<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SNOVA | New In</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
  
  <style>
    :root {
      --primary-black: #000000;
      --off-white: #ffffff;
      --text-gray: #666;
      --border-light: #eee;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: 'Inter', sans-serif;
    }

    body {
      background-color: var(--off-white);
      color: var(--primary-black);
      -webkit-font-smoothing: antialiased;
    }

    .shop-header {
      padding: 60px 5% 40px;
      text-align: left;
    }

    .shop-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 400;
      text-transform: uppercase;
      letter-spacing: -1px;
    }

    .shop-header p {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--text-gray);
      margin-top: 10px;
    }

    /* Minimal Grid */
    .section-wrapper {
      padding: 0 5% 80px;
    }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 15px;
    }

    .product-card {
      text-decoration: none;
      color: inherit;
      position: relative;
      margin-bottom: 30px;
    }

    .img-box {
      aspect-ratio: 3/4;
      background-color: #f9f9f9;
      overflow: hidden;
      position: relative;
      margin-bottom: 15px;
    }

    .product-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .product-card:hover .product-img {
      transform: scale(1.05);
    }

    .wishlist-btn {
      position: absolute;
      top: 15px;
      right: 15px;
      background: none;
      border: none;
      font-size: 18px;
      cursor: pointer;
      z-index: 5;
      color: #000;
      opacity: 0;
      transition: 0.3s;
    }

    .product-card:hover .wishlist-btn {
      opacity: 1;
    }

    .wishlist-btn.active {
      opacity: 1;
      color: #000;
    }

    .badge-minimal {
      position: absolute;
      top: 15px;
      left: 15px;
      background: #000;
      color: #fff;
      padding: 4px 10px;
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }

    .product-info {
      font-size: 0.75rem;
      line-height: 1.6;
    }

    .p-name {
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 400;
      display: block;
      margin-bottom: 4px;
    }

    .p-category {
      font-size: 0.65rem;
      color: var(--text-gray);
      text-transform: uppercase;
      letter-spacing: 1px;
      display: block;
      margin-bottom: 8px;
    }

    .p-price-row {
      display: flex;
      gap: 10px;
      font-weight: 600;
    }

    .old-price {
      text-decoration: line-through;
      color: #999;
      font-weight: 400;
    }

    .add-minimal {
      margin-top: 15px;
      display: block;
      width: 100%;
      padding: 12px;
      border: 1px solid #000;
      text-align: center;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-weight: 600;
      cursor: pointer;
      transition: 0.3s;
      background: transparent;
    }

    .add-minimal:hover {
      background: #000;
      color: #fff;
    }

    .add-minimal:disabled {
      border-color: #ccc;
      color: #ccc;
      cursor: not-allowed;
    }

    /* Pagination */
    .pagination-container {
      display: flex;
      justify-content: center;
      gap: 15px;
      margin-top: 50px;
    }

    .pg-link {
      text-decoration: none;
      color: #000;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding-bottom: 5px;
      border-bottom: 1px solid transparent;
    }

    .pg-link:hover, .pg-link.active {
      border-bottom: 1.5px solid #000;
    }

    @media (max-width: 1024px) {
      .product-grid { grid-template-columns: repeat(3, 1fr); }
    }

    @media (max-width: 768px) {
      .product-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
      .shop-header h1 { font-size: 2rem; }
      .wishlist-btn { opacity: 1; }
    }

    /* Zara Style Notifications */
    .zara-toast { background: #000 !important; color: #fff !important; border-radius: 0 !important; font-family: 'Inter', sans-serif !important; font-size: 0.65rem !important; text-transform: uppercase !important; letter-spacing: 2px !important; padding: 15px 40px !important; width: 100% !important; max-width: 600px !important; margin-top: 20px !important; box-shadow: 0 10px 40px rgba(0,0,0,0.2) !important; }
  </style>
</head>
<body>

  <%- include('../partials/user/header') %>

  <header class="shop-header">
    <p>SNOVA Categories</p>
    <h1>NEW ARRIVALS</h1>
  </header>

  <div class="section-wrapper">
    <div class="product-grid">
      <% if (products.length === 0) { %>
        <div style="grid-column: 1/-1; text-align: center; padding: 100px 0;">
          <p style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; color: #999;">No items found in this section.</p>
        </div>
      <% } %>

      <% products.forEach(product => { %>
        <div class="product-card">
          <!-- Discount badge -->
          <% if (product.discount > 0) { %>
            <span class="badge-minimal">Sale</span>
          <% } %>

          <!-- Wishlist -->
          <% const inWishlist = wishlistProductIds.includes(product._id.toString()); %>
          <button 
            class="wishlist-btn <%= inWishlist ? 'active' : '' %>" 
            onclick="toggleWishlist('<%= product._id %>', this)"
            id="wish-<%= product._id %>"
          >
            <i class="<%= inWishlist ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
          </button>

          <a href="/product/<%= product._id %>">
            <div class="img-box" style="background-color: #f0f0f0; min-height: 350px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
              <% 
                let displayImg = '';
                const checkPath = (p) => p && typeof p === 'string' && p.trim() !== '' && p !== 'undefined' && p !== 'null';
                
                if (checkPath(product.images && product.images[0])) {
                    displayImg = product.images[0];
                } else if (product.variants && product.variants.length > 0) {
                    const varWithImg = product.variants.find(v => checkPath(v.images && v.images[0]));
                    if (varWithImg) displayImg = varWithImg.images[0];
                }
                
                if(!checkPath(displayImg)) displayImg = 'https://picsum.photos/seed/snova' + product._id + '/600/800';
              %>
              <img src="<%= displayImg %>" 
                   alt="<%= product.name %>" 
                   class="product-img" 
                   style="width: 100%; height: 100%; object-fit: cover; display: block;"
                   onerror="this.onerror=null;this.src='https://picsum.photos/600/800?grayscale';">
            </div>
          </a>

          <div class="product-info">
            <span class="p-category"><%= product.category ? product.category.name : 'ESSENTIAL' %></span>
            <a href="/product/<%= product._id %>" style="text-decoration:none; color:inherit;"><span class="p-name"><%= product.name %></span></a>
            
            <div class="p-price-row">
              <% if (product.discount > 0) { %>
                <span style="color: #000;">₹<%= Math.round(product.price - (product.price * product.discount / 100)).toLocaleString('en-IN') %></span>
                <span class="old-price">₹<%= product.price.toLocaleString('en-IN') %></span>
              <% } else { %>
                <span>₹<%= product.price.toLocaleString('en-IN') %></span>
              <% } %>
            </div>

            <% if (product.stock === 0) { %>
              <button class="add-minimal" disabled>Sold Out</button>
            <% } else { %>
              <button class="add-minimal" onclick="addToCart('<%= product._id %>')">Add to Bag</button>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
      <div class="pagination-container">
        <% if (currentPage > 1) { %>
          <a href="/products?page=<%= currentPage - 1 %>" class="pg-link">Back</a>
        <% } %>
        
        <% for(let i=1; i <= totalPages; i++) { %>
          <a href="/products?page=<%= i %>" class="pg-link <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
        <% } %>

        <% if (currentPage < totalPages) { %>
          <a href="/products?page=<%= currentPage + 1 %>" class="pg-link">Next</a>
        <% } %>
      </div>
    <% } %>
  </div>

  <%- include('../partials/user/footer') %>

  <script>
    function showToast(msg) {
      Swal.fire({
        text: msg,
        toast: true,
        position: 'top',
        showConfirmButton: false,
        timer: 3000,
        customClass: { popup: 'zara-toast' },
        showClass: { popup: 'animate__animated animate__fadeInDown' }
      });
    }

    async function addToCart(productId) {
      try {
        const res = await fetch('/cart/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, quantity: 1 })
        });
        const data = await res.json();
        if (data.success) {
          showToast('Added to bag');
        } else {
          showToast(data.msg || 'Could not add to cart');
        }
      } catch (err) {
        showToast('Something went wrong');
      }
    }

    async function toggleWishlist(productId, btn) {
      <% if (!isLoggedIn) { %>
        window.location.href = '/login';
        return;
      <% } %>

      const icon = btn.querySelector('i');
      const isWishlisted = icon.classList.contains('fa-solid');
      const url = isWishlisted ? '/wishlist/remove' : '/wishlist/add';

      try {
        const res = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId })
        });
        const data = await res.json();

        if (data.success) {
          if (isWishlisted) {
            icon.classList.replace('fa-solid', 'fa-regular');
            btn.classList.remove('active');
          } else {
            icon.classList.replace('fa-regular', 'fa-solid');
            btn.classList.add('active');
          }
          showToast(data.msg);
        }
      } catch (err) {
        console.error(err);
      }
    }
  </script>
</body>
</html>