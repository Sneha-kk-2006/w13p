<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Categories</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        body {
            background-color: var(--off-white);
            color: var(--primary-black);
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .filter-sidebar {
            width: 280px;
            padding: 40px 2% 80px;
            border-right: 0.5px solid var(--border-light);
            height: calc(100vh - 80px);
            position: sticky;
            top: 80px;
            overflow-y: auto;
        }

        .filter-section {
            margin-bottom: 40px;
        }

        .filter-title {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            margin-bottom: 20px;
            display: block;
        }

        .filter-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
            cursor: pointer;
            text-transform: uppercase;
        }

        .filter-item input[type="checkbox"] {
            accent-color: #000;
            width: 14px;
            height: 14px;
        }

        .price-input {
            width: 100%;
            border: none;
            border-bottom: 1px solid #000;
            padding: 8px 0;
            font-size: 0.75rem;
            outline: none;
            background: transparent;
            margin-bottom: 15px;
        }

        .btn-black-small {
            width: 100%;
            background: #000;
            color: #fff;
            padding: 10px;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
        }

        /* Products list */
        .products-container {
            flex: 1;
            padding: 40px 3%;
        }

        .grid-header {
            margin-bottom: 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .grid-header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 400;
            text-transform: uppercase;
        }

        .sort-select {
            border: none;
            border-bottom: 1px solid #000;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            outline: none;
            padding: 5px 0;
            cursor: pointer;
        }

        /* Essential Grid (Shared with Products) */
        .p-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
        }

        .p-card {
            margin-bottom: 40px;
        }

        .p-img-box {
            aspect-ratio: 3/4;
            background: #f8f8f8;
            margin-bottom: 15px;
            position: relative;
            overflow: hidden;
        }

        .p-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.5s ease;
        }

        .p-img-secondary {
            position: absolute;
            top: 0;
            left: 0;
            opacity: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.5s ease;
        }

        .p-card:hover .p-img {
            transform: scale(1.05);
            opacity: 0;
        }

        .p-card:hover .p-img-secondary {
            transform: scale(1.05);
            opacity: 1;
        }


        .p-info {
            font-size: 0.75rem;
            line-height:1.5;
        }

        .p-name { text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 5px; display: block; }
        .p-price { font-weight: 600; }

        .search-minimal {
            display: flex;
            border-bottom: 1px solid #000;
            margin-bottom: 30px;
            align-items: center;
            padding-bottom: 5px;
        }

        .search-minimal input {
            border: none;
            outline: none;
            flex: 1;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 5px;
        }

        .tag-minimal {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #f4f4f4;
            padding: 5px 12px;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-right: 10px;
            margin-bottom: 10px;
        }

        .pagination-minimal {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 60px;
        }

        .pg-btn {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            padding-bottom: 5px;
            border-bottom: 1px solid transparent;
        }

        .pg-btn.active { border-bottom: 1.5px solid #000; }

        @media (max-width: 768px) {
            .filter-sidebar { display: none; }
            .p-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
        }
    </style>
</head>
<body>

    <%- include('../partials/user/header') %>

    <div class="flex">
        <!-- Sidebar -->
        <aside class="filter-sidebar">
            <div class="search-minimal">
                <input type="text" id="searchInput" placeholder="Search..." value="<%= search %>" onkeypress="if(event.key==='Enter') applyFilter()">
                <i class="fa-solid fa-magnifying-glass text-xs cursor-pointer" onclick="applyFilter()"></i>
            </div>

            <div class="filter-section">
                <span class="filter-title">Categories</span>
                <% categories.forEach(cat => { %>
                    <label class="filter-item">
                        <input type="checkbox" class="category-filter" value="<%= cat._id %>" <%= categoryId == cat._id.toString() ? 'checked' : '' %> onchange="applyFilter()">
                        <span><%= cat.name %></span>
                    </label>
                <% }) %>
            </div>

            <div class="filter-section">
                <span class="filter-title">Price Range</span>
                <input type="number" id="minPrice" placeholder="MIN PRICE (₹)" class="price-input" value="<%= minPrice %>">
                <input type="number" id="maxPrice" placeholder="MAX PRICE (₹)" class="price-input" value="<%= maxPrice %>">
                <button onclick="applyFilter()" class="btn-black-small">Filter Price</button>
            </div>

            <a href="/category" style="font-size: 0.6rem; text-decoration: underline; text-transform: uppercase; letter-spacing: 1.5px; color: #999;">Clear All Filters</a>
        </aside>

        <!-- Main -->
        <main class="products-container">
            <div class="grid-header">
                <h1>Shop</h1>
                <select id="sortSelect" onchange="applyFilter()" class="sort-select">
                    <option value="" <%= sort==='' ? 'selected':'' %>>Sort By</option>
                    <option value="price-low" <%= sort==='price-low' ? 'selected':'' %>>Price: Low to High</option>
                    <option value="price-high" <%= sort==='price-high' ? 'selected':'' %>>Price: High to Low</option>
                    <option value="az" <%= sort==='az' ? 'selected':'' %>>A - Z</option>
                    <option value="za" <%= sort==='za' ? 'selected':'' %>>Z - A</option>
                </select>
            </div>

            <div class="flex flex-wrap mb-10">
                <% if (search) { %><span class="tag-minimal">Search: <%= search %> <i class="fa-solid fa-xmark ml-1 cursor-pointer" onclick="clearSearch()"></i></span><% } %>
                <% if (categoryId) { %>
                    <span class="tag-minimal">
                        Category Filtered 
                        <i class="fa-solid fa-xmark ml-1 cursor-pointer" onclick="location.href='/category'"></i>
                    </span>
                <% } %>
            </div>

            <div class="p-grid">
                <% if (products.length === 0) { %>
                    <div class="col-span-full py-20 text-center"><p class="text-xs uppercase tracking-widest text-gray-400">No pieces found in this selection.</p></div>
                <% } %>

                <% products.forEach(product => { %>
                    <div class="p-card">
                        <a href="/product/<%= product._id %>">
                            <div class="p-img-box">
                                <% 
                                  let primaryImg = '';
                                  let secondaryImg = '';
                                  const checkPath = (p) => p && typeof p === 'string' && p.trim() !== '' && p !== 'undefined' && p !== 'null';
                                  
                                  if (checkPath(product.images && product.images[0])) {
                                      primaryImg = product.images[0];
                                      secondaryImg = checkPath(product.images[1]) ? product.images[1] : primaryImg;
                                  }
                                  
                                  if ((!secondaryImg || secondaryImg === primaryImg) && product.variants && product.variants.length > 0) {
                                      const varWithImg = product.variants.find(v => checkPath(v.images && v.images[0]) && v.images[0] !== primaryImg);
                                      if (varWithImg) {
                                          secondaryImg = varWithImg.images[0];
                                      } else if (!checkPath(primaryImg)) {
                                          const firstVarImg = product.variants.find(v => checkPath(v.images && v.images[0]));
                                          if (firstVarImg) primaryImg = firstVarImg.images[0];
                                      }
                                  }
                                  
                                  if(!checkPath(primaryImg)) primaryImg = '/images/placeholder.jpg';
                                  if(!checkPath(secondaryImg)) secondaryImg = primaryImg;

                                  const getFmt = (img) => (img && !img.startsWith('http') && !img.startsWith('/images/')) ? (img.startsWith('/') ? img : '/uploads/products/' + img) : img;
                                %>
                                <img src="<%= getFmt(primaryImg) %>" alt="<%= product.name %>" class="p-img">
                                <img src="<%= getFmt(secondaryImg) %>" alt="<%= product.name %>" class="p-img-secondary">
                                
                                <% if(product.offerPrice || product.discount > 0) { %>
                                    <span style="position:absolute; bottom:10px; left:10px; background:#e53935; color:#fff; font-size:8px; padding:2px 6px; letter-spacing:1px; text-transform:uppercase; z-index:2;">Sale</span>
                                <% } %>
                            </div>
                        </a>

                        <div class="p-info">
                            <a href="/product/<%= product._id %>" class="p-name"><%= product.name %></a>
                            <div class="p-price">
                                <% if (product.offerPrice) { %>
                                    <span style="color:#e53935;">₹<%= product.offerPrice.toLocaleString('en-IN') %></span>
                                    <span style="text-decoration:line-through; color:#999; font-size:0.65rem; margin-left:5px; font-weight:400;">₹<%= product.price.toLocaleString('en-IN') %></span>
                                <% } else if (product.discount > 0) { %>
                                    <span style="color:#e53935;">₹<%= Math.round(product.price - (product.price * product.discount / 100)).toLocaleString('en-IN') %></span>
                                    <span style="text-decoration:line-through; color:#999; font-size:0.65rem; margin-left:5px; font-weight:400;">₹<%= product.price.toLocaleString('en-IN') %></span>
                                <% } else { %>
                                    ₹<%= product.price.toLocaleString('en-IN') %>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <div class="pagination-minimal">
                    <% if (currentPage > 1) { %>
                        <a href="/category?page=<%= currentPage-1 %>&search=<%= search %>&sort=<%= sort %>&category=<%= categoryId %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>" class="pg-btn">Back</a>
                    <% } %>

                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="/category?page=<%= i %>&search=<%= search %>&sort=<%= sort %>&category=<%= categoryId %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>" class="pg-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <a href="/category?page=<%= currentPage+1 %>&search=<%= search %>&sort=<%= sort %>&category=<%= categoryId %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>" class="pg-btn">Next</a>
                    <% } %>
                </div>
            <% } %>
        </main>
    </div>

    <%- include('../partials/user/footer') %>

    <script>
        function applyFilter() {
            const search = document.getElementById('searchInput').value.trim();
            const sort = document.getElementById('sortSelect').value;
            const minPrice = document.getElementById('minPrice').value;
            const maxPrice = document.getElementById('maxPrice').value;
            
            // Single selection logic
            const allCheckboxes = document.querySelectorAll('.category-filter');
            let category = '';
            
            // The one that was just changed will be the only one considered
            const eventTarget = event ? event.target : null;
            if (eventTarget && eventTarget.classList.contains('category-filter')) {
                if (eventTarget.checked) {
                    category = eventTarget.value;
                    // Uncheck others visually before reload for better UX
                    allCheckboxes.forEach(cb => {
                        if (cb !== eventTarget) cb.checked = false;
                    });
                }
            } else {
                // If triggered by something else (like price filter), find the currently checked one
                const checked = document.querySelector('.category-filter:checked');
                category = checked ? checked.value : '';
            }

            const params = new URLSearchParams();
            if (search) params.set('search', search);
            if (sort) params.set('sort', sort);
            if (category) params.set('category', category);
            if (minPrice) params.set('minPrice', minPrice);
            if (maxPrice) params.set('maxPrice', maxPrice);
            params.set('page', '1');

            window.location.href = `/category?${params.toString()}`;
        }

        function clearSearch() {
            const sort = document.getElementById('sortSelect').value;
            const minPrice = document.getElementById('minPrice').value;
            const maxPrice = document.getElementById('maxPrice').value;
            const checkedCat = document.querySelector('.category-filter:checked');
            const category = checkedCat ? checkedCat.value : '';

            const params = new URLSearchParams();
            if (sort) params.set('sort', sort);
            if (category) params.set('category', category);
            if (minPrice) params.set('minPrice', minPrice);
            if (maxPrice) params.set('maxPrice', maxPrice);
            params.set('page', '1');

            window.location.href = `/category?${params.toString()}`;
        }
    </script>
</body>
</html>
