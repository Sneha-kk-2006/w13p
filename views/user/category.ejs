<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA - Categories</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background-color: #121826; color: white; }
        .sidebar { background-color: #0d1117; }
        .card { background-color: #1c222d; }
        .accent-gold { color: #d4af37; }
    </style>
</head>
<body>

    <nav class="flex items-center justify-between px-10 py-4 border-b border-gray-800">
        <div class="text-2xl font-bold text-green-500">SNOVA</div>
        <div class="flex space-x-8 text-sm">
            <a href="#" class="hover:text-green-400">Home</a>
            <a href="#" class="hover:text-green-400">Products</a>
            <a href="#" class="text-green-400 font-semibold border-b-2 border-green-400">Categories</a>
        </div>
        <div class="flex items-center space-x-6">
            <div class="relative">
                <input type="text" placeholder="Search mobiles..." class="bg-gray-800 rounded-full px-4 py-1 text-sm w-64 border border-gray-700">
            </div>
            <i class="fa-regular fa-heart cursor-pointer"></i>
            <div class="relative cursor-pointer">
                <i class="fa-solid fa-cart-shopping"></i>
                <span class="absolute -top-2 -right-2 bg-green-500 text-xs rounded-full px-1">2</span>
            </div>
            <i class="fa-regular fa-user cursor-pointer"></i>
        </div>
    </nav>

    <div class="flex">
        <aside class="w-64 p-6 sidebar min-h-screen border-r border-gray-800">
            <div class="flex justify-between mb-6">
                <h2 class="font-semibold">Filter by</h2>
                <button class="text-xs text-gray-400">Clear All</button>
            </div>

            <section class="mb-8">
                <h3 class="text-sm font-medium mb-4">Categories</h3>
                <% const categories = [['Womens', 14], ['Mens', 23], ['Kids', 8], ['Girls', 12]]; %>
                <% categories.forEach(cat => { %>
                    <label class="flex items-center space-x-3 mb-2 text-sm text-gray-400">
                        <input type="checkbox" class="accent-green-500"> <span><%= cat[0] %></span>
                        <span class="ml-auto text-xs"><%= cat[1] %></span>
                    </label>
                <% }) %>
            </section><section class="mb-8">
    <h3 class="text-sm font-medium mb-4 flex justify-between items-center">
        Size 
        <i class="fa-solid fa-chevron-up text-xs text-gray-500"></i>
    </h3>
    <div class="grid grid-cols-2 gap-2">
        <% ['S', 'M', 'L', 'XL'].forEach(size => { %>
            <button class="border border-gray-700 py-2 rounded text-xs hover:border-green-500 hover:text-green-500 transition-colors focus:bg-gray-800">
                <%= size %>
            </button>
        <% }) %>
    </div>
</section>

<section class="mb-8">
    <h3 class="text-sm font-medium mb-4 flex justify-between items-center">
        Type 
        <i class="fa-solid fa-chevron-up text-xs text-gray-500"></i>
    </h3>
    <div class="grid grid-cols-2 gap-2 text-[10px]">
        <button class="border border-gray-700 py-2 rounded uppercase">Western</button>
        <button class="border border-orange-500 text-orange-500 py-2 rounded uppercase">Saree</button>
        <button class="border border-gray-700 py-2 rounded uppercase">Kurti</button>
        <button class="border border-gray-700 py-2 rounded uppercase">Lehenga</button>
    </div>
</section>

            <section class="mb-8">
                <h3 class="text-sm font-medium mb-4">Price Range</h3>
                <input type="range" class="w-full h-1 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-gold">
                <div class="flex justify-between text-xs mt-2 text-gray-400">
                    <span>₹100</span><span>₹10,000</span>
                </div>
            </section>
        </aside>

        <main class="flex-1 p-8">
            <h1 class="text-3xl font-bold mb-6">Categories</h1>

            <div class="flex space-x-3 mb-10">
                <span class="bg-gray-800 px-3 py-1 rounded text-xs flex items-center">womens <i class="fa-solid fa-xmark ml-2 cursor-pointer"></i></span>
                <span class="bg-gray-800 px-3 py-1 rounded text-xs flex items-center">M <i class="fa-solid fa-xmark ml-2 cursor-pointer"></i></span>
                <span class="bg-gray-800 px-3 py-1 rounded text-xs flex items-center">saree <i class="fa-solid fa-xmark ml-2 cursor-pointer"></i></span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                <% products.forEach(product => { %>
                    <div class="card rounded-xl overflow-hidden shadow-lg hover:scale-105 transition-transform duration-300">
                        <div class="relative">
                            <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-64 object-cover">
                            <% if(product.discount) { %>
                                <span class="absolute top-2 left-2 bg-pink-600 text-[10px] font-bold px-2 py-1 rounded">-<%= product.discount %>% OFF</span>
                            <% } %>
                            <button class="absolute top-2 right-2 bg-white/20 p-2 rounded-full backdrop-blur-sm">
                                <i class="fa-regular fa-heart text-white text-xs"></i>
                            </button>
                        </div>
                        <div class="p-4">
                            <h4 class="text-lg font-medium"><%= product.name %></h4>
                            <p class="text-xs text-gray-500 mb-4">Size: L</p>
                            <div class="flex justify-between items-center">
                                <span class="text-xl font-bold">₹<%= product.price %>.00</span>
                                <button class="bg-orange-100 text-orange-800 p-2 rounded-full">
                                    <i class="fa-solid fa-cart-shopping text-sm"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </main>
    </div>

    <footer class="bg-black/40 pt-16 pb-8 px-10 border-t border-gray-800">
        <div class="grid grid-cols-4 gap-10">
            <div>
                <h2 class="text-2xl font-bold text-white mb-4">SNOVA</h2>
                <p class="text-gray-400 text-sm leading-relaxed">Your trusted destination for stylish and high-quality dresses. Discover elegant designs and exceptional customer service.</p>
                <div class="flex space-x-4 mt-6">
                    <i class="fa-brands fa-facebook-f text-gray-400 hover:text-white cursor-pointer"></i>
                    <i class="fa-brands fa-twitter text-gray-400 hover:text-white cursor-pointer"></i>
                    <i class="fa-brands fa-instagram text-gray-400 hover:text-white cursor-pointer"></i>
                </div>
            </div>
            <div>
                <h4 class="font-bold mb-4">Shop by category</h4>
                <ul class="text-gray-400 text-sm space-y-2">
                    <li>Casual Dresses</li>
                    <li>Ethnic Wear</li>
                    <li>Kids Wear</li>
                </ul>
            </div>
            <div>
                <h4 class="font-bold mb-4">Customer Support</h4>
                <ul class="text-gray-400 text-sm space-y-2">
                    <li>Contact Us</li>
                    <li>Returns & Refunds</li>
                    <li>Shipping Info</li>
                </ul>
            </div>
            <div>
                <h4 class="font-bold mb-4">Company Info</h4>
                <ul class="text-gray-400 text-sm space-y-2">
                    <li>About Us</li>
                    <li>Privacy Policy</li>
                    <li>Terms of Service</li>
                </ul>
            </div>
        </div>
        <div class="text-center text-gray-600 text-xs mt-16">
            © 2026 Snova. All rights reserved.
        </div>
    </footer>

</body>
</html>