<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA - Products</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body { background-color: hsl(0, 12%, 92%); color: black }
        .sidebar { background-color: #000007; }
        .card { background-color: ffffff;}
        .accent-gold { color: #6d5917; }
        .pagination-active { background-color: #f97316; color: rgb(28, 26, 26); }

        /* Force white text inside sidebar */
        .sidebar, .sidebar h2, .sidebar h3, .sidebar label,
        .sidebar span, .sidebar a { color: white !important; }
        .sidebar input { color: white !important; background-color: #1f2937 !important; }
        .sidebar input::placeholder { color: #9ca3af !important; }
    </style>
</head>
<body>
    <%- include('../partials/user/header') %>

    <div class="flex">

        <!-- ===== SIDEBAR ===== -->
        <aside class="w-64 p-6 h-screen border-r border-gray-800">

            <div class="flex justify-between mb-6">
                <h2 class="font-semibold">Filter by</h2>
                <a href="/category" class="text-xs hover:text-orange-400">Clear All</a>
            </div>

            <!-- Categories from DB -->
            <section class="mb-8">
                <h3 class="text-sm font-medium mb-4">Categories</h3>
                <% categories.forEach(cat => { %>
                    <label class="flex items-center space-x-3 mb-2 text-sm cursor-pointer">
                        <input
                            type="checkbox"
                            class="accent-orange-500 category-filter"
                            value="<%= cat._id %>"
                            <%= categoryId == cat._id.toString() ? 'checked' : '' %>
                            onchange="applyFilter()"
                        />
                        <span><%= cat.name %></span>
                    </label>
                <% }) %>
            </section>

            <!-- Price Range Filter -->
            <section class="mb-8">
                <h3 class="text-sm font-medium mb-4">Price Range</h3>
                <div class="flex gap-2">
                    <input
                        type="number"
                        id="minPrice"
                        placeholder="Min"
                        value="<%= minPrice %>"
                        class="w-full border border-gray-600 rounded px-2 py-1 text-xs"
                    />
                    <input
                        type="number"
                        id="maxPrice"
                        placeholder="Max"
                        value="<%= maxPrice %>"
                        class="w-full border border-gray-600 rounded px-2 py-1 text-xs"
                    />
                </div>
                <button
                    onclick="applyFilter()"
                    class="mt-3 w-full bg-orange-500 hover:bg-orange-600 text-white text-xs py-2 rounded transition"
                >
                    Apply Price
                </button>
            </section>

        </aside>

        <!-- ===== MAIN CONTENT ===== -->
        <main class="flex-1 p-8">
            <h1 class="text-3xl font-bold mb-6">Products</h1>

            <!-- Search + Sort Bar -->
            <div class="flex gap-4 mb-6 flex-wrap">

                <!-- Search Input -->
                <div class="flex items-center bg-gray-800 rounded px-3 py-2 flex-1 min-w-[200px]">
                    <i class="fa-solid fa-magnifying-glass text-gray-400 mr-2 text-sm"></i>
                    <input
                        type="text"
                        id="searchInput"
                        placeholder="Search products..."
                        value="<%= search %>"
                        class="bg-transparent text-white text-sm outline-none flex-1"
                        onkeypress="if(event.key==='Enter') applyFilter()"
                    />
                    <% if (search) { %>
                        <button onclick="clearSearch()" class="text-gray-400 hover:text-white ml-2">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    <% } %>
                </div>

                <!-- Search Button -->
                <button
                    onclick="applyFilter()"
                    class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded text-sm transition"
                >
                    Search
                </button>

                <!-- Sort Dropdown -->
                <select
                    id="sortSelect"
                    onchange="applyFilter()"
                    class="bg-gray-800 border border-gray-700 text-white text-sm rounded px-3 py-2 outline-none"
                >
                    <option value=""           <%= sort===''           ? 'selected':'' %>>Default</option>
                    <option value="price-low"  <%= sort==='price-low'  ? 'selected':'' %>>Price: Low to High</option>
                    <option value="price-high" <%= sort==='price-high' ? 'selected':'' %>>Price: High to Low</option>
                    <option value="az"         <%= sort==='az'         ? 'selected':'' %>>A - Z</option>
                    <option value="za"         <%= sort==='za'         ? 'selected':'' %>>Z - A</option>
                </select>
            </div>

            <!-- Active Filter Tags -->
            <div class="flex flex-wrap gap-2 mb-6">
                <% if (search) { %>
                    <span class="bg-gray-800 text-white px-3 py-1 rounded-full text-xs flex items-center gap-2">
                        Search: "<%= search %>"
                        <a href="/category?sort=<%= sort %>&category=<%= categoryId %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>">
                            <i class="fa-solid fa-xmark cursor-pointer hover:text-orange-400"></i>
                        </a>
                    </span>
                <% } %>
                <% if (categoryId) { %>
                    <span class="bg-gray-800 text-white px-3 py-1 rounded-full text-xs flex items-center gap-2">
                        Category filtered
                        <a href="/category?search=<%= search %>&sort=<%= sort %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>">
                            <i class="fa-solid fa-xmark cursor-pointer hover:text-orange-400"></i>
                        </a>
                    </span>
                <% } %>
                <% if (minPrice || maxPrice) { %>
                    <span class="bg-gray-800 text-white px-3 py-1 rounded-full text-xs flex items-center gap-2">
                        Price: ₹<%= minPrice || 0 %> - ₹<%= maxPrice || '∞' %>
                        <a href="/category?search=<%= search %>&sort=<%= sort %>&category=<%= categoryId %>">
                            <i class="fa-solid fa-xmark cursor-pointer hover:text-orange-400"></i>
                        </a>
                    </span>
                <% } %>
                <% if (sort) { %>
                    <span class="bg-gray-800 text-white px-3 py-1 rounded-full text-xs flex items-center gap-2">
                        Sorted: <%= sort %>
                        <a href="/category?search=<%= search %>&category=<%= categoryId %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>">
                            <i class="fa-solid fa-xmark cursor-pointer hover:text-orange-400"></i>
                        </a>
                    </span>
                <% } %>
            </div>

            <!-- Products Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

                <% if (products.length === 0) { %>
                    <div class="col-span-4 text-center py-20 text-gray-500">
                        <i class="fa-solid fa-box-open text-5xl mb-4 block"></i>
                        <p class="text-lg">No products found</p>
                        <a href="/category" class="text-orange-500 text-sm mt-2 inline-block hover:underline">
                            Clear all filters
                        </a>
                    </div>
                <% } %>

                <% products.forEach(product => { %>
                    <div class="card rounded-xl overflow-hidden shadow-lg hover:scale-105 transition-transform duration-300">
                        <div class="relative">
                            <a href="/product/<%= product._id %>">   <!-- ✅ add this -->
        <img
            src="<%= product.images && product.images[0] ? product.images[0] : '/images/placeholder.png' %>"
            alt="<%= product.name %>"
            class="w-full h-64 object-cover"
        />
        </a> 

                            <!-- Discount Badge -->
                            <% if(product.discount) { %>
                                <span class="absolute top-2 left-2 bg-pink-600 text-white text-[10px] font-bold px-2 py-1 rounded">
                                    -<%= product.discount %>% OFF
                                </span>
                            <% } %>

                            <!-- Out of Stock Badge -->
                            <% if(product.stock === 0) { %>
                                <span class="absolute top-2 left-2 bg-gray-700 text-white text-[10px] font-bold px-2 py-1 rounded">
                                    Out of Stock
                                </span>
                            <% } %>

                            <!-- Wishlist Button -->
                            <% const inWishlist = wishlistProductIds.includes(product._id.toString()); %>
                            <button 
                                id="wish-<%= product._id %>"
                                onclick="toggleWishlist('<%= product._id %>', this)"
                                class="absolute top-2 right-2 bg-white/20 p-2 rounded-full backdrop-blur-sm hover:bg-white/40 transition"
                                title="<%= inWishlist ? 'Remove from Wishlist' : 'Add to Wishlist' %>"
                            >
                                <i class="<%= inWishlist ? 'fa-solid' : 'fa-regular' %> fa-heart text-sm <%= inWishlist ? 'text-red-500' : 'text-white' %>"></i>
                            </button>
                        </div>

                        <div class="p-4">
                         <a href="/product/<%= product._id %>">
  <h4 class="text-lg font-medium text-black hover:text-orange-500 transition"><%= product.name %></h4>
</a>
                            <p class="text-xs text-gray-400 mb-1">
                                <%= product.category ? product.category.name : '' %>
                            </p>

                            <!-- Stock Info -->
                            <% if(product.stock > 0 && product.stock <= 5) { %>
                                <p class="text-xs text-orange-400 mb-2">Only <%= product.stock %> left!</p>
                            <% } else if(product.stock === 0) { %>
                                <p class="text-xs text-red-400 mb-2">Out of Stock</p>
                            <% } %>

                            <div class="flex justify-between items-center mt-2">
                                <div>
                                    <span class="text-xl font-bold text-black">₹<%= product.price %></span>
                                    <% if(product.discount) { %>
                                        <span class="text-xs text-gray-400 line-through ml-1">
                                            ₹<%= Math.round(product.price / (1 - product.discount/100)) %>
                                        </span>
                                    <% } %>
                                </div>

                                <!-- Cart Button -->
                                <% if(product.stock > 0) { %>
                                    <button
                                        onclick="addToCart('<%= product._id %>')"
                                        class="bg-orange-100 text-orange-800 p-2 rounded-full hover:bg-orange-200 transition"
                                    >
                                        <i class="fa-solid fa-cart-shopping text-sm"></i>
                                    </button>
                                <% } else { %>
                                    <button
                                        disabled
                                        class="bg-gray-300 text-gray-500 p-2 rounded-full cursor-not-allowed"
                                    >
                                        <i class="fa-solid fa-cart-shopping text-sm"></i>
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <div class="flex justify-center gap-2 mt-10 flex-wrap">

                    <% if (currentPage > 1) { %>
                        <a href="/category?page=<%= currentPage-1 %>&search=<%= search %>&sort=<%= sort %>&category=<%= categoryId %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>"
                           class="px-3 py-1 bg-gray-800 text-white rounded text-sm hover:bg-gray-700 transition">
                            ← Prev
                        </a>
                    <% } %>

                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="/category?page=<%= i %>&search=<%= search %>&sort=<%= sort %>&category=<%= categoryId %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>"
                           class="px-3 py-1 rounded text-sm transition <%= i === currentPage ? 'pagination-active' : 'bg-gray-800 text-white hover:bg-gray-700' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <a href="/category?page=<%= currentPage+1 %>&search=<%= search %>&sort=<%= sort %>&category=<%= categoryId %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>"
                           class="px-3 py-1 bg-gray-800 text-white rounded text-sm hover:bg-gray-700 transition">
                            Next →
                        </a>
                    <% } %>
                </div>

                <p class="text-center text-xs text-gray-500 mt-3">
                    Page <%= currentPage %> of <%= totalPages %>
                </p>
            <% } %>

        </main>
    </div>

    <!-- FOOTER -->
    <%- include('../partials/user/footer') %>

    <!-- JAVASCRIPT -->
    <script>
        // Apply all filters combined
        function applyFilter() {
            const search   = document.getElementById('searchInput').value.trim();
            const sort     = document.getElementById('sortSelect').value;
            const minPrice = document.getElementById('minPrice').value;
            const maxPrice = document.getElementById('maxPrice').value;

            const checkedCat = document.querySelector('.category-filter:checked');
            const category   = checkedCat ? checkedCat.value : '';

            const params = new URLSearchParams();
            if (search)   params.set('search',   search);
            if (sort)     params.set('sort',      sort);
            if (category) params.set('category',  category);
            if (minPrice) params.set('minPrice',  minPrice);
            if (maxPrice) params.set('maxPrice',  maxPrice);
            params.set('page', '1');

            window.location.href = `/category?${params.toString()}`;
        }

        // Clear only search, keep other filters
        function clearSearch() {
            const sort     = document.getElementById('sortSelect').value;
            const minPrice = document.getElementById('minPrice').value;
            const maxPrice = document.getElementById('maxPrice').value;

            const checkedCat = document.querySelector('.category-filter:checked');
            const category   = checkedCat ? checkedCat.value : '';

            const params = new URLSearchParams();
            if (sort)     params.set('sort',     sort);
            if (category) params.set('category', category);
            if (minPrice) params.set('minPrice', minPrice);
            if (maxPrice) params.set('maxPrice', maxPrice);
            params.set('page', '1');

            window.location.href = `/category?${params.toString()}`;
        }

        // Add to Wishlist (toggle)
        async function toggleWishlist(productId, btn) {
            <% if (!isLoggedIn) { %>
                window.location.href = '/login';
                return;
            <% } %>

            const icon = btn.querySelector('i');
            const isWishlisted = icon.classList.contains('fa-solid');
            const url = isWishlisted ? '/wishlist/remove' : '/wishlist/add';

            try {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId })
                });
                const data = await res.json();

                if (data.success) {
                    // Toggle icon appearance
                    if (isWishlisted) {
                        icon.classList.replace('fa-solid', 'fa-regular');
                        icon.classList.remove('text-red-500');
                        icon.classList.add('text-white');
                        btn.title = 'Add to Wishlist';
                    } else {
                        icon.classList.replace('fa-regular', 'fa-solid');
                        icon.classList.add('text-red-500');
                        icon.classList.remove('text-white');
                        btn.title = 'Remove from Wishlist';
                    }
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'success',
                        title: data.msg,
                        showConfirmButton: false,
                        timer: 1500
                    });
                } else {
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'info',
                        title: data.msg,
                        showConfirmButton: false,
                        timer: 1800
                    });
                }
            } catch (err) {
                Swal.fire({ icon: 'error', title: 'Server error' });
            }
        }

        // Add to Cart
        async function addToCart(productId) {
            try {
                const res  = await fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId })
                });
                const data = await res.json();
                if (data.success) {
                    alert('Added to cart!');
                } else {
                    alert(data.message || 'Failed to add to cart');
                }
            } catch (err) {
                alert('Server error');
            }
        }
    </script>

</body>
</html>
