<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Wishlist</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    
    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        body {
            background-color: var(--off-white);
            color: var(--primary-black);
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .container-minimal {
            max-width: 1400px;
            margin: 60px auto;
            padding: 0 5%;
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            text-transform: uppercase;
            letter-spacing: -1px;
            margin-bottom: 50px;
        }

        .wishlist-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
        }

        .wishlist-card {
            position: relative;
            margin-bottom: 40px;
        }

        .img-box {
            aspect-ratio: 3/4;
            background: #f9f9f9;
            overflow: hidden;
            position: relative;
            margin-bottom: 15px;
        }

        .product-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .wishlist-card:hover .product-img {
            transform: scale(1.05);
        }

        .remove-icon {
            position: absolute;
            top: 15px;
            right: 15px;
            background: none;
            border: none;
            font-size: 14px;
            cursor: pointer;
            z-index: 10;
            color: #000;
            opacity: 0;
            transition: 0.3s;
        }

        .wishlist-card:hover .remove-icon {
            opacity: 1;
        }

        .info-box {
            font-size: 0.75rem;
            line-height: 1.6;
        }

        .p-name {
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 400;
            display: block;
            margin-bottom: 5px;
        }

        .p-price {
            font-weight: 600;
            display: block;
            margin-bottom: 15px;
        }

        .btn-black-minimal {
            display: block;
            width: 100%;
            padding: 12px;
            border: 1px solid #000;
            background: transparent;
            color: #000;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-black-minimal:hover {
            background: #000;
            color: #fff;
        }

        .empty-wrap {
            padding: 100px 0;
            text-align: center;
        }

        .empty-wrap p {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #999;
            margin-bottom: 30px;
        }

        .underline-link {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
            text-decoration: underline;
            color: #000;
        }

        /* Zara Style Notifications */
        .zara-toast { background: #000 !important; color: #fff !important; border-radius: 0 !important; font-family: 'Inter', sans-serif !important; font-size: 0.65rem !important; text-transform: uppercase !important; letter-spacing: 2px !important; padding: 15px 40px !important; width: 100% !important; max-width: 600px !important; margin-top: 20px !important; box-shadow: 0 10px 40px rgba(0,0,0,0.2) !important; }

        @media (max-width: 1024px) {
            .wishlist-grid { grid-template-columns: repeat(3, 1fr); }
        }

        @media (max-width: 768px) {
            .wishlist-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
            .remove-icon { opacity: 1; }
        }
    </style>
</head>
<body>

    <%- include('../partials/user/header') %>

    <div class="container-minimal">
        <h1 class="page-title">Wishlist</h1>

        <% if (wishlist.length > 0) { %>
            <div class="wishlist-grid">
                <% wishlist.forEach(item => { %>
                    <% if (item.productId) { %>
                        <div class="wishlist-card" id="card-<%= item.productId._id %>">
                            <button class="remove-icon" onclick="removeFromWishlist('<%= item.productId._id %>')">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                            
                            <a href="/product/<%= item.productId._id %>">
                                <div class="img-box">
                                    <img src="<%= item.productId.images[0] %>" alt="<%= item.productId.name %>" class="product-img">
                                </div>
                            </a>

                            <div class="info-box">
                                <a href="/product/<%= item.productId._id %>" style="text-decoration:none; color:inherit;">
                                    <span class="p-name"><%= item.productId.name %></span>
                                </a>
                                <span class="p-price">
                                    <% if (item.productId.offerPrice) { %>
                                        <span style="color:#e53935;">₹<%= item.productId.offerPrice.toLocaleString('en-IN') %></span>
                                        <span style="text-decoration:line-through; color:#999; font-size:0.65rem; margin-left:5px; font-weight:400;">₹<%= item.productId.price.toLocaleString('en-IN') %></span>
                                    <% } else if (item.productId.discount > 0) { %>
                                        <span style="color:#e53935;">₹<%= Math.round(item.productId.price - (item.productId.price * item.productId.discount / 100)).toLocaleString('en-IN') %></span>
                                        <span style="text-decoration:line-through; color:#999; font-size:0.65rem; margin-left:5px; font-weight:400;">₹<%= item.productId.price.toLocaleString('en-IN') %></span>
                                    <% } else { %>
                                        ₹<%= item.productId.price.toLocaleString('en-IN') %>
                                    <% } %>
                                </span>
                                
                                <button class="btn-black-minimal" 
                                    data-variant-id="<%= item.variantId ? item.variantId.toString() : '' %>"
                                    onclick="addToCart('<%= item.productId._id %>', this)">
                                    Add to Bag
                                </button>
                            </div>
                        </div>
                    <% } %>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-wrap">
                <p>Your wishlist is empty.</p>
                <a href="/products" class="underline-link">Go to boutique</a>
            </div>
        <% } %>
    </div>

    <%- include('../partials/user/footer') %>

    <script>
        function showToast(msg, type = 'success') {
            Toastify({
                text: (msg || "").toUpperCase(),
                duration: 3000,
                gravity: "top",
                position: "center",
                style: { 
                    background: type === 'success' ? "#000" : "#ff0000", 
                    borderRadius: "0px",
                    fontSize: "0.7rem",
                    letterSpacing: "1.5px",
                    fontWeight: "500",
                    fontFamily: "'Inter', sans-serif",
                    padding: "15px 40px"
                }
            }).showToast();
        }

        async function addToCart(productId, btn) {
            try {
                // Use stored variantId from wishlist entry if available
                const variantId = (btn && btn.dataset.variantId) ? btn.dataset.variantId : null;
                const response = await fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, variantId, quantity: 1 })
                });
                const data = await response.json();
                if (data.success) {
                    showToast('Added to bag');
                    if (typeof updateCartBadge === 'function') updateCartBadge(data.cartCount);
                } else {
                    showToast(data.msg || 'Error');
                }
            } catch (error) { console.error(error); }
        }

        async function removeFromWishlist(productId) {
            try {
                const res = await fetch('/wishlist/remove', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId })
                });
                const data = await res.json();
                if (data.success) {
                    document.getElementById(`card-${productId}`).remove();
                    showToast('Removed from wishlist');
                    if (typeof updateWishlistBadge === 'function') updateWishlistBadge(data.wishlistCount);
                    if(document.querySelectorAll('.wishlist-card').length === 0) {
                        document.querySelector('.container-minimal').innerHTML = `
                            <h1 class="page-title">Wishlist</h1>
                            <div class="empty-wrap">
                                <p>Your wishlist is empty.</p>
                                <a href="/products" class="underline-link">Go to boutique</a>
                            </div>
                        `;
                    }
                }

            } catch (error) { console.error(error); }
        }
    </script>
</body>
</html>