<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Verify Your Account</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    
    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--primary-black);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            -webkit-font-smoothing: antialiased;
        }

        .verify-wrapper {
            width: 100%;
            max-width: 400px;
            padding: 40px;
            text-align: center;
        }

        .header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            text-transform: uppercase;
            letter-spacing: -1px;
            margin-bottom: 15px;
        }

        .instruction {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--text-gray);
            line-height: 1.8;
            margin-bottom: 40px;
        }

        .otp-grid {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 30px;
        }

        .otp-field {
            width: 100%;
            aspect-ratio: 1/1.2;
            border: none;
            border-bottom: 1.5px solid #000;
            text-align: center;
            font-size: 1.5rem;
            font-weight: 300;
            outline: none;
            background: transparent;
        }

        .timer-row {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 40px;
            font-weight: 600;
        }

        .btn-verify {
            width: 100%;
            background: #000;
            color: #fff;
            padding: 18px;
            border: none;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 3px;
            cursor: pointer;
            margin-bottom: 30px;
        }

        .resend-box {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-gray);
        }

        .resend-link {
            color: #000;
            font-weight: 700;
            text-decoration: underline;
            cursor: pointer;
        }

        .back-link {
            display: inline-block;
            margin-top: 40px;
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-decoration: underline;
            color: #999;
        }
    </style>
</head>
<body>

    <div class="verify-wrapper">
        <div class="header">
            <div style="font-family: 'Playfair Display'; font-size: 1.2rem; letter-spacing: 4px; margin-bottom: 50px; cursor: pointer;" onclick="location.href='/'">SNOVA</div>
            <h1>Verification</h1>
        </div>
        <p class="instruction">We have sent a 6-digit access code<br>to your registered email address.</p>

        <form id="otpForm" onsubmit="verifyOtp(); return false;">
            <div class="otp-grid">
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
            </div>

            <div class="timer-row">
                EXPIRING IN <span id="timer" style="color: #000;">00:59</span>
            </div>

            <button type="submit" class="btn-verify">Authenticate</button>
        </form>

        <div class="resend-box">
            DIDN'T RECEIVE THE CODE? <span class="resend-link" onclick="resendOTP()">RESEND</span>
        </div>

        <a href="/login" class="back-link">Return to login</a>
    </div>

    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
        let timeLeft = 59;
        const timerElement = document.getElementById('timer');
        let countdown;

        function startTimer() {
            if (countdown) clearInterval(countdown);
            timeLeft = 59;
            countdown = setInterval(() => {
                if (timeLeft <= 0) {
                    clearInterval(countdown);
                    timerElement.innerText = "EXPIRED";
                    timerElement.style.color = "red";
                } else {
                    timeLeft--;
                    timerElement.innerText = `00:${timeLeft < 10 ? '0'+timeLeft : timeLeft}`;
                }
            }, 1000);
        }
        startTimer();

        const inputs = document.querySelectorAll('.otp-field');
        inputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                if (e.target.value.length === 1 && index < inputs.length - 1) inputs[index + 1].focus();
            });
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !e.target.value && index > 0) inputs[index - 1].focus();
            });
        });

        async function verifyOtp() {
            let otp = "";
            inputs.forEach(i => otp += i.value);
            try {
                const res = await fetch('/verify-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ otp })
                });
                const data = await res.json();
                if (data.success) {
                    Toastify({ text: "AUTHENTICATED", duration: 2000, gravity: "top", position: "right", backgroundColor: "#000" }).showToast();
                    setTimeout(() => window.location.href = data.redirectUrl, 1000);
                } else {
                    Toastify({ text: data.message || "INVALID CODE", duration: 3000, gravity: "top", position: "right", backgroundColor: "#d32f2f" }).showToast();
                }
            } catch (err) { console.error(err); }
        }

        async function resendOTP() {
            startTimer();
            try {
                const res = await fetch('/resend-otp', { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    Toastify({ text: "CODE RESENT", duration: 2000, gravity: "top", position: "right", backgroundColor: "#000" }).showToast();
                }
            } catch (err) { console.error(err); }
        }
    </script>
</body>
</html>