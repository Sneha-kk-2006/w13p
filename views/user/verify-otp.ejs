<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Verify Identity</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    
    <style>
        :root {
            --primary-black: #000000;
            --off-white: #ffffff;
            --text-gray: #666;
            --border-gray: #e5e5e5;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', sans-serif; }
        body { background-color: var(--off-white); color: var(--primary-black); min-height: 100vh; -webkit-font-smoothing: antialiased; display: flex; align-items: center; justify-content: center; }

        .form-wrapper { width: 100%; max-width: 400px; padding: 40px; }

        .header { margin-bottom: 50px; }
        .header h1 { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 400; letter-spacing: -1px; text-transform: uppercase; margin-bottom: 15px; }
        .header p { font-size: 0.7rem; color: var(--text-gray); text-transform: uppercase; letter-spacing: 2px; line-height: 1.6; }

        .form-group { margin-bottom: 35px; }
        .form-group label { display: block; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px; font-weight: 600; }
        .form-group input { width: 100%; padding: 12px 0; border: none; border-bottom: 1px solid var(--primary-black); font-size: 0.9rem; outline: none; background: transparent; }

        .otp-grid { display: flex; justify-content: space-between; gap: 10px; margin-bottom: 40px; }
        .otp-field { width: 100%; aspect-ratio: 1/1.2; border: none; border-bottom: 1.5px solid #000; text-align: center; font-size: 1.5rem; font-weight: 300; outline: none; background: transparent; }

        .timer-row { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 40px; font-weight: 600; color: var(--text-gray); }

        .btn-minimal { width: 100%; padding: 20px; background: var(--primary-black); color: var(--off-white); border: 1px solid var(--primary-black); text-transform: uppercase; letter-spacing: 3px; font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: 0.3s; margin-top: 20px; }
        .btn-minimal:hover { background: transparent; color: var(--primary-black); }

        .footer-links { margin-top: 40px; text-align: center; }
        .resend-box { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-gray); margin-bottom: 20px; }
        .resend-link { color: #000; font-weight: 700; text-decoration: underline; cursor: pointer; opacity: 0.5; pointer-events: none; }
        .resend-link.active { opacity: 1; pointer-events: auto; }

        .back-link { display: inline-block; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: #000; text-decoration: none; font-weight: 600; border-bottom: 1px solid transparent; transition: 0.3s; }
        .back-link:hover { border-bottom: 1px solid #000; }
    </style>
</head>
<body>
    <div class="form-wrapper">
        <header class="header">
            <div onclick="location.href='/'" style="cursor: pointer; font-family: 'Playfair Display', serif; font-size: 1.5rem; letter-spacing: 4px; margin-bottom: 60px; text-align: center;">SNOVA</div>
            <h1>Verify Identity</h1>
            <p>Enter the unique secure signature transmitted to your contact address.</p>
        </header>

        <form id="otpForm" onsubmit="verifyOtp(); return false;">
            <div class="otp-grid">
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
                <input type="text" class="otp-field" maxlength="1" inputmode="numeric" required>
            </div>
            
            <div class="timer-row">
                Authentication expires in <span id="timer" style="color: #000;">01:00</span>
            </div>

            <button type="submit" class="btn-minimal">Authorize Entry</button>
        </form>

        <div class="footer-links">
            <div class="resend-box">
                Didn't receive the code? <span id="resendBtn" class="resend-link" onclick="resendOTP()">Resend</span>
            </div>
            <a href="/login" class="back-link">Return to Identity Entry</a>
        </div>
    </div>

    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
        let timeLeft = 60;
        let countdown;
        const timerElement = document.getElementById('timer');
        const resendBtn = document.getElementById('resendBtn');
        const inputs = document.querySelectorAll('.otp-field');

        function startTimer() {
            if (countdown) clearInterval(countdown);
            timeLeft = 60;
            resendBtn.classList.remove('active');
            countdown = setInterval(() => {
                if (timeLeft <= 0) {
                    clearInterval(countdown);
                    timerElement.innerText = "EXPIRED";
                    resendBtn.classList.add('active');
                } else {
                    timeLeft--;
                    timerElement.innerText = `00:${timeLeft < 10 ? '0'+timeLeft : timeLeft}`;
                }
            }, 1000);
        }
        startTimer();

        inputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                // Ensure only numbers
                e.target.value = e.target.value.replace(/[^0-9]/g, '');
                
                if (e.target.value.length === 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            });
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !e.target.value && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });

        async function verifyOtp() {
            let otp = "";
            inputs.forEach(i => otp += i.value);
            try {
                const res = await fetch('/verify-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ otp })
                });
                const data = await res.json();
                if (data.success) {
                    showToast("AUTHENTICATED", "#000");
                    setTimeout(() => window.location.href = data.redirectUrl, 1000);
                } else {
                    showToast(data.message || "INVALID CODE", "#d32f2f");
                }
            } catch (err) { console.error(err); }
        }

        async function resendOTP() {
            startTimer();
            try {
                const res = await fetch('/resend-otp', { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    showToast("CODE RESENT", "#000");
                }
            } catch (err) { console.error(err); }
        }

        function showToast(msg, bg) {
            Toastify({
                text: msg.toUpperCase(),
                duration: 3000,
                gravity: "top",
                position: "center",
                style: {
                    background: "#000",
                    color: "#fff",
                    borderRadius: "0",
                    fontSize: "10px",
                    letterSpacing: "1px",
                    fontFamily: "Inter"
                }
            }).showToast();
        }
    </script>
</body>
</html>