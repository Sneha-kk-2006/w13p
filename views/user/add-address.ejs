<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Add Address Popup</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style>
        :root {
            --primary-green: #10b981;
            --dark-blue-bg: #1a2332;
            --text-dark: #111111;
            --text-gray: #666;
            --input-bg: #bcc8cd;
        }

        /* Overlay Background */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7); /* Dim the background */
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        /* Popup Container */
        .modal-card {
            background: white;
            width: 90%;
            max-width: 600px;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            border-bottom: 1px solid #eee;
            padding-bottom: 15px;
        }

        .modal-header h2 {
            font-size: 22px;
            font-weight: 700;
        }

        .close-btn {
            cursor: pointer;
            color: var(--text-gray);
        }

        /* Form Layout */
        .address-form {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .full-width {
            grid-column: span 2;
        }

        .field-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .field-group label {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-dark);
        }

        .field-group label span {
            color: #ef4444; /* Required asterisk */
        }

        /* Input Styling to match your reference */
        .input-box {
            background: var(--input-bg);
            padding: 10px 15px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .input-box input, .input-box select {
            background: transparent;
            border: none;
            outline: none;
            width: 100%;
            font-size: 14px;
            font-weight: 600;
            color: #111;
        }

        .input-box select {
            cursor: pointer;
        }

        /* Checkbox Styling */
        .checkbox-container {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
            font-size: 14px;
            font-weight: 600;
        }

        .checkbox-container input {
            accent-color: var(--primary-green);
            width: 18px;
            height: 18px;
        }

        /* Footer Buttons */
        .modal-footer {
            margin-top: 30px;
            display: flex;
            gap: 15px;
        }

        .btn-save {
            flex: 2;
            background: #111;
            color: white;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-save:hover {
            background: #333;
        }

        .btn-cancel {
            flex: 1;
            background: #f1f5f9;
            color: var(--text-gray);
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: bold;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="modal-overlay" id="addressModal">
        <div class="modal-card">
            
            <div class="modal-header">
                <h2>Add New Address</h2>
                <span class="material-symbols-outlined close-btn" onclick="toggleModal()">close</span>
            </div>

            <form class="address-form">
                
                <div class="field-group">
                    <label>Type <span>*</span></label>
                    <div class="input-box">
                        <span class="material-symbols-outlined">home</span>
                        <select required>
                            <option value="home">Home</option>
                            <option value="work">Work</option>
                            <option value="others">Others</option>
                        </select>
                    </div>
                </div>

                <div class="field-group">
                    <label>Full Name <span>*</span></label>
                    <div class="input-box">
                        <span class="material-symbols-outlined">person</span>
                        <input type="text" placeholder="e.g. Jane Doe" required>
                    </div>
                </div>

                <div class="field-group full-width">
                    <label>Address Line 1 <span>*</span></label>
                    <div class="input-box">
                        <span class="material-symbols-outlined">location_on</span>
                        <input type="text" placeholder="Street address, house number, P.O. box" required>
                    </div>
                </div>

                <div class="field-group full-width">
                    <label>Address Line 2 (optional)</label>
                    <div class="input-box">
                        <span class="material-symbols-outlined">apartment</span>
                        <input type="text" placeholder="Apartment, suite, unit, building, floor">
                    </div>
                </div>

                <div class="field-group">
                    <label>City <span>*</span></label>
                    <div class="input-box">
                        <input type="text" placeholder="e.g. Malappuram" required>
                    </div>
                </div>

                <div class="field-group">
                    <label>State <span>*</span></label>
                    <div class="input-box">
                        <input type="text" placeholder="e.g. Kerala" required>
                    </div>
                </div>

                <div class="field-group">
                    <label>Pincode <span>*</span></label>
                    <div class="input-box">
                        <input type="text" placeholder="673641" required>
                    </div>
                </div>

                <div class="field-group">
                    <label>Country <span>*</span></label>
                    <div class="input-box">
                        <input type="text" value="India" required>
                    </div>
                </div>

                <div class="field-group full-width">
                    <label>Phone Number <span>*</span></label>
                    <div class="input-box">
                        <span class="material-symbols-outlined">call</span>
                        <input type="tel" placeholder="+91 9073105805" required>
                    </div>
                </div>

                <div class="checkbox-container full-width">
                    <input type="checkbox" id="setDefault">
                    <label for="setDefault">Set as Default Address</label>
                </div>

                <div class="modal-footer full-width">
                    <button type="submit" class="btn-save">Save Changes</button>
                    <button type="button" class="btn-cancel" onclick="toggleModal()">Cancel</button>
                </div>

            </form>
        </div>
    </div>

    <script>
        // Simple function to close the popup for demonstration
        function toggleModal() {
            const modal = document.getElementById('addressModal');
            modal.style.display = (modal.style.display === 'none') ? 'flex' : 'none';
        }
    </script>
</body>
</html>