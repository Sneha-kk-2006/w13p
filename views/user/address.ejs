<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Manage Addresses</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style>
        :root {
            --primary-green: #10b981;
            --dark-blue-bg: #1a2332;
            --sidebar-teal: #c9e2e2;
            --text-dark: #111111;
            --text-gray: #64748b;
            --input-bg: #bcc8cd;
            --danger-red: #ef4444;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', sans-serif; }
        body { background-color: #0f172a; min-height: 100vh; }

        /* --- UI Components --- */
        .navbar { background: #000; padding: 15px 5%; display: flex; justify-content: space-between; align-items: center; color: white; }
        .logo { color: var(--primary-green); font-size: 24px; font-weight: bold; text-decoration: none; }
        
        .dashboard-container { display: flex; width: 95%; max-width: 1200px; margin: 30px auto; background: var(--dark-blue-bg); border-radius: 12px; overflow: hidden; min-height: 70vh; }
        .sidebar { width: 260px; background: var(--sidebar-teal); padding: 30px 20px; display: flex; flex-direction: column; gap: 12px; }
        .side-link { display: flex; align-items: center; gap: 12px; padding: 12px 20px; background: white; border-radius: 10px; text-decoration: none; color: var(--text-dark); font-weight: 600; }
        .side-link.active { background: #9aa7ad; }

        .main-content { flex: 1; padding: 40px; background: #f8fafc; }
        .address-card { background: white; border-radius: 20px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }

        /* --- Address Items --- */
        .address-item { border: 1.5px solid #e2e8f0; border-radius: 12px; padding: 20px; margin-bottom: 20px; }
        .type-badge { font-size: 10px; font-weight: 800; background: #e2e8f0; padding: 3px 10px; border-radius: 5px; text-transform: uppercase; }
        .address-footer { margin-top: 15px; display: flex; gap: 20px; font-size: 13px; font-weight: 700; color: var(--text-gray); }
        .action-link { cursor: pointer; text-decoration: none; }
        .action-link:hover { color: var(--primary-green); }

        /* --- Modal System --- */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.6); display: none;
            align-items: center; justify-content: center; z-index: 1000;
        }
        .modal-card {
            background: white; width: 95%; max-width: 650px; border-radius: 20px;
            padding: 30px; max-height: 90vh; overflow-y: auto; position: relative;
        }
        .modal-header { display: flex; justify-content: space-between; margin-bottom: 20px; border-bottom: 1px solid #eee; padding-bottom: 10px; }
        
        /* --- Form Elements --- */
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .full-width { grid-column: span 2; }
        
        .field-label { font-size: 12px; font-weight: 700; color: var(--text-dark); margin-bottom: 5px; display: block; }
        .field-label span { color: var(--danger-red); }

        .input-box { background: var(--input-bg); padding: 12px; border-radius: 10px; display: flex; align-items: center; gap: 10px; }
        .input-box input, .input-box select { background: transparent; border: none; outline: none; width: 100%; font-weight: 600; font-size: 14px; color: #1e293b; }
        
        .btn-main { background: #111; color: white; padding: 14px; border: none; border-radius: 10px; cursor: pointer; font-weight: bold; width: 100%; margin-top: 10px; }
        .btn-add-new { background: var(--primary-green); width: auto; padding: 10px 20px; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; }

        .modal-footer { display: flex; gap: 10px; margin-top: 20px; }
        .btn-cancel { background: #eee; color: #333; }

        /* --- Delete Specific --- */
        .delete-modal { max-width: 400px; text-align: center; }
        .delete-icon { font-size: 50px; color: var(--danger-red); margin-bottom: 15px; }
        .btn-danger { background: var(--danger-red); }


            .side-btn {
            background: white;
            padding: 12px 15px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: #333;
            font-weight: 600;
            border: 1px solid #ddd;
        }
    </style>
</head>
<body>
  <%- include('../partials/user/header1') %> 


    <div class="dashboard-container">
           <aside class="sidebar">
                <div class="side-btn active">
                    <span class="material-symbols-outlined">person</span> Profile
                </div>
                <div class="side-btn">
                    <span class="material-symbols-outlined">location_on</span> Address
                </div>
                <div class="side-btn">
                    <span class="material-symbols-outlined">package</span> My Orders
                </div>
                <div class="side-btn">
                    <span class="material-symbols-outlined">favorite</span> Wishlist
                </div>
                <div class="side-btn">
                    <span class="material-symbols-outlined">account_balance_wallet</span> Wallet
                </div>
            </aside>
        <main class="main-content">
            <div class="address-card">
                <div style="display:flex; justify-content:space-between; margin-bottom:30px;">
                    <h2>My Addresses</h2>
                    <button class="btn-add-new" onclick="openModal('addModal')">+ Add New</button>
                </div>

                <div class="address-item">
                    <span class="type-badge">Home</span>
                    <div style="margin-top:10px;">
                        <strong>sneha kk</strong><br>
                       kizhisseri, kondotty (po) 676122<br>
                       Malappuram<br>
                        India | +1 (555) 248-1930
                    </div>
                    <div class="address-footer">
                        <span class="action-link" onclick="openModal('editModal')">Edit</span>
                        <span class="action-link" style="color:var(--danger-red)" onclick="openModal('deleteModal')">Delete</span>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div class="modal-overlay" id="addModal">
        <div class="modal-card">
            <div class="modal-header"><h3>Add New Address</h3><span class="material-symbols-outlined" style="cursor:pointer" onclick="closeModal('addModal')">close</span></div>
            <form class="form-grid">
                <div class="full-width">
                    <label class="field-label">Type <span>*</span></label>
                    <div class="input-box">
                        <select>
                            <option>Home</option>
                            <option>Work</option>
                            <option>Others</option>
                        </select>
                    </div>
                </div>
                <div class="full-width">
                    <label class="field-label">Full Name <span>*</span></label>
                    <div class="input-box"><input type="text" placeholder="Enter your Name"></div>
                </div>
                <div class="full-width">
                    <label class="field-label">Phone Number <span>*</span></label>
                    <div class="input-box"><input type="tel" placeholder="Enter your Mobile Number"></div>
                </div>
                <div class="full-width">
                    <label class="field-label">Address Line 1 <span>*</span></label>
                    <div class="input-box"><span class="material-symbols-outlined" style="font-size: 18px;">location_on</span><input type="text" placeholder="Eg :- Street address, house number, P.O. box"></div>
                </div>
                <div class="full-width">
                    <label class="field-label">Address Line 2 (Optional)</label>
                    <div class="input-box"><input type="text" placeholder="Eg :- Apartment, suite, unit, building, floor, etc."></div>
                </div>
                <div>
                    <label class="field-label">City <span>*</span></label>
                    <div class="input-box"><input type="text" placeholder="Enter your City Name"></div>
                </div>
                <div>
                    <label class="field-label">State / Province <span>*</span></label>
                    <div class="input-box">
                        <select>
                            <option>Select State</option>
                            <option>Kerala</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label class="field-label">Pincode <span>*</span></label>
                    <div class="input-box"><input type="text" placeholder="Enter pincode"></div>
                </div>
                <div>
                    <label class="field-label">Country <span>*</span></label>
                    <div class="input-box"><input type="text" value="United States"></div>
                </div>
                
                <div class="modal-footer full-width">
                    <button type="submit" class="btn-main">Add Address</button>
                    <button type="button" class="btn-main btn-cancel" onclick="closeModal('addModal')">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal-overlay" id="editModal">
        <div class="modal-card">
            <div class="modal-header"><h3>Edit Address</h3><span class="material-symbols-outlined" style="cursor:pointer" onclick="closeModal('editModal')">close</span></div>
            <form class="form-grid">
                <div class="full-width">
                    <label class="field-label">Type <span>*</span></label>
                    <div class="input-box">
                        <select>
                            <option selected>Home</option>
                            <option>Work</option>
                            <option>Others</option>
                        </select>
                    </div>
                </div>
                <div class="full-width">
                    <label class="field-label">Full Name <span>*</span></label>
                    <div class="input-box"><input type="text" value="Busthan Thasreef"></div>
                </div>
                <div class="full-width">
                    <label class="field-label">Phone Number <span>*</span></label>
                    <div class="input-box"><input type="tel" value="+1 (555) 248-1930"></div>
                </div>
                <div class="full-width">
                    <label class="field-label">Address Line 1 <span>*</span></label>
                    <div class="input-box"><span class="material-symbols-outlined" style="font-size: 18px;">location_on</span><input type="text" value="Chengarayi house, Elankur (po) 676122"></div>
                </div>
                <div class="full-width">
                    <label class="field-label">Address Line 2 (Optional)</label>
                    <div class="input-box"><input type="text" value="Niranna Parambu near milma"></div>
                </div>
                <div>
                    <label class="field-label">City <span>*</span></label>
                    <div class="input-box"><input type="text" value="Manjeri"></div>
                </div>
                <div>
                    <label class="field-label">State / Province <span>*</span></label>
                    <div class="input-box"><input type="text" value="Kerala"></div>
                </div>
                <div>
                    <label class="field-label">Pincode <span>*</span></label>
                    <div class="input-box"><input type="text" value="676122"></div>
                </div>
                <div>
                    <label class="field-label">Country <span>*</span></label>
                    <div class="input-group"><div class="input-box"><input type="text" value="India"></div></div>
                </div>

                <div class="modal-footer full-width">
                    <button type="submit" class="btn-main">Save Changes</button>
                    <button type="button" class="btn-main btn-cancel" onclick="closeModal('editModal')">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal-overlay" id="deleteModal">
        <div class="modal-card delete-modal">
            <span class="material-symbols-outlined delete-icon">delete_forever</span>
            <h3>Delete Address?</h3>
            <p style="color:var(--text-gray); margin: 10px 0 20px;">Are you sure you want to remove this address? This action cannot be undone.</p>
            <div style="display:flex; gap:10px;">
                <button class="btn-main btn-danger" onclick="closeModal('deleteModal')">Yes, Delete</button>
                <button class="btn-main" style="background:#eee; color:#333;" onclick="closeModal('deleteModal')">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        function openModal(id) { document.getElementById(id).style.display = 'flex'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }
        
        window.onclick = function(event) {
            if (event.target.className === 'modal-overlay') {
                event.target.style.display = 'none';
            }
        }
    </script>
</body>
</html>