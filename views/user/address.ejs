<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | Addresses</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--primary-black);
            -webkit-font-smoothing: antialiased;
        }

        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }

        .main-content {
            flex: 1;
            padding: 60px 5%;
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            text-transform: uppercase;
            letter-spacing: -1px;
            margin-bottom: 50px;
        }

        .address-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
        }

        .address-card-minimal {
            border: 0.5px solid var(--border-light);
            padding: 30px;
            position: relative;
            background: #fbfbfb;
            transition: 0.3s;
        }

        .address-card-minimal:hover {
            border-color: #000;
        }

        .address-type {
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            margin-bottom: 20px;
            display: block;
            color: #999;
        }

        .address-details {
            font-size: 0.75rem;
            line-height: 1.8;
            letter-spacing: 0.5px;
            margin-bottom: 25px;
            text-transform: uppercase;
        }

        .badge-default {
            position: absolute;
            top: 25px;
            right: 30px;
            font-size: 0.55rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
        }

        .card-actions {
            display: flex;
            gap: 20px;
            border-top: 0.5px solid var(--border-light);
            padding-top: 20px;
        }

        .action-link {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
            text-decoration: underline;
            cursor: pointer;
            color: #000;
            background: none;
            border: none;
        }

        .btn-add-minimal {
            display: inline-block;
            margin-top: 40px;
            padding: 15px 40px;
            border: 1px solid #000;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            color: #000;
            text-decoration: none;
            cursor: pointer;
            background: transparent;
        }

        .btn-add-minimal:hover {
            background: #000;
            color: #fff;
        }

        /* Modal */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(255,255,255,0.95);
            z-index: 1000;
            display: none;
            align-items: center;
            justify-content: center;
        }

        .modal-box {
            width: 90%;
            max-width: 500px;
            padding: 40px;
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-box h3 {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            text-transform: uppercase;
            margin-bottom: 30px;
        }

        .modal-form input, .modal-form textarea {
            width: 100%;
            border: none;
            border-bottom: 1px solid #000;
            padding: 12px 0;
            font-size: 0.8rem;
            outline: none;
            background: transparent;
            margin-bottom: 15px;
            text-transform: uppercase;
        }

        .error-msg {
            font-size: 0.55rem;
            color: #d32f2f;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: -10px;
            margin-bottom: 15px;
            display: block;
        }

        @media (max-width: 768px) {
            .dashboard-container { flex-direction: column; }
        }
    </style>
</head>
<body>

    <%- include('../partials/user/header') %>

    <div class="dashboard-container">
        <% var activePage = 'address'; %>
        <%- include('../partials/user/sidebar', { activePage: 'address' }) %>

        <main class="main-content">
            <h1 class="page-title">MY ADDRESSES</h1>

            <div class="address-list">
                <% if(addresses.length > 0) { %>
                    <% addresses.forEach(address => { %>
                        <div class="address-card-minimal">
                            <span class="address-type"><%= address.type %> Address</span>
                            <% if(address.isDefault) { %>
                                <span class="badge-default"><i class="fa-solid fa-circle-check"></i> Default</span>
                            <% } %>

                            <div class="address-details">
                                <p><strong><%= address.fullName %></strong></p>
                                <p><%= address.addressline1 %></p>
                                <% if(address.addressline2){ %><p><%= address.addressline2 %></p><% } %>
                                <p><%= address.city %>, <%= address.state %></p>
                                <p><%= address.country %> - <%= address.pincode %></p>
                                <p>T: <%= address.phone %></p>
                            </div>

                            <div class="card-actions">
                                <button class="action-link" onclick='editAddress(<%- JSON.stringify(address) %>)'>Edit</button>
                                <button class="action-link" style="color: #999;" onclick="deleteAddress('<%= address._id %>')">Delete</button>
                                <% if(!address.isDefault) { %>
                                    <a href="/setDefaultAddress?id=<%= address._id %>" class="action-link">Set Default</a>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-xs uppercase tracking-widest text-gray-400">No addresses registered yet.</p>
                <% } %>
            </div>

            <button class="btn-add-minimal" onclick="openAddModal()">Add new address</button>
        </main>
    </div>

    <!-- Address Modal -->
    <div class="modal-overlay" id="addressModal">
        <div class="modal-box">
            <h3 class="flex justify-between items-center"><span id="modalTitle">ADDRESS DETAILS</span> <span onclick="closeModal()" class="cursor-pointer text-xl font-sans">&times;</span></h3>
            
            <form id="addressForm" action="/addAddress" method="POST" class="modal-form">
                <input type="hidden" name="id" id="addressId">

                <input type="text" name="type" id="type" placeholder="Type (Home / Work)">
                <span class="error-msg" id="typeError"></span>

                <input type="text" name="fullName" id="fullName" placeholder="Full Name">
                <span class="error-msg" id="nameError"></span>

                <input type="text" name="phone" id="phone" placeholder="Phone Number">
                <span class="error-msg" id="phoneError"></span>

                <textarea name="addressline1" id="addressline1" placeholder="Address Line 1" rows="1"></textarea>
                <span class="error-msg" id="addressError"></span>

                <input type="text" name="city" id="city" placeholder="City">
                <span class="error-msg" id="cityError"></span>

                <input type="text" name="state" id="state" placeholder="State">
                <span class="error-msg" id="stateError"></span>

                <input type="text" name="country" id="country" placeholder="Country">
                <span class="error-msg" id="countryError"></span>

                <input type="text" name="pincode" id="pincode" placeholder="Pincode">
                <span class="error-msg" id="pincodeError"></span>

                <button type="submit" class="btn-add-minimal w-full">Save Address</button>
            </form>
        </div>
    </div>

    <%- include('../partials/user/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
        function openAddModal() {
            document.getElementById("modalTitle").innerText = "ADD ADDRESS";
            document.getElementById("addressForm").action = "/addAddress";
            document.getElementById("addressForm").reset();
            document.getElementById("addressModal").style.display = "flex";
        }

        function editAddress(address) {
            document.getElementById("modalTitle").innerText = "EDIT ADDRESS";
            document.getElementById("addressForm").action = "/editAddress";
            document.getElementById("addressId").value = address._id;
            document.getElementById("type").value = address.type;
            document.getElementById("fullName").value = address.fullName;
            document.getElementById("phone").value = address.phone;
            document.getElementById("addressline1").value = address.addressline1;
            document.getElementById("city").value = address.city;
            document.getElementById("state").value = address.state;
            document.getElementById("country").value = address.country;
            document.getElementById("pincode").value = address.pincode;
            document.getElementById("addressModal").style.display = "flex";
        }

        function closeModal() { document.getElementById("addressModal").style.display = "none"; }

        document.getElementById("addressForm").addEventListener("submit", function(e) {
            let valid = true;
            document.querySelectorAll(".error-msg").forEach(el => el.innerText = "");
            
            const fields = ["fullName", "type", "phone", "addressline1", "city", "state", "country", "pincode"];
            fields.forEach(f => {
                if(!document.getElementById(f).value.trim()) {
                    valid = false;
                    document.getElementById(f.replace("fullName", "name").replace("addressline1", "address") + "Error").innerText = "Required";
                }
            });

            if(!valid) e.preventDefault();
        });

        function deleteAddress(id) {
            Swal.fire({
                title: 'Delete this address?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#000',
                confirmButtonText: 'Delete'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = "/deleteAddress?id=" + id;
                }
            });
        }
    </script>
</body>
</html>