<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SNOVA | My Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        :root {
            --primary-black: #000;
            --off-white: #fff;
            --text-gray: #666;
            --border-light: #eee;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--primary-black);
            -webkit-font-smoothing: antialiased;
        }

        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }

        .main-profile-content {
            flex: 1;
            padding: 60px 5%;
        }

        .profile-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            text-transform: uppercase;
            letter-spacing: -1px;
            margin-bottom: 50px;
        }

        .profile-section {
            max-width: 600px;
        }

        .avatar-box {
            display: flex;
            align-items: center;
            gap: 30px;
            margin-bottom: 50px;
        }

        .avatar-img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid #000;
        }

        .btn-minimal {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
            text-decoration: underline;
            background: none;
            border: none;
            cursor: pointer;
            color: #000;
        }

        .form-group {
            margin-bottom: 35px;
        }

        .form-group label {
            display: block;
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            margin-bottom: 10px;
            color: #999;
        }

        .info-val {
            font-size: 0.9rem;
            border-bottom: 1px solid #000;
            padding-bottom: 8px;
            display: block;
            width: 100%;
        }

        .section-header {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 1px solid #eee;
            margin-top: 60px;
        }

        /* Modal Overlay */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(255,255,255,0.95);
            z-index: 1000;
            display: none;
            align-items: center;
            justify-content: center;
        }

        .modal-box {
            width: 90%;
            max-width: 450px;
            padding: 40px;
        }

        .modal-box h3 {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            text-transform: uppercase;
            margin-bottom: 30px;
        }

        .modal-form input {
            width: 100%;
            border: none;
            border-bottom: 1px solid #000;
            padding: 12px 0;
            font-size: 0.85rem;
            outline: none;
            background: transparent;
            margin-bottom: 25px;
        }

        .btn-black {
            width: 100%;
            background: #000;
            color: #fff;
            padding: 18px;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            margin-top: 20px;
        }

        @media (max-width: 768px) {
            .dashboard-container { flex-direction: column; }
            .sidebar { width: 100%; height: auto; border-right: none; border-bottom: 1px solid #eee; padding: 30px; }
        }
    </style>
</head>
<body>

    <%- include('../partials/user/header') %>

    <div class="dashboard-container">
        <% var activePage = 'profile'; %>
        <%- include('../partials/user/sidebar', { activePage: 'profile' }) %>

        <main class="main-profile-content">
            <h1 class="profile-title">PERSONAL DETAILS</h1>

            <div class="profile-section">
                <div class="avatar-box">
                    <img id="profileImage" src="<%= user.profileImage ? user.profileImage : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) %>" class="avatar-img">
                    <div>
                        <button class="btn-minimal" onclick="openModal('editModal')">Upload Image</button>
                        <p style="font-size: 0.6rem; color: #999; margin-top: 8px;">Joined <%= new Date(user.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
                    </div>
                </div>

                <div class="form-group">
                    <label>Full Name</label>
                    <span class="info-val"><%= user.name %></span>
                </div>

                <div class="form-group">
                    <label>E-mail</label>
                    <span class="info-val"><%= user.email %></span>
                </div>

                <div class="form-group">
                    <label>Mobile Number</label>
                    <span class="info-val"><%= user.phone || 'NOT PROVIDED' %></span>
                </div>

                <button class="btn-minimal" onclick="openModal('editModal')">Edit Details</button>

                <div class="section-header">SAVED ADDRESSES</div>
                <div class="address-summary" style="margin-bottom: 30px;">
                    <% if (addresses && addresses.length > 0) { %>
                        <% addresses.forEach(addr => { %>
                            <div style="margin-bottom: 15px; padding: 15px; border: 1px solid #eee; position: relative;">
                                <span style="font-size: 0.55rem; text-transform: uppercase; letter-spacing: 1px; color: #999;"><%= addr.type %></span>
                                <p style="font-size: 0.8rem; font-weight: 600; margin: 5px 0;"><%= addr.fullName %></p>
                                <p style="font-size: 0.75rem; color: #666;"><%= addr.addressline1 %>, <%= addr.city %>, <%= addr.state %> - <%= addr.pincode %></p>
                                <% if(addr.isDefault) { %>
                                    <span style="position: absolute; top: 15px; right: 15px; font-size: 0.6rem; font-weight: 700;">DEFAULT</span>
                                <% } %>
                            </div>
                        <% }); %>
                        <a href="/address" class="btn-minimal" style="display: block; margin-top: 10px;">Manage All Addresses</a>
                    <% } else { %>
                        <p style="font-size: 0.75rem; color: #999;">No addresses saved yet.</p>
                        <a href="/address" class="btn-minimal" style="display: block; margin-top: 10px;">Add New Address</a>
                    <% } %>
                </div>

                <div class="section-header">SECURITY</div>
                <% if(!user.googleId) { %>
                    <a href="/changePassword" class="btn-minimal" style="display:inline-block;">Update Password</a>
                <% } else { %>
                    <p style="font-size: 0.7rem; color: #999;">Managed via Google Authentication</p>
                <% } %>

                <form action="/logout" method="POST" style="margin-top: 40px;">
                    <button type="submit" class="btn-minimal" style="color: #d32f2f;">Sign Out</button>
                </form>
            </div>
        </main>
    </div>

    <!-- Edit Modal -->
    <div class="modal-overlay" id="editModal">
        <div class="modal-box">
            <h3 class="flex justify-between items-center">Edit Profile <span onclick="closeModal('editModal')" class="cursor-pointer text-xl font-sans">&times;</span></h3>
            
            <form id="editProfileForm" action="/editProfile" method="POST" enctype="multipart/form-data" class="modal-form">
                <div class="mb-8 text-center">
                    <img id="modalImage" src="<%= user.profileImage ? user.profileImage : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) %>" class="avatar-img mx-auto mb-4">
                    <input id="profileFile" name="profileImage" type="file" accept="image/*" hidden onchange="previewImage(event)">
                    <label for="profileFile" class="btn-minimal cursor-pointer">Change Image</label>
                    <button type="button" class="btn-minimal ml-5" style="color: #999;" onclick="removeImage()">Remove</button>
                </div>
                <input type="hidden" name="removeProfileImage" id="removeProfileImage" value="false">

                <div class="mb-5">
                    <label style="font-size:0.6rem; color:#999; text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:5px;">Name</label>
                    <input type="text" name="name" id="name" value="<%= user.name %>" required>
                    <p id="nameError" class="text-[9px] text-red-500 uppercase"></p>
                </div>

                <div class="mb-5">
                    <label style="font-size:0.6rem; color:#999; text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:5px;">Email</label>
                    <input type="email" name="email" value="<%= user.email %>" required>
                </div>

                <div class="mb-5">
                    <label style="font-size:0.6rem; color:#999; text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:5px;">Mobile</label>
                    <input type="text" id="phone" name="phone" value="<%= user.phone %>" pattern="\d{10}">
                    <p id="numberError" class="text-[9px] text-red-500 uppercase"></p>
                </div>

                <button onclick="SubmitEditProfile()" type="button" class="btn-black">Apply Changes</button>
            </form>
        </div>
    </div>

    <%- include('../partials/user/footer') %>

    <script>
        function openModal(id) { document.getElementById(id).style.display = "flex"; }
        function closeModal(id) { document.getElementById(id).style.display = "none"; }

        function previewImage(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) { document.getElementById("modalImage").src = e.target.result; };
            reader.readAsDataURL(file);
        }

        function removeImage() {
            document.getElementById("modalImage").src = "https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.name) %>";
            document.getElementById("profileFile").value = "";
            document.getElementById("removeProfileImage").value = "true";
        }

        function SubmitEditProfile() {
            const phone = document.getElementById("phone").value.trim();
            const name = document.getElementById("name").value.trim();
            
            if (phone && phone.length !== 10) {
                document.getElementById("numberError").textContent = "Must be 10 digits";
                return;
            }
            if (name.length < 2) {
                document.getElementById("nameError").textContent = "Name too short";
                return;
            }
            document.getElementById("editProfileForm").submit();
        }
    </script>
</body>
</html>