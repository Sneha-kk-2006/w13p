<style>
    .sidebar {
        width: 300px;
        background: #fff;
        padding: 60px 40px;
        display: flex;
        flex-direction: column;
        border-right: 0.5px solid #eee;
        height: auto;
        min-height: calc(100vh - 80px);
    }

    .sidebar h3 {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #999;
        margin-bottom: 30px;
        font-weight: 700;
    }

    .side-link {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 12px 0;
        text-decoration: none;
        color: #000;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 500;
        border-bottom: 1px solid transparent;
        transition: 0.3s;
    }

    .side-link i, .side-link .material-symbols-outlined {
        font-size: 18px;
    }

    .side-link:hover {
        padding-left: 10px;
        color: #666;
    }

    .side-link.active {
        font-weight: 700;
        border-bottom: 1px solid #000;
    }

    @media (max-width: 768px) {
        .sidebar {
            width: 100% !important;
            min-height: auto !important;
            height: auto !important;
            border-right: none !important;
            border-bottom: 0.5px solid #eee !important;
            padding: 20px 16px !important;
            flex-direction: row !important;
            flex-wrap: wrap !important;
            gap: 8px !important;
            justify-content: center !important;
        }

        .sidebar h3 {
            width: 100% !important;
            text-align: center !important;
            margin-bottom: 15px !important;
        }

        .side-link {
            padding: 8px 14px !important;
            border-bottom: none !important;
            border-radius: 4px !important;
            background: #f5f5f5 !important;
            font-size: 0.7rem !important;
            gap: 8px !important;
        }

        .side-link:hover {
            padding-left: 14px !important;
        }

        .side-link.active {
            background: #000 !important;
            color: #fff !important;
        }
    }
</style>

<aside class="sidebar">
    <h3>PERSONAL AREA</h3>

    <a class="side-link <%= activePage === 'profile' ? 'active' : '' %>" href="/profile">
        <i class="fa-regular fa-user"></i> Profile
    </a>

    <a class="side-link <%= activePage === 'address' ? 'active' : '' %>" href="/address">
        <i class="fa-solid fa-location-dot"></i> Address
    </a>

    <a class="side-link <%= activePage === 'orders' ? 'active' : '' %>" href="/orders">
        <i class="fa-solid fa-bag-shopping"></i> Orders
    </a>

    <a class="side-link <%= activePage === 'wishlist' ? 'active' : '' %>" href="/wishlist">
        <i class="fa-regular fa-heart"></i> Wishlist
    </a>

    <a class="side-link <%= activePage === 'wallet' ? 'active' : '' %>" href="/wallet">
        <i class="fa-solid fa-wallet"></i> Wallet
    </a>
</aside>
