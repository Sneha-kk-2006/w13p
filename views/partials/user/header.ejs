<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

<style>
  /* Auth section specific styling */
  .auth-group {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .profile-icon-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: white;
    transition: color 0.3s ease;
  }

  .profile-icon-link:hover {
    color: var(--primary-green);
  }

  .login-link-btn {
    background: transparent;
    border: 1px solid var(--primary-green);
    color: var(--primary-green) !important;
    padding: 4px 12px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .login-link-btn:hover {
    background: var(--primary-green);
    color: white !important;
  }

  /* Ensuring navbar alignment */
  .nav-tools {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .nav-links a {
    color: white;
    text-decoration: none;
    font-size: 14px;
    cursor: pointer;
    transition: 0.3s;
}

.search-bar input {
    background: transparent;
    border: none;
    color: white;
    outline: none;
    width: 180px;
    font-size: 12px;
}
.auth-group{
display:flex;
align-items:center;
gap:10px;
}

.profile-box{
display:flex;
align-items:center;
gap:8px;
text-decoration:none;
color:white;
}

.nav-profile-img{
width:32px;
height:32px;
border-radius:50%;
object-fit:cover;
border:2px solid #00c46b;
}

.nav-username{
font-size:14px;
font-weight:500;
}

.login-link-btn{
background:#00c46b;
color:white;
padding:6px 14px;
border-radius:6px;
text-decoration:none;
}
.nav-profile-img{
width:32px;
height:32px;
border-radius:50%;
object-fit:cover;
border:2px solid #00c46b;
}

</style>
<link rel="stylesheet" href="/style.css">

<header class="navbar">
  <div class="logo">SNOVA</div>
  <nav class="nav-links">
    <a href="/">Home</a>
    <a href="/products">Products</a>
    <a href="#">Categories</a>
  </nav>
  
  <div class="nav-tools">
    <div class="search-bar">
      <input type="text" placeholder="Search dresses by category...">
    </div>
    
    <div style="position:relative; cursor:pointer; font-size: 18px;" title="Wishlist">
      ❤️<span id="wishlist-count" style="position:absolute; top:-10px; right:-10px; background:var(--danger-red); border-radius:50%; padding:2px 6px; font-size:10px; color:white;">0</span>
    </div>
<div class="auth-group">

  <% if (user) { %>

    <a href="/profile" class="profile-box">

      <img 
        src="<%= user.profileImage ? user.profileImage : '/images/default-user.png' %>" 
        class="nav-profile-img"
        alt="Profile"
      >

      <span class="nav-username">
        <%= user.name %>
      </span>

    </a>

  <% } else { %>

    <a href="/login" class="login-link-btn">Login</a>

  <% } %>

</div>
    
    <div style="position:relative; cursor:pointer">
      🛒<span style="position:absolute; top:-12px; right:-10px; background:var(--primary-green); border-radius:50%; padding:2px 6px; font-size:10px; color:white;">2</span>
    </div>
  </div>
</header>