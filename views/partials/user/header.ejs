<link rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
  rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  .navbar {
    background: #ffffff !important;
    border-bottom: 0.5px solid #e0e0e0;
    padding: 10px 5% !important;
    height: auto;
    min-height: 80px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .logo {
    color: #000000 !important;
    font-family: 'Playfair Display', serif;
    font-size: 28px !important;
    letter-spacing: 4px;
    font-weight: 400 !important;
    cursor: pointer;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 30px;
  }

  .nav-links a {
    color: #000000 !important;
    text-transform: uppercase;
    font-size: 11px !important;
    letter-spacing: 2px;
    font-weight: 500;
    text-decoration: none;
    transition: 0.3s;
  }

  .nav-links a:hover {
    text-decoration: underline;
  }

  .nav-tools {
    display: flex;
    align-items: center;
    gap: 25px;
  }

  .search-bar {
    border-bottom: 1px solid #000;
    padding: 5px 0;
    display: flex;
    align-items: center;
  }

  .search-bar input {
    background: transparent;
    border: none;
    color: #000 !important;
    outline: none;
    width: 120px;
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .auth-group {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .profile-box {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #000;
  }

  .nav-profile-img {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid #000;
  }

  .nav-username {
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 500;
  }

  .login-link-btn {
    background: #000;
    color: #fff !important;
    padding: 8px 20px;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    text-decoration: none;
    font-weight: 600;
  }

  .cart-count-badge {
    position: absolute;
    background: #000;
    color: #fff;
    border-radius: 50%;
    min-width: 14px;
    height: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    font-weight: 700;
    top: -8px;
    right: -8px;
  }
</style>

<header class="navbar">
  <div class="logo" onclick="location.href='/'">SNOVA</div>

  <nav class="nav-links">
    <a href="/">Home</a>
    <a href="/products">New In</a>
    <a href="/category">Categories</a>
  </nav>

  <div class="nav-tools">
    <div class="search-bar">
      <input type="text" placeholder="SEARCH">
    </div>

    <a href="/wishlist" style="position:relative; color:#000; text-decoration:none;" title="Wishlist">
      <i class="fa-regular fa-heart" style="font-size: 18px;"></i>
      <span id="wishlistCountBadge" class="cart-count-badge" style="<%= (typeof wishlistCount === 'undefined' || wishlistCount === 0) ? 'display: none;' : '' %>">
        <%= (typeof wishlistCount !== 'undefined') ? wishlistCount : '' %>
      </span>
    </a>


    <div style="position:relative;">
      <a href="/cart" style="color:#000; text-decoration:none;">
        <i class="fa-solid fa-bag-shopping" style="font-size: 20px;"></i>
      </a>
      <span id="cartCountBadge" class="cart-count-badge" style="<%= (typeof cartCount === 'undefined' || cartCount === 0) ? 'display: none;' : '' %>">
        <%= (typeof cartCount !== 'undefined') ? (cartCount > 99 ? '99+' : cartCount) : '' %>
      </span>

    </div>

    <div class="auth-group">
      <% if (user) { %>
        <a href="/profile" class="profile-box">
          <% 
            let profileSrc = user.profileImage;
            if (profileSrc && profileSrc !== 'undefined' && profileSrc !== 'null' && profileSrc.trim() !== '') {
              if (!profileSrc.startsWith('/') && !profileSrc.startsWith('http')) {
                profileSrc = '/uploads/' + profileSrc;
              }
            } else {
              profileSrc = null;
            }
          %>
          <img
            src="<%= profileSrc ? profileSrc : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name || '') %>"
            class="nav-profile-img" 
            alt="Profile" 
            data-path="<%= profileSrc %>"
            onerror="this.onerror=null; console.log('Profile image failed to load:', this.src); this.src='https://ui-avatars.com/api/?name=' + encodeURIComponent('<%= (user.name || "").replace(/'/g, "\\'") %>')"/>
          <span class="nav-username">
            <%= user.name %>
          </span>
        </a>
        <% } else { %>
          <a href="/login" class="login-link-btn">Login</a>
          <% } %>
    </div>

  </div>
</header>

<script>
  function updateCartBadge(count) {
    const badge = document.getElementById('cartCountBadge');
    if (badge) {
      if (count > 0) {
        badge.textContent = count > 99 ? '99+' : count;
        badge.style.display = 'flex';
      } else {
        badge.style.display = 'none';
      }
    }
  }

  function updateWishlistBadge(count) {
    const badge = document.getElementById('wishlistCountBadge');
    if (badge) {
      if (count > 0) {
        badge.textContent = count;
        badge.style.display = 'flex';
      } else {
        badge.style.display = 'none';
      }
    }
  }
</script>