<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

<style>
    :root {
        --admin-bg: #fff;
        --sidebar-border: #eee;
        --accent-black: #000;
        --muted-text: #999;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Inter', sans-serif;
    }

    body {
        background-color: #fbfbfb;
        display: flex;
        min-height: 100vh;
    }

    /* SIDEBAR */
    .sidebar {
        width: 280px;
        background: var(--admin-bg);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        border-right: 0.5px solid var(--sidebar-border);
        padding: 40px 0;
        height: 100vh;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .logo-box {
        padding: 0 40px 50px;
    }

    .admin-logo {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        letter-spacing: 4px;
        font-weight: 700;
        text-transform: uppercase;
        color: #000;
        text-decoration: none;
    }

    .nav-group {
        display: flex;
        flex-direction: column;
        padding: 0 20px;
    }

    .nav-heading {
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--muted-text);
        margin: 20px 20px 15px;
        font-weight: 700;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 12px 20px;
        text-decoration: none;
        color: #000;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 500;
        transition: 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        border-radius: 4px;
    }

    .nav-item i, .nav-item .material-symbols-outlined {
        font-size: 18px;
        width: 20px;
    }

    .nav-item:hover {
        background: #f5f5f5;
        padding-left: 25px;
    }

    .nav-item.active {
        background: #000;
        color: #fff;
    }

    /* FOOTER PROFILE */
    .admin-profile {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 20px 30px;
        border-top: 0.5px solid var(--sidebar-border);
        margin-top: 40px;
    }

    .admin-avatar {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #eee;
    }

    .admin-info h4 {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0;
        font-weight: 700;
    }

    .admin-info p {
        font-size: 0.6rem;
        color: var(--muted-text);
        margin: 0;
        text-transform: lowercase;
    }

    .sign-out-btn {
        margin-left: auto;
        color: #999;
        font-size: 14px;
        cursor: pointer;
        transition: 0.3s;
    }

    .sign-out-btn:hover { color: #000; }

    /* Admin Responsiveness Styles */
    .admin-mobile-header {
        display: none;
    }

    @media (max-width: 992px) {
        body {
            flex-direction: column !important;
        }

        .sidebar {
            position: fixed !important;
            left: -280px !important;
            top: 0 !important;
            z-index: 2000 !important;
            transition: left 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) !important;
            box-shadow: 5px 0 25px rgba(0,0,0,0.15) !important;
        }

        .sidebar.active {
            left: 0 !important;
        }

        .admin-mobile-header {
            display: flex !important;
            align-items: center;
            justify-content: space-between;
            background: #ffffff;
            padding: 15px 20px;
            border-bottom: 0.5px solid var(--sidebar-border);
            position: sticky;
            top: 0;
            z-index: 999;
            width: 100%;
        }

        .admin-main {
            padding: 20px !important;
        }

        .dash-header {
            flex-direction: column !important;
            align-items: flex-start !important;
            gap: 15px !important;
            margin-bottom: 30px !important;
        }

        .stats-grid {
            grid-template-columns: 1fr !important;
            gap: 15px !important;
        }

        .analytics-grid {
            grid-template-columns: 1fr !important;
            gap: 20px !important;
        }

        /* Adjust forms and card layouts globally in admin */
        .card {
            padding: 20px !important;
        }

        .table-responsive, table {
            display: block;
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .btn-action {
            width: 100%;
            text-align: center;
        }

        .header-actions {
            width: 100%;
            flex-direction: column;
            gap: 10px;
        }
    }
</style>

<div class="admin-mobile-header">
    <button class="admin-hamburger-btn" onclick="toggleAdminSidebar(event)" style="background: none; border: none; font-size: 20px; cursor: pointer; color: #000;">
        <i class="fa-solid fa-bars"></i>
    </button>
    <a href="/admin/dashboard" class="admin-logo" style="font-size: 1.1rem; letter-spacing: 2px;">SNOVA</a>
    <div style="width: 20px;"></div>
</div>

<aside class="sidebar" id="adminSidebar">
    <div>
        <div class="logo-box">
            <a href="/admin/dashboard" class="admin-logo">SNOVA</a>
            <div style="font-size: 0.5rem; letter-spacing: 2px; color: #999; margin-top: 4px;">ADMINISTRATION</div>
        </div>

        <nav class="nav-group">
            <h3 class="nav-heading">Management</h3>

            <a href="/admin/dashboard" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'dashboard') ? 'active' : '' %>">
                <i class="fa-solid fa-chart-line"></i> Dashboard
            </a>

            <a href="/admin/orders" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'orders') ? 'active' : '' %>">
                <i class="fa-solid fa-bag-shopping"></i> Orders
            </a>

            <a href="/admin/product" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'products') ? 'active' : '' %>">
                <i class="fa-solid fa-shirt"></i> Products
            </a>

            <a href="/admin/category" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'categories') ? 'active' : '' %>">
                <i class="fa-solid fa-layer-group"></i> Categories
            </a>

            <a href="/admin/coupons" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'coupons') ? 'active' : '' %>">
                <i class="fa-solid fa-ticket"></i> Coupons
            </a>

            <a href="/admin/offers" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'offers') ? 'active' : '' %>">
                <i class="fa-solid fa-tags"></i> Offers
            </a>

            <a href="/admin/usermanagement" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'customers') ? 'active' : '' %>">
                <i class="fa-solid fa-users"></i> Customers
            </a>


        </nav>
    </div>

    <div class="admin-profile">
        <img src="https://ui-avatars.com/api/?name=Admin&background=000&color=fff" class="admin-avatar">
        <div class="admin-info">
            <h4>Admin Snova</h4>
            <p>admin@snova.com</p>
        </div>
        <a href="/admin/logout" class="sign-out-btn" title="Sign Out">
            <i class="fa-solid fa-right-from-bracket"></i>
        </a>
    </div>
</aside>

<script>
    function toggleAdminSidebar(event) {
        event.stopPropagation();
        const sidebar = document.getElementById('adminSidebar');
        sidebar.classList.toggle('active');
        const icon = event.currentTarget.querySelector('i');
        if (sidebar.classList.contains('active')) {
            icon.className = 'fa-solid fa-xmark';
        } else {
            icon.className = 'fa-solid fa-bars';
        }
    }

    // Close admin sidebar when clicking outside
    window.addEventListener('click', function(event) {
        const sidebar = document.getElementById('adminSidebar');
        if (sidebar && sidebar.classList.contains('active')) {
            if (!event.target.closest('#adminSidebar') && !event.target.closest('.admin-hamburger-btn')) {
                sidebar.classList.remove('active');
                const btnIcon = document.querySelector('.admin-hamburger-btn i');
                if (btnIcon) btnIcon.className = 'fa-solid fa-bars';
            }
        }
    });
</script>